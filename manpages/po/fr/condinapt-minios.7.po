#. type: SS
#: condinapt-minios.7:260
#, no-wrap
msgid "Module Environment Variables"
msgstr "Variables d'environnement des modules"

#. type: Plain text
#: condinapt-minios.7:263
msgid "Within the MiniOS module context, the following variables are available:"
msgstr "Dans le contexte d'un module MiniOS, les variables suivantes sont disponibles :"

#. type: TP
#: condinapt-minios.7:263
#, no-wrap
msgid "\\f[B]$CWD\\fR"
msgstr "\\f[B]$CWD\\fR"

#. type: Plain text
#: condinapt-minios.7:266
msgid "Current module directory"
msgstr "Répertoire courant du module"

#. type: TP
#: condinapt-minios.7:266
#, no-wrap
msgid "\\f[B]$LIVEKITNAME\\fR"
msgstr "\\f[B]$LIVEKITNAME\\fR"

#. type: Plain text
#: condinapt-minios.7:269
msgid "System name (usually \\[lq]minios\\[rq])"
msgstr "Nom du système (généralement \\[lq]minios\\[rq])"

#. type: TP
#: condinapt-minios.7:269
#, no-wrap
msgid "\\f[B]$MODULE\\fR"
msgstr "\\f[B]$MODULE\\fR"

#. type: Plain text
#: condinapt-minios.7:272
msgid "Current module name"
msgstr "Nom courant du module"

#. type: SS
#: condinapt-minios.7:272
#, no-wrap
msgid "Using minioslib"
msgstr "Utilisation de minioslib"

#. type: Plain text
#: condinapt-minios.7:275
msgid "Example installation script with conditional execution:"
msgstr "Exemple de script d'installation avec exécution conditionnelle :"

#. type: Plain text
#: condinapt-minios.7:289
#, no-wrap
msgid ""
"\\f[C]# Check module conditions\n"
"if [ \\[dq]$PACKAGE_VARIANT\\[dq] = \\[dq]minimum\\[dq] ] && [ \\[dq]$DESKTOP_ENVIRONMENT\\[dq] = \\[dq]core\\[dq] ]; then\n"
"    echo \\[dq]Skipping module for minimal core build\\[dq]\n"
"    exit 0\n"
"fi\\fR\n"
msgstr ""
"\\f[C]# Vérifier les conditions du module\n"
"if [ \\[dq]$PACKAGE_VARIANT\\[dq] = \\[dq]minimum\\[dq] ] && [ \\[dq]$DESKTOP_ENVIRONMENT\\[dq] = \\[dq]core\\[dq] ]; then\n"
"    echo \\[dq]Module ignoré pour une construction core minimale\\[dq]\n"
"    exit 0\n"
"fi\\fR\n"

#. type: Plain text
#: condinapt-minios.7:296
#, no-wrap
msgid ""
"\\f[C]# Install packages\n"
"/usr/share/minios-live/condinapt \\[rs]\n"
"    -l \\[dq]$CWD/packages.list\\[dq] \\[rs]\n"
"    -c /etc/minios-live/build.conf \\[rs]\n"
"    -m /usr/share/minios-live/condinapt.map\\fR\n"
"\n"
msgstr ""
"\\f[C]# Installer les paquets\n"
"/usr/share/minios-live/condinapt \\[rs]\n"
"    -l \\[dq]$CWD/packages.list\\[dq] \\[rs]\n"
"    -c /etc/minios-live/build.conf \\[rs]\n"
"    -m /usr/share/minios-live/condinapt.map\\fR\n"
"\n"

#. type: TP
#: condinapt-minios.7:298
#, no-wrap
msgid "\\f[B]/etc/minios-live/build.conf\\fR"
msgstr "\\f[B]/etc/minios-live/build.conf\\fR"

#. type: Plain text
#: condinapt-minios.7:301
msgid "Main MiniOS build configuration file"
msgstr "Fichier principal de configuration de construction MiniOS"

#. type: TP
#: condinapt-minios.7:301
#, no-wrap
msgid "\\f[B]/usr/share/minios-live/condinapt.map\\fR"
msgstr "\\f[B]/usr/share/minios-live/condinapt.map\\fR"

#. type: Plain text
#: condinapt-minios.7:304
msgid "Filter mapping for MiniOS build system"
msgstr "Mappage des filtres pour le système de construction MiniOS"

#. type: TP
#: condinapt-minios.7:304
#, no-wrap
msgid "\\f[B]/usr/share/minios-live/scripts/XX-module-name/packages.list\\fR"
msgstr "\\f[B]/usr/share/minios-live/scripts/XX-module-name/packages.list\\fR"

