msgstr "\\f[B]current\\f[R] : bullseye, bookworm, focal, jammy, noble\\fR"

#. type: Plain text
#: condinapt-minios.7:137
msgid "\\f[B]future\\f[R]: trixie, kali-rolling, sid\\fR"
msgstr "\\f[B]future\\f[R] : trixie, kali-rolling, sid\\fR"

#. type: SS
#: condinapt-minios.7:139
#, no-wrap
msgid "Multimedia Module"
msgstr "Module Multimédia"

#. type: Plain text
#: condinapt-minios.7:153
#, no-wrap
msgid ""
"\\f[C]# Additional codecs - not for minimal variant\n"
"gstreamer1.0-plugins-bad -pv=minimum\n"
"gstreamer1.0-plugins-ugly -pv=minimum\n"
"gstreamer1.0-libav -pv=minimum\\fR\n"
msgstr ""
"\\f[C]# Codecs supplémentaires – non inclus pour la variante minimale\n"
"gstreamer1.0-plugins-bad -pv=minimum\n"
"gstreamer1.0-plugins-ugly -pv=minimum\n"
"gstreamer1.0-libav -pv=minimum\\fR\n"

#. type: Plain text
#: condinapt-minios.7:161
#, no-wrap
msgid ""
"\\f[C]# Professional tools - only for toolbox and ultra\n"
"audacity +{pv=toolbox|pv=ultra}\n"
"kdenlive +{pv=toolbox|pv=ultra} +{de=xfce|de=lxqt}\n"
"---\n"
"# Distribution-specific packages from backports\n"
"ffmpeg \\[at]bookworm-backports +d=bookworm\\fR\n"
"\n"
msgstr ""
"\\f[C]# Outils professionnels – uniquement pour toolbox et ultra\n"
"audacity +{pv=toolbox|pv=ultra}\n"
"kdenlive +{pv=toolbox|pv=ultra} +{de=xfce|de=lxqt}\n"
"---\n"
"# Paquets spécifiques à la distribution depuis backports\n"
"ffmpeg \\[at]bookworm-backports +d=bookworm\\fR\n"
"\n"

#. type: SS
#: condinapt-minios.7:162
#, no-wrap
msgid "Driver Module"
msgstr "Module Pilotes"

#. type: Plain text
#: condinapt-minios.7:171
#, no-wrap
msgid ""
"\\f[C]\n"
"# Basic drivers\n"
"mesa-utils\n"
"xserver-xorg-video-all\\fR\n"
msgstr ""
"\\f[C]\n"
"# Pilotes de base\n"
"mesa-utils\n"
"xserver-xorg-video-all\\fR\n"

#. type: Plain text
#: condinapt-minios.7:174
#, no-wrap
msgid ""
"\\f[C]# NVIDIA drivers - only for non-free distributions\n"
"nvidia-driver +d=bookworm -{pv=minimum&de=core}\\fR\n"
msgstr ""
"\\f[C]# Pilotes NVIDIA – uniquement pour les distributions non-free\n"
"nvidia-driver +d=bookworm -{pv=minimum&de=core}\\fR\n"

#. type: Plain text
#: condinapt-minios.7:178
#, no-wrap
msgid ""
"\\f[C]# AMD drivers - for modern distributions\n"
"firmware-amd-graphics +{d=trixie|d=noble}\n"
"mesa-vulkan-drivers +{d=trixie|d=noble}\\fR\n"
msgstr ""
"\\f[C]# Pilotes AMD – pour les distributions récentes\n"
"firmware-amd-graphics +{d=trixie|d=noble}\n"
"mesa-vulkan-drivers +{d=trixie|d=noble}\\fR\n"

#. type: Plain text
#: condinapt-minios.7:182
#, no-wrap
msgid ""
"\\f[C]# Old drivers - for old systems\n"
"xserver-xorg-video-radeon +d=bookworm\\fR\n"
"\n"
msgstr ""
"\\f[C]# Anciens pilotes – pour les systèmes anciens\n"
"xserver-xorg-video-radeon +d=bookworm\\fR\n"
"\n"

#. type: SS
#: condinapt-minios.7:183
#, no-wrap
msgid "Localization Module"
msgstr "Module de Localisation"

#. type: Plain text
#: condinapt-minios.7:191
#, no-wrap
msgid ""
"\\f[C]\n"
"# Basic locales - always\n"
"locales\\fR\n"
msgstr ""
"\\f[C]\n"
"# Locales de base – toujours incluses\n"
"locales\\fR\n"

#. type: Plain text
#: condinapt-minios.7:196
#, no-wrap
msgid ""
"\\f[C]# Russian localization\n"
"language-pack-ru +lo=ru_RU\n"
"fonts-liberation +lo=ru_RU\n"
"firefox-esr-l10n-ru +lo=ru_RU +{de=xfce|de=lxqt}\\fR\n"
msgstr ""
"\\f[C]# Localisation russe\n"
"language-pack-ru +lo=ru_RU\n"
"fonts-liberation +lo=ru_RU\n"
"firefox-esr-l10n-ru +lo=ru_RU +{de=xfce|de=lxqt}\\fR\n"

#. type: Plain text
#: condinapt-minios.7:200
#, no-wrap
msgid ""
"\\f[C]# Multilingual support\n"
"task-russian +ml=true +lo=ru_RU\n"
"hunspell-ru +ml=true +lo=ru_RU\\fR\n"
msgstr ""
"\\f[C]# Prise en charge multilingue\n"
"task-russian +ml=true +lo=ru_RU\n"
"hunspell-ru +ml=true +lo=ru_RU\\fR\n"

#. type: Plain text
#: condinapt-minios.7:203
#, no-wrap
msgid ""
"\\f[C]# Keeping locales\n"
"vlc-l10n +kl=true +{pv=toolbox|pv=ultra}\\fR\n"
msgstr ""
"\\f[C]# Conservation des locales\n"
"vlc-l10n +kl=true +{pv=toolbox|pv=ultra}\\fR\n"

#. type: Plain text
#: condinapt-minios.7:209
#, no-wrap
msgid ""
"\\f[C]# Regional settings for different locales\n"
"language-pack-pt +lo=pt_BR\n"
"language-pack-de +lo=de_DE\n"
"language-pack-fr +lo=fr_FR\\fR\n"
"\n"
msgstr ""
"\\f[C]# Paramètres régionaux pour différentes locales\n"
"language-pack-pt +lo=pt_BR\n"
"language-pack-de +lo=de_DE\n"
"language-pack-fr +lo=fr_FR\\fR\n"
"\n"

#. type: SS
#: condinapt-minios.7:210
#, no-wrap
msgid "Advanced Filter Usage"
msgstr "Utilisation avancée des filtres"

#. type: Plain text
#: condinapt-minios.7:219
#, no-wrap
msgid ""
"\\f[C]\n"
"# DKMS modules with kernel and distribution conditions\n"
"ntfs3-dkms -ka=true -d=buster -d=trixie -d=sid\n"
"zfs-dkms +{pv=toolbox|pv=ultra} +da=amd64 +kbd=true -kf=none\\fR\n"
msgstr ""
"\\f[C]\n"
"# Modules DKMS avec conditions sur le noyau et la distribution\n"
"ntfs3-dkms -ka=true -d=buster -d=trixie -d=sid\n"
"zfs-dkms +{pv=toolbox|pv=ultra} +da=amd64 +kbd=true -kf=none\\fR\n"

#. type: Plain text
#: condinapt-minios.7:223
#, no-wrap
msgid ""
"\\f[C]# Drivers for old systems\n"
"broadcom-sta-dkms -d=jammy -ka=true -da=i386\n"
"aufs-dkms +dt=debian +d=buster\\fR\n"
msgstr ""
"\\f[C]# Pilotes pour anciens systèmes\n"
"broadcom-sta-dkms -d=jammy -ka=true -da=i386\n"
"aufs-dkms +dt=debian +d=buster\\fR\n"

#. type: Plain text
#: condinapt-minios.7:227
#, no-wrap
msgid ""
"\\f[C]# Exclusion for new distributions\n"
"realtek-rtl8821cu-dkms -d=trixie -d=sid\n"
"firmware-b43-installer -d=bionic\\fR\n"
msgstr ""
"\\f[C]# Exclusion pour les nouvelles distributions\n"
"realtek-rtl8821cu-dkms -d=trixie -d=sid\n"
"firmware-b43-installer -d=bionic\\fR\n"

#. type: Plain text
#: condinapt-minios.7:230
#, no-wrap
msgid ""
"\\f[C]# Complex alternatives with filters\n"
"exfatprogs -pv=minimum || exfat-utils -pv=minimum && exfat-fuse -pv=minimum\\fR\n"
msgstr ""
"\\f[C]# Alternatives complexes avec filtres\n"
"exfatprogs -pv=minimum || exfat-utils -pv=minimum && exfat-fuse -pv=minimum\\fR\n"

#. type: Plain text
#: condinapt-minios.7:237
#, no-wrap
msgid ""
"\\f[C]# Localization with exclusions and conditions\n"
"vlc-l10n -lo=en_US +{pv=toolbox|pv=ultra}\n"
"language-pack-gnome-ru-base +lo=ru_RU +dt=ubuntu\n"
"language-pack-gnome-ru-base +ml=true +dt=ubuntu\n"
"language-pack-gnome-ru-base +kl=true +dt=ubuntu\\fR\n"
"\n"
msgstr ""
"\\f[C]# Localisation avec exclusions et conditions\n"
"vlc-l10n -lo=en_US +{pv=toolbox|pv=ultra}\n"
"language-pack-gnome-ru-base +lo=ru_RU +dt=ubuntu\n"
"language-pack-gnome-ru-base +ml=true +dt=ubuntu\n"
"language-pack-gnome-ru-base +kl=true +dt=ubuntu\\fR\n"
"\n"

