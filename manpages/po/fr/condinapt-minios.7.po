#: condinapt-minios.7:307
msgid "Package list for each module"
msgstr "Liste des paquets pour chaque module"

#. type: TP
#: condinapt-minios.7:307
#, no-wrap
msgid "\\f[B]/usr/share/minios-live/scripts/XX-module-name/install\\fR"
msgstr "\\f[B]/usr/share/minios-live/scripts/XX-module-name/install\\fR"

