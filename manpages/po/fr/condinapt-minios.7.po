#, no-wrap
msgid "MiniOS CondinAPT Integration"
msgstr "Intégration CondinAPT pour MiniOS"

#. type: Plain text
#: condinapt-minios.7:22
msgid "condinapt-minios - CondinAPT integration in the MiniOS build system"
msgstr "condinapt-minios - Intégration CondinAPT dans le système de construction MiniOS"

#. type: Plain text
#: condinapt-minios.7:26
msgid "This document describes the specific aspects of using \\f[B]condinapt\\f[R](1) in the MiniOS build system.\\fR"
msgstr "Ce document décrit les aspects spécifiques de l'utilisation de \\f[B]condinapt\\f[R](1) dans le système de construction MiniOS.\\fR"

#. type: Plain text
#: condinapt-minios.7:28
msgid "For basic CondinAPT features, see \\f[B]condinapt\\f[R](1).\\fR"
msgstr "Pour les fonctionnalités de base de CondinAPT, voir \\f[B]condinapt\\f[R](1).\\fR"

#. type: SH
#: condinapt-minios.7:28
#, no-wrap
msgid "INTEGRATION WITH MINIOS BUILD SYSTEM"
msgstr "INTÉGRATION AU SYSTÈME DE CONSTRUCTION MINIOS"

#. type: SS
#: condinapt-minios.7:29
#, no-wrap
msgid "Usage in MiniOS Modules"
msgstr "Utilisation dans les modules MiniOS"

#. type: Plain text
#: condinapt-minios.7:34
msgid "CondinAPT is a standard tool for package installation in MiniOS modules.  It integrates into the build process through the standard module interface."
msgstr "CondinAPT est un outil standard pour l'installation de paquets dans les modules MiniOS. Il s'intègre au processus de construction via l'interface standard des modules."

#. type: Plain text
#: condinapt-minios.7:36
msgid "In the module installation script (\\f[B]install\\f[R]):\\fR"
msgstr "Dans le script d'installation du module (\\f[B]install\\f[R]) : \\fR"

#. type: Plain text
#: condinapt-minios.7:41 condinapt-minios.7:280
#, no-wrap
msgid ""
"\\f[C]\n"
"#!/bin/bash\n"
"set -e\\fR\n"
msgstr ""
"\\f[C]\n"
"#!/bin/bash\n"
"set -e\\fR\n"

#. type: Plain text
#: condinapt-minios.7:44 condinapt-minios.7:283
#, no-wrap
msgid ""
"\\f[C]# Load MiniOS library\n"
"\\&. /minioslib || exit 1\\fR\n"
msgstr ""
"\\f[C]# Charger la bibliothèque MiniOS\n"
"\\&. /minioslib || exit 1\\fR\n"

#. type: Plain text
#: condinapt-minios.7:51
#, no-wrap
msgid ""
"\\f[C]# Install packages via CondinAPT\n"
"/usr/share/minios-live/condinapt \\[rs]\n"
"    -l \\[dq]$CWD/packages.list\\[dq] \\[rs]\n"
"    -c /etc/minios-live/build.conf \\[rs]\n"
"    -m /usr/share/minios-live/condinapt.map\\fR\n"
"\n"
msgstr ""
"\\f[C]# Installer les paquets via CondinAPT\n"
"/usr/share/minios-live/condinapt \\[rs]\n"
"    -l \\[dq]$CWD/packages.list\\[dq] \\[rs]\n"
"    -c /etc/minios-live/build.conf \\[rs]\n"
"    -m /usr/share/minios-live/condinapt.map\\fR\n"
"\n"

#. type: SS
#: condinapt-minios.7:52
#, no-wrap
msgid "MiniOS Module Structure"
msgstr "Structure d'un module MiniOS"

#. type: Plain text
#: condinapt-minios.7:56
msgid "Each module in \\f[B]/usr/share/minios-live/scripts/\\f[R] follows a standardized structure:\\fR"
msgstr "Chaque module dans \\f[B]/usr/share/minios-live/scripts/\\f[R] suit une structure standardisée : \\fR"

#. type: Plain text
#: condinapt-minios.7:65
#, no-wrap
msgid ""
"\\f[C]\n"
"XX-module-name/\n"
"\\[u251C]\\[u2500]\\[u2500] packages.list                     # Package list with conditions\n"
"\\[u251C]\\[u2500]\\[u2500] install                           # Installation script (uses CondinAPT)\n"
"\\[u251C]\\[u2500]\\[u2500] rootcopy-install/                 # (optional) Files to copy\n"
"\\[u2514]\\[u2500]\\[u2500] rootcopy-postinstall/             # (optional) Files after installation\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"XX-module-name/\n"
"\\[u251C]\\[u2500]\\[u2500] packages.list                     # Liste des paquets avec conditions\n"
"\\[u251C]\\[u2500]\\[u2500] install                           # Script d'installation (utilise CondinAPT)\n"
"\\[u251C]\\[u2500]\\[u2500] rootcopy-install/                 # (optionnel) Fichiers à copier\n"
"\\[u2514]\\[u2500]\\[u2500] rootcopy-postinstall/             # (optionnel) Fichiers après installation\\fR\n"
"\n"

