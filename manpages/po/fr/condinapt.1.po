#. type: TH
#: condinapt.1:17
#, no-wrap
msgid "CONDINAPT"
msgstr "CONDINAPT"

#. type: TH
#: condinapt.1:17
#, no-wrap
msgid "CondinAPT Package Manager"
msgstr "Gestionnaire de paquets CondinAPT"

#. type: Plain text
#: condinapt.1:23
msgid "condinapt - conditional package installation tool for Debian-like systems"
msgstr "condinapt \\- outil d'installation conditionnelle de paquets pour les systèmes de type Debian"

#. type: Plain text
#: condinapt.1:26
msgid "\\f[B]condinapt\\f[R] [\\f[I]OPTIONS\\f[R]]\\fR"
msgstr "\\f[B]condinapt\\f[R] [\\f[I]OPTIONS\\f[R]]\\fR"

#. type: Plain text
#: condinapt.1:33
msgid "\\f[B]CondinAPT\\f[R] is a versatile tool for automating package installation in any Debian-like system (Debian, Ubuntu, and their derivatives).  Its key feature is the ability to define complex conditions and rules for installing each package based on arbitrary system configurations.\\fR"
msgstr "\\f[B]CondinAPT\\f[R] est un outil polyvalent permettant d'automatiser l'installation de paquets sur tout système de type Debian (Debian, Ubuntu et leurs dérivés).  Sa fonctionnalité principale est la possibilité de définir des conditions et des règles complexes pour installer chaque paquet selon des configurations système arbitraires.\\fR"

#. type: SS
#: condinapt.1:33
#, no-wrap
msgid "Areas of Application"
msgstr "Domaines d'application"

#. type: Plain text
#: condinapt.1:36
msgid "Linux distribution build systems"
msgstr "Systèmes de construction de distributions Linux"

#. type: Plain text
#: condinapt.1:38
msgid "Automation of server and workstation setup"
msgstr "Automatisation de l'installation de serveurs et stations de travail"

#. type: Plain text
#: condinapt.1:40
msgid "Deployment of various system configurations"
msgstr "Déploiement de diverses configurations système"

#. type: Plain text
#: condinapt.1:42
msgid "Package management in Docker containers"
msgstr "Gestion des paquets dans les conteneurs Docker"

#. type: Plain text
#: condinapt.1:44
msgid "CI/CD pipelines for environment setup"
msgstr "Pipelines CI/CD pour la préparation d'environnements"

#. type: Plain text
#: condinapt.1:46
msgid "Creation of custom installation images"
msgstr "Création d'images d'installation personnalisées"

#. type: SS
#: condinapt.1:46
#, no-wrap
msgid "Key Features"
msgstr "Fonctionnalités principales"

#. type: Plain text
#: condinapt.1:50
msgid "\\f[B]Conditional Installation:\\f[R] Install packages based on flexible filters (+, -)\\fR"
msgstr "\\f[B]Installation conditionnelle :\\f[R] Installation des paquets selon des filtres flexibles (+, -)\\fR"

#. type: Plain text
#: condinapt.1:53
msgid "\\f[B]External Configuration:\\f[R] Complete separation of logic (package list) from data (system parameters)\\fR"
msgstr "\\f[B]Configuration externe :\\f[R] Séparation complète de la logique (liste de paquets) et des données (paramètres système)\\fR"

#. type: Plain text
#: condinapt.1:56
msgid "\\f[B]Installation Queues:\\f[R] Divide the process into sequential stages to resolve dependencies\\fR"
msgstr "\\f[B]Files d'installation :\\f[R] Découpage du processus en étapes séquentielles pour résoudre les dépendances\\fR"

#. type: Plain text
#: condinapt.1:59
msgid "\\f[B]Priority Queue:\\f[R] Guaranteed installation of critical packages first\\fR"
msgstr "\\f[B]File de priorité :\\f[R] Installation garantie des paquets critiques en premier\\fR"

#. type: Plain text
#: condinapt.1:62
msgid "\\f[B]Complex Logic:\\f[R] Support for \\[lq]AND\\[rq] (&&), \\[lq]OR\\[rq] (||) operators, as well as group filters (+{a|b}, -{a&b})\\fR"
msgstr "\\f[B]Logique complexe :\\f[R] Prise en charge des opérateurs \\[lq]AND\\[rq] (&&), \\[lq]OR\\[rq] (||), ainsi que des filtres de groupe (+{a|b}, -{a&b})\\fR"

#. type: Plain text
#: condinapt.1:65
msgid "\\f[B]Readability:\\f[R] Support for comments and empty lines to structure lists\\fR"
msgstr "\\f[B]Lisibilité :\\f[R] Prise en charge des commentaires et des lignes vides pour structurer les listes\\fR"

#. type: Plain text
#: condinapt.1:68
msgid "\\f[B]Backward Compatibility:\\f[R] Supports simple package lists without conditions\\fR"
msgstr "\\f[B]Rétrocompatibilité :\\f[R] Prend en charge les listes de paquets simples sans conditions\\fR"

#. type: TP
#: condinapt.1:69
#, no-wrap
msgid "\\f[B]-l\\f[R], \\f[B]--package-list\\f[R] \\f[I]PATH\\fR"
msgstr "\\f[B]-l\\f[R], \\f[B]--package-list\\f[R] \\f[I]PATH\\fR"

#. type: Plain text
#: condinapt.1:72
msgid "(Required) Path to the package list file"
msgstr "(Obligatoire) Chemin vers le fichier de liste de paquets"

#. type: TP
#: condinapt.1:72
#, no-wrap
msgid "\\f[B]-c\\f[R], \\f[B]--config\\f[R] \\f[I]PATH\\fR"
msgstr "\\f[B]-c\\f[R], \\f[B]--config\\f[R] \\f[I]PATH\\fR"

#. type: Plain text
#: condinapt.1:75
msgid "(Required) Path to the main configuration file"
msgstr "(Obligatoire) Chemin vers le fichier principal de configuration"

#. type: TP
#: condinapt.1:75
#, no-wrap
msgid "\\f[B]-m\\f[R], \\f[B]--filter-mapping\\f[R] \\f[I]PATH\\fR"
msgstr "\\f[B]-m\\f[R], \\f[B]--filter-mapping\\f[R] \\f[I]PATH\\fR"

#. type: Plain text
#: condinapt.1:78
msgid "(Optional) Path to the filter mapping file"
msgstr "(Optionnel) Chemin vers le fichier de correspondance des filtres"

#. type: TP
#: condinapt.1:78
#, no-wrap
msgid "\\f[B]-P\\f[R], \\f[B]--priority-list\\f[R] \\f[I]PATH\\fR"
msgstr "\\f[B]-P\\f[R], \\f[B]--priority-list\\f[R] \\f[I]PATH\\fR"

#. type: Plain text
#: condinapt.1:81
msgid "(Optional) Path to the priority package list file"
msgstr "(Optionnel) Chemin vers le fichier de liste de paquets prioritaires"

#. type: TP
#: condinapt.1:81
#, no-wrap
msgid "\\f[B]-s\\f[R], \\f[B]--simulation\\fR"
msgstr "\\f[B]-s\\f[R], \\f[B]--simulation\\fR"

#. type: Plain text
#: condinapt.1:85
msgid "Simulation mode.  Packages will not be installed"
msgstr "Mode simulation.  Les paquets ne seront pas installés"

#. type: TP
#: condinapt.1:85
#, no-wrap
msgid "\\f[B]-C\\f[R], \\f[B]--check-only\\fR"
msgstr "\\f[B]-C\\f[R], \\f[B]--check-only\\fR"

#. type: Plain text
#: condinapt.1:88
msgid "Only check if packages are already installed"
msgstr "Vérifie uniquement si les paquets sont déjà installés"

#. type: TP
#: condinapt.1:88
#, no-wrap
msgid "\\f[B]-v\\f[R], \\f[B]--verbose\\fR"
msgstr "\\f[B]-v\\f[R], \\f[B]--verbose\\fR"

#. type: Plain text
#: condinapt.1:91
msgid "Verbose output"
msgstr "Affichage détaillé"

#. type: TP
#: condinapt.1:91
#, no-wrap
msgid "\\f[B]-vv\\f[R], \\f[B]--very-verbose\\fR"
msgstr "\\f[B]-vv\\f[R], \\f[B]--very-verbose\\fR"

#. type: Plain text
#: condinapt.1:94
msgid "Very verbose output"
msgstr "Affichage très détaillé"

#. type: TP
#: condinapt.1:94
#, no-wrap
msgid "\\f[B]-x\\f[R], \\f[B]--xtrace\\fR"
msgstr "\\f[B]-x\\f[R], \\f[B]--xtrace\\fR"

#. type: Plain text
#: condinapt.1:97
msgid "Enable \\f[B]set -x\\f[R] command tracing\\fR"
msgstr "Active le traçage des commandes \\f[B]set -x\\f[R]\\fR"

#. type: TP
#: condinapt.1:97
#, no-wrap
msgid "\\f[B]-f\\f[R], \\f[B]--force\\fR"
msgstr "\\f[B]-f\\f[R], \\f[B]--force\\fR"

#. type: Plain text
#: condinapt.1:100
msgid "Force apt cache update (apt update)"
msgstr "Force la mise à jour du cache apt (apt update)"

#. type: TP
#: condinapt.1:100
#, no-wrap
msgid "\\f[B]-h\\f[R], \\f[B]--help\\fR"
msgstr "\\f[B]-h\\f[R], \\f[B]--help\\fR"

#. type: Plain text
#: condinapt.1:103
msgid "Show help"
msgstr "Afficher l'aide"

#. type: SH
#: condinapt.1:103
#, no-wrap
msgid "CORE COMPONENTS"
msgstr "COMPOSANTS PRINCIPAUX"

#. type: Plain text
#: condinapt.1:106
msgid "CondinAPT operates with four key files:"
msgstr "CondinAPT fonctionne avec quatre fichiers clés :"

#. type: SS
#: condinapt.1:106
#, no-wrap
msgid "condinapt script"
msgstr "script condinapt"

#. type: Plain text
#: condinapt.1:109
msgid "The core, containing all processing logic"
msgstr "Le cœur, contenant toute la logique de traitement"

#. type: SS
#: condinapt.1:109
#, no-wrap
msgid "Main configuration file (-c)"
msgstr "Fichier de configuration principal (-c)"

#. type: Plain text
#: condinapt.1:112
msgid "A file with bash variables describing the current environment"
msgstr "Un fichier contenant des variables bash décrivant l'environnement actuel"

#. type: Plain text
#: condinapt.1:114
msgid "Example (\\f[B]system.conf\\f[R]):\\fR"
msgstr "Exemple (\\f[B]system.conf\\f[R]) :\\fR"

#. type: Plain text
#: condinapt.1:123
#, no-wrap
msgid ""
"\\f[C]\n"
"DISTRIBUTION=\\[dq]bookworm\\[dq]\n"
"SYSTEM_TYPE=\\[dq]server\\[dq]\n"
"ENVIRONMENT=\\[dq]production\\[dq]\n"
"LOCALE=\\[dq]en_US\\[dq]\n"
"FEATURES=\\[dq]web,database\\[dq]\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"DISTRIBUTION=\\[dq]bookworm\\[dq]\n"
"SYSTEM_TYPE=\\[dq]server\\[dq]\n"
"ENVIRONMENT=\\[dq]production\\[dq]\n"
"LOCALE=\\[dq]en_US\\[dq]\n"
"FEATURES=\\[dq]web,database\\[dq]\\fR\n"
"\n"

#. type: SS
#: condinapt.1:124
#, no-wrap
msgid "Filter mapping file (-m)"
msgstr "Fichier de correspondance des filtres (-m)"

#. type: Plain text
#: condinapt.1:132
msgid "Links short prefixes (used in the package list) to variable names from the main configuration file.  This file is \\f[B]optional\\f[R].  If a filter is not present in the filter mapping file, it will be used as a variable name from the main configuration file.  If the variable is not found, CondinAPT will declare it empty.\\fR"
msgstr "Lie les préfixes courts (utilisés dans la liste des paquets) aux noms de variables du fichier de configuration principal.  Ce fichier est \\f[B]optionnel\\f[R].  Si un filtre n'est pas présent dans le fichier de correspondance, il sera utilisé comme nom de variable du fichier de configuration principal.  Si la variable n'est pas trouvée, CondinAPT la déclarera vide.\\fR"

#. type: Plain text
#: condinapt.1:134
msgid "Example (\\f[B]filters.map\\f[R]):\\fR"
msgstr "Exemple (\\f[B]filters.map\\f[R]) :\\fR"

#. type: Plain text
#: condinapt.1:143
#, no-wrap
msgid ""
"\\f[C]\n"
"d=DISTRIBUTION\n"
"st=SYSTEM_TYPE\n"
"env=ENVIRONMENT\n"
"arch=ARCHITECTURE\n"
"feat=FEATURES\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"d=DISTRIBUTION\n"
"st=SYSTEM_TYPE\n"
"env=ENVIRONMENT\n"
"arch=ARCHITECTURE\n"
"feat=FEATURES\\fR\n"
"\n"

#. type: SS
#: condinapt.1:144
#, no-wrap
msgid "Package list file (-l)"
msgstr "Fichier de liste des paquets (-l)"

#. type: Plain text
#: condinapt.1:147
msgid "The main file describing what to install and under what conditions"
msgstr "Le fichier principal décrivant quoi installer et sous quelles conditions"

#. type: SH
#: condinapt.1:147
#, no-wrap
msgid "PACKAGE LIST SYNTAX"
msgstr "SYNTAXE DE LA LISTE DES PAQUETS"

#. type: Plain text
#: condinapt.1:150
msgid "Each line in the package list file consists of two main parts:"
msgstr "Chaque ligne du fichier de liste des paquets se compose de deux parties principales :"

#. type: IP
#: condinapt.1:150
#, no-wrap
msgid "1."
msgstr "1."

#. type: Plain text
#: condinapt.1:152
msgid "Package name with optional version and release specification"
msgstr "Nom du paquet avec version et publication optionnelles"

#. type: IP
#: condinapt.1:152 condinapt.1:466
#, no-wrap
msgid "2."
msgstr "2."

#. type: Plain text
#: condinapt.1:155
msgid "Condition filters - define the conditions under which the package will be installed"
msgstr "Filtres de condition – définissent les conditions dans lesquelles le paquet sera installé"

#. type: SS
#: condinapt.1:155
#, no-wrap
msgid "Package Name Structure"
msgstr "Structure du nom du paquet"

#. type: Plain text
#: condinapt.1:158
msgid "\\f[B]Simple name:\\fR"
msgstr "\\f[B]Nom simple :\\fR"

#. type: Plain text
#: condinapt.1:163
#, no-wrap
msgid ""
"\\f[C]\n"
"vim\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"vim\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:166
msgid "\\f[B]Package version:\\fR"
msgstr "\\f[B]Version du paquet :\\fR"

#. type: Plain text
#: condinapt.1:170
msgid "\\f[B]package=version\\f[R] - loose version requirement.  If the required version is unavailable, an available version is installed\\fR"
msgstr "\\f[B]package=version\\f[R] – exigence de version souple.  Si la version requise n'est pas disponible, une version disponible sera installée\\fR"

#. type: Plain text
#: condinapt.1:173
msgid "\\f[B]package==version\\f[R] - strict requirement.  If the version is not found, installation aborts with an error\\fR"
msgstr "\\f[B]package==version\\f[R] – exigence stricte.  Si la version n'est pas trouvée, l'installation s'arrête avec une erreur\\fR"

#. type: Plain text
#: condinapt.1:175
msgid "\\f[B]Release specification:\\fR"
msgstr "\\f[B]Spécification de la version :\\fR"

#. type: Plain text
#: condinapt.1:177
msgid "The release is specified using the **\\[at]** symbol:"
msgstr "La version est spécifiée à l’aide du symbole **\\[at]** :"

#. type: Plain text
#: condinapt.1:183
#, no-wrap
msgid ""
"\\f[C]\n"
"telegram\\[at]bookworm-backports\n"
"kernel-image-6.5.0\\[at]trixie-backports\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"telegram\\[at]bookworm-backports\n"
"kernel-image-6.5.0\\[at]trixie-backports\\fR\n"
"\n"

#. type: SS
#: condinapt.1:184
#, no-wrap
msgid "File Structure"
msgstr "Structure du fichier"

#. type: Plain text
#: condinapt.1:188
msgid "\\f[B]Package names:\\f[R] Each package or condition is written on a new line\\fR"
msgstr "\\f[B]Noms de paquets :\\f[R] Chaque paquet ou condition est écrit sur une nouvelle ligne\\fR"

#. type: Plain text
#: condinapt.1:191
msgid "\\f[B]Comments:\\f[R] Lines starting with \\f[B]#\\f[R], or text after \\f[B]#\\f[R] on a line, are completely ignored\\fR"
msgstr "\\f[B]Commentaires :\\f[R] Les lignes débutant par \\f[B]#\\f[R], ou le texte après \\f[B]#\\f[R] sur une ligne, sont totalement ignorés\\fR"

#. type: Plain text
#: condinapt.1:193
msgid "\\f[B]Empty lines:\\f[R] Ignored and serve for visual separation\\fR"
msgstr "\\f[B]Lignes vides :\\f[R] Ignorées et servent à la séparation visuelle\\fR"

#. type: SS
#: condinapt.1:193
#, no-wrap
msgid "Filters and Conditions"
msgstr "Filtres et conditions"

#. type: SS
#: condinapt.1:194
#, no-wrap
msgid "Single Filters"
msgstr "Filtres simples"

#. type: Plain text
#: condinapt.1:198
msgid "\\f[B]+ (Positive):\\f[R] The condition is true if the variable value \\f[B]matches\\fR"
msgstr "\\f[B]+ (Positif) :\\f[R] La condition est vraie si la valeur de la variable \\f[B]correspond\\fR"

#. type: Plain text
#: condinapt.1:200
msgid "Format: \\f[B]+=\\fR"
msgstr "Format : \\f[B]+=\\fR"

#. type: Plain text
#: condinapt.1:202 condinapt.1:215 condinapt.1:306
msgid "Example:"
msgstr "Exemple :"

#. type: Plain text
#: condinapt.1:207
#, no-wrap
msgid ""
"\\f[C]\n"
"nginx +st=server\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"nginx +st=server\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:211
msgid "\\f[B]- (Negative):\\f[R] The condition is true if the variable value \\f[B]does not match\\fR"
msgstr "\\f[B]- (Négatif) :\\f[R] La condition est vraie si la valeur de la variable \\f[B]ne correspond pas\\fR"

#. type: Plain text
#: condinapt.1:213
msgid "Format: \\f[B]-=\\fR"
msgstr "Format : \\f[B]-=\\fR"

#. type: Plain text
#: condinapt.1:220
#, no-wrap
msgid ""
"\\f[C]\n"
"monitoring-tools -st=desktop\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"monitoring-tools -st=desktop\\fR\n"
"\n"

#. type: SS
#: condinapt.1:221
#, no-wrap
msgid "Group Filters"
msgstr "Filtres de groupe"

#. type: Plain text
#: condinapt.1:225
msgid "\\f[B]+{a|b} (OR for inclusion):\\f[R] True if \\f[B]at least one\\f[R] of the conditions in the group is true\\fR"
msgstr "\\f[B]+{a|b} (OU pour inclusion) :\\f[R] Vrai si \\f[B]au moins une\\f[R] des conditions du groupe est vraie\\fR"

#. type: Plain text
#: condinapt.1:230
#, no-wrap
msgid ""
"\\f[C]\n"
"web-server +{st=server|st=web-server}\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"web-server +{st=server|st=web-server}\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:234
msgid "\\f[B]+{a&b} (AND for inclusion):\\f[R] True only if \\f[B]all\\f[R] conditions in the group are true\\fR"
msgstr "\\f[B]+{a&b} (ET pour inclusion) :\\f[R] Vrai uniquement si \\f[B]toutes\\f[R] les conditions du groupe sont vraies\\fR"

#. type: Plain text
#: condinapt.1:239
#, no-wrap
msgid ""
"\\f[C]\n"
"database-tools +{d=bookworm&st=server}\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"database-tools +{d=bookworm&st=server}\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:243
msgid "\\f[B]-{a|b} (OR for exclusion):\\f[R] The package is excluded if \\f[B]at least one\\f[R] of the conditions is true\\fR"
msgstr "\\f[B]-{a|b} (OU pour exclusion) :\\f[R] Le paquet est exclu si \\f[B]au moins une\\f[R] des conditions est vraie\\fR"

#. type: Plain text
#: condinapt.1:248
#, no-wrap
msgid ""
"\\f[C]\n"
"debug-tools -{env=production|st=minimal}\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"debug-tools -{env=production|st=minimal}\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:252
msgid "\\f[B]-{a&b} (AND for exclusion):\\f[R] The package is excluded only if \\f[B]all\\f[R] conditions are true\\fR"
msgstr "\\f[B]-{a&b} (ET pour exclusion) :\\f[R] Le paquet est exclu uniquement si \\f[B]toutes\\f[R] les conditions sont vraies\\fR"

#. type: Plain text
#: condinapt.1:257
#, no-wrap
msgid ""
"\\f[C]\n"
"development-tools -{env=production&st=minimal}\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"development-tools -{env=production&st=minimal}\\fR\n"
"\n"

#. type: SS
#: condinapt.1:258
#, no-wrap
msgid "Logical Operators"
msgstr "Opérateurs logiques"

#. type: Plain text
#: condinapt.1:262
msgid "\\f[B]|| (OR / Fallback):\\f[R] Try to install the left part.  If it fails, try the right part\\fR"
msgstr "\\f[B]|| (OU / Repli) :\\f[R] Tente d’installer la partie gauche. Si cela échoue, tente la partie droite\\fR"

#. type: Plain text
#: condinapt.1:267
#, no-wrap
msgid ""
"\\f[C]\n"
"exfatprogs -d=bookworm || exfat-utils\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"exfatprogs -d=bookworm || exfat-utils\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:271
msgid "\\f[B]&& (AND / Conjunction):\\f[R] All parts must successfully pass filter checks\\fR"
msgstr "\\f[B]&& (ET / Conjonction) :\\f[R] Toutes les parties doivent réussir les vérifications de filtres\\fR"

#. type: Plain text
#: condinapt.1:276
#, no-wrap
msgid ""
"\\f[C]\n"
"nginx +st=web-server && php-fpm\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"nginx +st=web-server && php-fpm\\fR\n"
"\n"

#. type: SS
#: condinapt.1:277
#, no-wrap
msgid "Special Modifiers"
msgstr "Modificateurs spéciaux"

#. type: Plain text
#: condinapt.1:283
msgid "\\f[B]! (Mandatory Package):\\f[R] If a package is marked with \\f[B]!\\f[R], but cannot be found in repositories, CondinAPT will abort execution with an error\\fR"
msgstr "\\f[B]! (Paquet obligatoire) :\\f[R] Si un paquet est marqué avec \\f[B]!\\f[R], mais n’est pas trouvé dans les dépôts, CondinAPT interrompt l’exécution avec une erreur\\fR"

#. type: Plain text
#: condinapt.1:288
#, no-wrap
msgid ""
"\\f[C]\n"
"!essential-package\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"!essential-package\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:292
msgid "\\f[B]\\[at] (Release Specification):\\f[R] Install a package from a specific Debian/Ubuntu release\\fR"
msgstr "\\f[B]\\[at] (Spécification de version) :\\f[R] Installer un paquet depuis une version spécifique de Debian/Ubuntu\\fR"

#. type: Plain text
#: condinapt.1:297
#, no-wrap
msgid ""
"\\f[C]\n"
"kernel-image-6.5.0 \\[at]trixie-backports\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"kernel-image-6.5.0 \\[at]trixie-backports\\fR\n"
"\n"

#. type: SS
#: condinapt.1:298
#, no-wrap
msgid "Installation Queues"
msgstr "Files d’installation"

#. type: Plain text
#: condinapt.1:304
msgid "The \\f[B]\\[em]\\f[R] separator on a separate line divides the list into groups (queues).  Packages from one queue are installed together in a single apt call.  Queues are executed strictly sequentially.\\fR"
msgstr "Le séparateur \\f[B]\\[em]\\f[R] sur une ligne séparée divise la liste en groupes (files). Les paquets d’une file sont installés ensemble lors d’un seul appel à apt. Les files sont exécutées strictement de manière séquentielle.\\fR"

#. type: Plain text
#: condinapt.1:320
#, no-wrap
msgid ""
"\\f[C]\n"
"# Queue 1: Base system\n"
"systemd\n"
"network-manager\n"
"---\n"
"# Queue 2: Web server\n"
"nginx\n"
"php-fpm\n"
"---\n"
"# Queue 3: Monitoring\n"
"prometheus\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"# Queue 1: Base system\n"
"systemd\n"
"network-manager\n"
"---\n"
"# Queue 2: Web server\n"
"nginx\n"
"php-fpm\n"
"---\n"
"# Queue 3: Monitoring\n"
"prometheus\\fR\n"
"\n"

#. type: SS
#: condinapt.1:321
#, no-wrap
msgid "Priority Queue"
msgstr "File prioritaire"

#. type: Plain text
#: condinapt.1:326
msgid "Packages listed in the file specified by the \\f[B]-P\\f[R] flag (one package per line, no filters) form a special \\[lq]Queue #1\\[rq], which is executed first.\\fR"
msgstr "Les paquets listés dans le fichier spécifié par l’option \\f[B]-P\\f[R] (un paquet par ligne, sans filtres) constituent une \\[lq]Queue #1\\[rq] spéciale, qui est exécutée en premier.\\fR"

#. type: Plain text
#: condinapt.1:330
msgid "Any package from the priority list is automatically removed from all regular queues.  This ensures it will be installed unconditionally."
msgstr "Tout paquet figurant dans la liste de priorité est automatiquement retiré de toutes les files d’attente classiques.  Cela garantit son installation inconditionnelle."

#. type: SS
#: condinapt.1:331
#, no-wrap
msgid "Quick Start"
msgstr "Démarrage rapide"

#. type: Plain text
#: condinapt.1:334
msgid "Create the configuration file \\f[B]config.conf\\f[R]:\\fR"
msgstr "Créez le fichier de configuration \\f[B]config.conf\\f[R] :\\fR"

#. type: Plain text
#: condinapt.1:341
#, no-wrap
msgid ""
"\\f[C]\n"
"DISTRIBUTION=\\[dq]bookworm\\[dq]\n"
"SYSTEM_TYPE=\\[dq]server\\[dq]\n"
"ENVIRONMENT=\\[dq]production\\[dq]\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"DISTRIBUTION=\\[dq]bookworm\\[dq]\n"
"SYSTEM_TYPE=\\[dq]server\\[dq]\n"
"ENVIRONMENT=\\[dq]production\\[dq]\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:344
msgid "Create the package list \\f[B]packages.list\\f[R]:\\fR"
msgstr "Créez la liste de paquets \\f[B]packages.list\\f[R] :\\fR"

#. type: Plain text
#: condinapt.1:350
#, no-wrap
msgid ""
"\\f[C]\n"
"# Base packages - always installed\n"
"vim\n"
"curl\\fR\n"
msgstr ""
"\\f[C]\n"
"# Paquets de base – toujours installés\n"
"vim\n"
"curl\\fR\n"

#. type: Plain text
#: condinapt.1:354
#, no-wrap
msgid ""
"\\f[C]# Packages only for servers\n"
"nginx +SYSTEM_TYPE=server\n"
"mysql-server +SYSTEM_TYPE=server\\fR\n"
msgstr ""
"\\f[C]# Paquets uniquement pour les serveurs\n"
"nginx +SYSTEM_TYPE=server\n"
"mysql-server +SYSTEM_TYPE=server\\fR\n"

#. type: Plain text
#: condinapt.1:358
#, no-wrap
msgid ""
"\\f[C]# Exclude packages for production environment\n"
"debug-tools -ENVIRONMENT=production\\fR\n"
"\n"
msgstr ""
"\\f[C]# Exclure les paquets pour l’environnement de production\n"
"debug-tools -ENVIRONMENT=production\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:361
msgid "Run the installation:"
msgstr "Lancez l’installation :"

#. type: Plain text
#: condinapt.1:366
#, no-wrap
msgid ""
"\\f[C]\n"
"condinapt -l packages.list -c config.conf\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"condinapt -l packages.list -c config.conf\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:369
msgid "Or test in simulation mode:"
msgstr "Ou testez en mode simulation :"

#. type: Plain text
#: condinapt.1:374
#, no-wrap
msgid ""
"\\f[C]\n"
"condinapt -l packages.list -c config.conf -s\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"condinapt -l packages.list -c config.conf -s\\fR\n"
"\n"

#. type: SS
#: condinapt.1:375
#, no-wrap
msgid "Multimedia Server"
msgstr "Serveur multimédia"

#. type: Plain text
#: condinapt.1:378 condinapt.1:400 condinapt-minios.7:142
#: condinapt-minios.7:165 condinapt-minios.7:186 condinapt-minios.7:213
msgid "\\f[B]packages.list:\\fR"
msgstr "\\f[B]packages.list :\\fR"

#. type: Plain text
#: condinapt.1:384 condinapt-minios.7:148
#, no-wrap
msgid ""
"\\f[C]\n"
"# Basic multimedia codecs - always\n"
"gstreamer1.0-plugins-base\n"
"gstreamer1.0-plugins-good\\fR\n"
msgstr ""
"\\f[C]\n"
"# Codecs multimédia de base – toujours\n"
"gstreamer1.0-plugins-base\n"
"gstreamer1.0-plugins-good\\fR\n"

#. type: Plain text
#: condinapt.1:388
#, no-wrap
msgid ""
"\\f[C]# Additional codecs - not for minimal installation\n"
"gstreamer1.0-plugins-bad -st=minimal\n"
"gstreamer1.0-plugins-ugly -st=minimal\\fR\n"
msgstr ""
"\\f[C]# Codecs additionnels – non inclus pour une installation minimale\n"
"gstreamer1.0-plugins-bad -st=minimal\n"
"gstreamer1.0-plugins-ugly -st=minimal\\fR\n"

#. type: Plain text
#: condinapt.1:396
#, no-wrap
msgid ""
"\\f[C]# Professional tools - only for full configuration\n"
"ffmpeg +st=media-server\n"
"vlc +st=media-server\n"
"---\n"
"# Distribution-specific packages from backports\n"
"ffmpeg \\[at]bookworm-backports +d=bookworm\\fR\n"
"\n"
msgstr ""
"\\f[C]# Outils professionnels – uniquement pour la configuration complète\n"
"ffmpeg +st=media-server\n"
"vlc +st=media-server\n"
"---\n"
"# Paquets spécifiques à la distribution depuis backports\n"
"ffmpeg \\[at]bookworm-backports +d=bookworm\\fR\n"
"\n"

#. type: SS
#: condinapt.1:397
#, no-wrap
msgid "Web Server with Various Configurations"
msgstr "Serveur web avec diverses configurations"

#. type: Plain text
#: condinapt.1:406
#, no-wrap
msgid ""
"\\f[C]\n"
"# Basic web server components\n"
"nginx\n"
"openssl\\fR\n"
msgstr ""
"\\f[C]\n"
"# Composants de base pour serveur web\n"
"nginx\n"
"openssl\\fR\n"

#. type: Plain text
#: condinapt.1:410
#, no-wrap
msgid ""
"\\f[C]# Database - only for full installations\n"
"mysql-server +st=full-server -{env=minimal}\n"
"postgresql +st=database-server\\fR\n"
msgstr ""
"\\f[C]# Base de données – uniquement pour les installations complètes\n"
"mysql-server +st=full-server -{env=minimal}\n"
"postgresql +st=database-server\\fR\n"

#. type: Plain text
#: condinapt.1:414
#, no-wrap
msgid ""
"\\f[C]# PHP - for web servers\n"
"php-fpm +feat=php\n"
"php-mysql +{feat=php&st=full-server}\\fR\n"
msgstr ""
"\\f[C]# PHP – pour serveurs web\n"
"php-fpm +feat=php\n"
"php-mysql +{feat=php&st=full-server}\\fR\n"

#. type: Plain text
#: condinapt.1:418
#, no-wrap
msgid ""
"\\f[C]# Monitoring - not for development\n"
"prometheus-node-exporter -env=development\\fR\n"
"\n"
msgstr ""
"\\f[C]# Supervision – non inclus pour le développement\n"
"prometheus-node-exporter -env=development\\fR\n"
"\n"

#. type: SH
#: condinapt.1:419
#, no-wrap
msgid "OPERATING MODES"
msgstr "MODES DE FONCTIONNEMENT"

#. type: SS
#: condinapt.1:420
#, no-wrap
msgid "Simulation Mode"
msgstr "Mode simulation"

#. type: Plain text
#: condinapt.1:424
msgid "Allows you to see which packages will be installed without actually installing them:"
msgstr "Permet de voir quels paquets seront installés sans effectuer réellement l’installation :"

#. type: Plain text
#: condinapt.1:429
#, no-wrap
msgid ""
"\\f[C]\n"
"condinapt -l packages.list -c system.conf -s\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"condinapt -l packages.list -c system.conf -s\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:432
msgid "In simulation mode, the script exits with exit code 1."
msgstr "En mode simulation, le script se termine avec le code de sortie 1."

#. type: SS
#: condinapt.1:432
#, no-wrap
msgid "Check Mode"
msgstr "Mode vérification"

#. type: Plain text
#: condinapt.1:435
msgid "Checks which packages from the list are already installed on the system:"
msgstr "Vérifie quels paquets de la liste sont déjà installés sur le système :"

#. type: Plain text
#: condinapt.1:440
#, no-wrap
msgid ""
"\\f[C]\n"
"condinapt -l packages.list -c system.conf -C\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"condinapt -l packages.list -c system.conf -C\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:444
msgid "Shows errors for uninstalled packages and returns exit code 1 if there are uninstalled packages."
msgstr "Affiche des erreurs pour les paquets non installés et retourne le code de sortie 1 s’il y a des paquets non installés."

#. type: SS
#: condinapt.1:444
#, no-wrap
msgid "Debugging Modes"
msgstr "Modes de débogage"

#. type: Plain text
#: condinapt.1:447
msgid "\\f[B]Verbose Output (-v):\\fR"
msgstr "\\f[B]Affichage verbeux (-v) :\\fR"

#. type: Plain text
#: condinapt.1:450
msgid "Shows detailed information about filter checks and displays results for each package."
msgstr "Affiche des informations détaillées sur les vérifications de filtres et présente les résultats pour chaque paquet."

#. type: Plain text
#: condinapt.1:452
msgid "\\f[B]Very Verbose Output (-vv):\\fR"
msgstr "\\f[B]Affichage très verbeux (-vv) :\\fR"

#. type: Plain text
#: condinapt.1:454
msgid "Maximum process detail, shows all intermediate steps."
msgstr "Détail maximal du processus, affiche toutes les étapes intermédiaires."

#. type: Plain text
#: condinapt.1:456
msgid "\\f[B]Command Tracing (-x):\\fR"
msgstr "\\f[B]Traçage des commandes (-x) :\\fR"

#. type: Plain text
#: condinapt.1:459
msgid "Enables \\f[B]set -x\\f[R] for script debugging, shows each command being executed.\\fR"
msgstr "Active \\f[B]set -x\\f[R] pour le débogage du script, affiche chaque commande exécutée.\\fR"

#. type: SH
#: condinapt.1:459
#, no-wrap
msgid "ERROR HANDLING"
msgstr "GESTION DES ERREURS"

#. type: SS
#: condinapt.1:460
#, no-wrap
msgid "Mandatory Packages"
msgstr "Paquets obligatoires"

#. type: Plain text
#: condinapt.1:464
msgid "If a package is marked as mandatory (\\f[B]!\\f[R]) but not found in repositories, CondinAPT:\\fR"
msgstr "Si un paquet est marqué comme obligatoire (\\f[B]!\\f[R]) mais n'est pas trouvé dans les dépôts, CondinAPT :\\fR"

#. type: IP
#: condinapt.1:464
#, no-wrap
msgid "\\f[R]1.\\fR"
msgstr "\\f[R]1.\\fR"

#. type: Plain text
#: condinapt.1:466
msgid "Outputs an error message"
msgstr "Affiche un message d'erreur"

#. type: Plain text
#: condinapt.1:468
msgid "Aborts execution (unless in simulation mode)"
msgstr "Interrompt l'exécution (sauf en mode simulation)"

#. type: IP
#: condinapt.1:468
#, no-wrap
msgid "3."
msgstr "3."

#. type: Plain text
#: condinapt.1:470
msgid "Returns exit code 1"
msgstr "Retourne le code de sortie 1"

#. type: SS
#: condinapt.1:470
#, no-wrap
msgid "Handling Unavailable Versions"
msgstr "Gestion des versions indisponibles"

#. type: Plain text
#: condinapt.1:473
msgid "\\f[B]Loose Versions (=):\\fR"
msgstr "\\f[B]Versions souples (=) :\\fR"

#. type: Plain text
#: condinapt.1:476
msgid "If the exact version is unavailable, any available version is installed with a warning."
msgstr "Si la version exacte n'est pas disponible, n'importe quelle version disponible est installée avec un avertissement."

#. type: Plain text
#: condinapt.1:478
msgid "\\f[B]Strict Versions (==):\\fR"
msgstr "\\f[B]Versions strictes (==) :\\fR"

#. type: Plain text
#: condinapt.1:481
msgid "If the exact version is unavailable, the package is skipped.  If the package is mandatory (\\f[B]!\\f[R]), execution aborts.\\fR"
msgstr "Si la version exacte n'est pas disponible, le paquet est ignoré. Si le paquet est obligatoire (\\f[B]!\\f[R]), l'exécution est interrompue.\\fR"

#. type: SS
#: condinapt.1:481
#, no-wrap
msgid "Version Holding"
msgstr "Blocage de version"

#. type: Plain text
#: condinapt.1:485
msgid "CondinAPT automatically applies \\f[B]apt-mark hold\\f[R] when the exactly requested version was installed, preventing automatic updates.\\fR"
msgstr "CondinAPT applique automatiquement \\f[B]apt-mark hold\\f[R] lorsque la version précisément demandée a été installée, empêchant les mises à jour automatiques.\\fR"

#. type: SH
#: condinapt.1:485 condinapt-minios.7:297
#, no-wrap
msgid "FILES"
msgstr "FICHIERS"

#. type: TP
#: condinapt.1:486
#, no-wrap
msgid "\\f[B]/etc/condinapt/config.conf\\fR"
msgstr "\\f[B]/etc/condinapt/config.conf\\fR"

#. type: Plain text
#: condinapt.1:489
msgid "Default configuration file"
msgstr "Fichier de configuration par défaut"

#. type: TP
#: condinapt.1:489
#, no-wrap
msgid "\\f[B]/etc/condinapt/filters.map\\fR"
msgstr "\\f[B]/etc/condinapt/filters.map\\fR"

#. type: Plain text
#: condinapt.1:492
msgid "Default filter mapping file"
msgstr "Fichier de correspondance des filtres par défaut"

#. type: Plain text
#: condinapt.1:496
msgid "\\f[B]apt\\f[R](8), \\f[B]apt-get\\f[R](8), \\f[B]apt-cache\\f[R](8), \\f[B]condinapt-minios\\f[R](7)\\fR"
msgstr "\\f[B]apt\\f[R](8), \\f[B]apt-get\\f[R](8), \\f[B]apt-cache\\f[R](8), \\f[B]condinapt-minios\\f[R](7)\\fR"
