#. type: TH
#: condinapt.1:17
#, no-wrap
msgid "CONDINAPT"
msgstr "CONDINAPT"

#. type: TH
#: condinapt.1:17
#, no-wrap
msgid "CondinAPT Package Manager"
msgstr "Gestore pacchetti CondinAPT"

#. type: Plain text
#: condinapt.1:23
msgid "condinapt - conditional package installation tool for Debian-like systems"
msgstr "condinapt - strumento per l'installazione condizionale di pacchetti su sistemi tipo Debian"

#. type: Plain text
#: condinapt.1:26
msgid "\\f[B]condinapt\\f[R] [\\f[I]OPTIONS\\f[R]]\\fR"
msgstr "\\f[B]condinapt\\f[R] [\\f[I]OPTIONS\\f[R]]\\fR"

#. type: Plain text
#: condinapt.1:33
msgid "\\f[B]CondinAPT\\f[R] is a versatile tool for automating package installation in any Debian-like system (Debian, Ubuntu, and their derivatives).  Its key feature is the ability to define complex conditions and rules for installing each package based on arbitrary system configurations.\\fR"
msgstr "\\f[B]CondinAPT\\f[R] è uno strumento versatile per automatizzare l'installazione dei pacchetti su qualsiasi sistema tipo Debian (Debian, Ubuntu e derivati). La sua caratteristica principale è la capacità di definire condizioni e regole complesse per l'installazione di ciascun pacchetto in base a configurazioni di sistema arbitrarie.\\fR"

#. type: SS
#: condinapt.1:33
#, no-wrap
msgid "Areas of Application"
msgstr "Aree di applicazione"

#. type: Plain text
#: condinapt.1:36
msgid "Linux distribution build systems"
msgstr "Sistemi di build per distribuzioni Linux"

#. type: Plain text
#: condinapt.1:38
msgid "Automation of server and workstation setup"
msgstr "Automazione della configurazione di server e workstation"

#. type: Plain text
#: condinapt.1:40
msgid "Deployment of various system configurations"
msgstr "Distribuzione di diverse configurazioni di sistema"

#. type: Plain text
#: condinapt.1:42
msgid "Package management in Docker containers"
msgstr "Gestione dei pacchetti in container Docker"

#. type: Plain text
#: condinapt.1:44
msgid "CI/CD pipelines for environment setup"
msgstr "Pipeline CI/CD per la preparazione degli ambienti"

#. type: Plain text
#: condinapt.1:46
msgid "Creation of custom installation images"
msgstr "Creazione di immagini di installazione personalizzate"

#. type: SS
#: condinapt.1:46
#, no-wrap
msgid "Key Features"
msgstr "Caratteristiche principali"

#. type: Plain text
#: condinapt.1:50
msgid "\\f[B]Conditional Installation:\\f[R] Install packages based on flexible filters (+, -)\\fR"
msgstr "\\f[B]Installazione condizionale:\\f[R] Installa i pacchetti in base a filtri flessibili (+, -)\\fR"

#. type: Plain text
#: condinapt.1:53
msgid "\\f[B]External Configuration:\\f[R] Complete separation of logic (package list) from data (system parameters)\\fR"
msgstr "\\f[B]Configurazione esterna:\\f[R] Separazione completa della logica (lista pacchetti) dai dati (parametri di sistema)\\fR"

#. type: Plain text
#: condinapt.1:56
msgid "\\f[B]Installation Queues:\\f[R] Divide the process into sequential stages to resolve dependencies\\fR"
msgstr "\\f[B]Code di installazione:\\f[R] Suddivide il processo in fasi sequenziali per risolvere le dipendenze\\fR"

#. type: Plain text
#: condinapt.1:59
msgid "\\f[B]Priority Queue:\\f[R] Guaranteed installation of critical packages first\\fR"
msgstr "\\f[B]Coda prioritaria:\\f[R] Installazione garantita dei pacchetti critici come prima cosa\\fR"

#. type: Plain text
#: condinapt.1:62
msgid "\\f[B]Complex Logic:\\f[R] Support for \\[lq]AND\\[rq] (&&), \\[lq]OR\\[rq] (||) operators, as well as group filters (+{a|b}, -{a&b})\\fR"
msgstr "\\f[B]Logica complessa:\\f[R] Supporto per operatori \\[lq]AND\\[rq] (&&), \\[lq]OR\\[rq] (||), oltre a filtri di gruppo (+{a|b}, -{a&b})\\fR"

#. type: Plain text
#: condinapt.1:65
msgid "\\f[B]Readability:\\f[R] Support for comments and empty lines to structure lists\\fR"
msgstr "\\f[B]Leggibilità:\\f[R] Supporto per commenti e righe vuote per strutturare le liste\\fR"

#. type: Plain text
#: condinapt.1:68
msgid "\\f[B]Backward Compatibility:\\f[R] Supports simple package lists without conditions\\fR"
msgstr "\\f[B]Compatibilità retroattiva:\\f[R] Supporta liste di pacchetti semplici senza condizioni\\fR"

#. type: TP
#: condinapt.1:69
#, no-wrap
msgid "\\f[B]-l\\f[R], \\f[B]--package-list\\f[R] \\f[I]PATH\\fR"
msgstr "\\f[B]-l\\f[R], \\f[B]--package-list\\f[R] \\f[I]PATH\\fR"

#. type: Plain text
#: condinapt.1:72
msgid "(Required) Path to the package list file"
msgstr "(Obbligatorio) Percorso al file della lista pacchetti"

#. type: TP
#: condinapt.1:72
#, no-wrap
msgid "\\f[B]-c\\f[R], \\f[B]--config\\f[R] \\f[I]PATH\\fR"
msgstr "\\f[B]-c\\f[R], \\f[B]--config\\f[R] \\f[I]PATH\\fR"

#. type: Plain text
#: condinapt.1:75
msgid "(Required) Path to the main configuration file"
msgstr "(Obbligatorio) Percorso al file di configurazione principale"

#. type: TP
#: condinapt.1:75
#, no-wrap
msgid "\\f[B]-m\\f[R], \\f[B]--filter-mapping\\f[R] \\f[I]PATH\\fR"
msgstr "\\f[B]-m\\f[R], \\f[B]--filter-mapping\\f[R] \\f[I]PATH\\fR"

#. type: Plain text
#: condinapt.1:78
msgid "(Optional) Path to the filter mapping file"
msgstr "(Opzionale) Percorso al file di mapping dei filtri"

#. type: TP
#: condinapt.1:78
#, no-wrap
msgid "\\f[B]-P\\f[R], \\f[B]--priority-list\\f[R] \\f[I]PATH\\fR"
msgstr "\\f[B]-P\\f[R], \\f[B]--priority-list\\f[R] \\f[I]PATH\\fR"

#. type: Plain text
#: condinapt.1:81
msgid "(Optional) Path to the priority package list file"
msgstr "(Opzionale) Percorso al file della lista pacchetti prioritari"

#. type: TP
#: condinapt.1:81
#, no-wrap
msgid "\\f[B]-s\\f[R], \\f[B]--simulation\\fR"
msgstr "\\f[B]-s\\f[R], \\f[B]--simulation\\fR"

#. type: Plain text
#: condinapt.1:85
msgid "Simulation mode.  Packages will not be installed"
msgstr "Modalità simulazione.  I pacchetti non verranno installati"

#. type: TP
#: condinapt.1:85
#, no-wrap
msgid "\\f[B]-C\\f[R], \\f[B]--check-only\\fR"
msgstr "\\f[B]-C\\f[R], \\f[B]--check-only\\fR"

#. type: Plain text
#: condinapt.1:88
msgid "Only check if packages are already installed"
msgstr "Verifica solo se i pacchetti sono già installati"

#. type: TP
#: condinapt.1:88
#, no-wrap
msgid "\\f[B]-v\\f[R], \\f[B]--verbose\\fR"
msgstr "\\f[B]-v\\f[R], \\f[B]--verbose\\fR"

#. type: Plain text
#: condinapt.1:91
msgid "Verbose output"
msgstr "Output dettagliato"

#. type: TP
#: condinapt.1:91
#, no-wrap
msgid "\\f[B]-vv\\f[R], \\f[B]--very-verbose\\fR"
msgstr "\\f[B]-vv\\f[R], \\f[B]--very-verbose\\fR"

#. type: Plain text
#: condinapt.1:94
msgid "Very verbose output"
msgstr "Output molto dettagliato"

#. type: TP
#: condinapt.1:94
#, no-wrap
msgid "\\f[B]-x\\f[R], \\f[B]--xtrace\\fR"
msgstr "\\f[B]-x\\f[R], \\f[B]--xtrace\\fR"

#. type: Plain text
#: condinapt.1:97
msgid "Enable \\f[B]set -x\\f[R] command tracing\\fR"
msgstr "Abilita il tracciamento dei comandi \\f[B]set -x\\f[R]"

#. type: TP
#: condinapt.1:97
#, no-wrap
msgid "\\f[B]-f\\f[R], \\f[B]--force\\fR"
msgstr "\\f[B]-f\\f[R], \\f[B]--force\\fR"

#. type: Plain text
#: condinapt.1:100
msgid "Force apt cache update (apt update)"
msgstr "Forza l'aggiornamento della cache di apt (apt update)"

#. type: TP
#: condinapt.1:100
#, no-wrap
msgid "\\f[B]-h\\f[R], \\f[B]--help\\fR"
msgstr "\\f[B]-h\\f[R], \\f[B]--help\\fR"

#. type: Plain text
#: condinapt.1:103
msgid "Show help"
msgstr "Mostra l'aiuto"

#. type: SH
#: condinapt.1:103
#, no-wrap
msgid "CORE COMPONENTS"
msgstr "COMPONENTI PRINCIPALI"

#. type: Plain text
#: condinapt.1:106
msgid "CondinAPT operates with four key files:"
msgstr "CondinAPT opera con quattro file chiave:"

#. type: SS
#: condinapt.1:106
#, no-wrap
msgid "condinapt script"
msgstr "script condinapt"

#. type: Plain text
#: condinapt.1:109
msgid "The core, containing all processing logic"
msgstr "Il nucleo, che contiene tutta la logica di elaborazione"

#. type: SS
#: condinapt.1:109
#, no-wrap
msgid "Main configuration file (-c)"
msgstr "File di configurazione principale (-c)"

#. type: Plain text
#: condinapt.1:112
msgid "A file with bash variables describing the current environment"
msgstr "Un file con variabili bash che descrivono l'ambiente corrente"

#. type: Plain text
#: condinapt.1:114
msgid "Example (\\f[B]system.conf\\f[R]):\\fR"
msgstr "Esempio (\\f[B]system.conf\\f[R]):\\fR"

#. type: Plain text
#: condinapt.1:123
#, no-wrap
msgid ""
"\\f[C]\n"
"DISTRIBUTION=\\[dq]bookworm\\[dq]\n"
"SYSTEM_TYPE=\\[dq]server\\[dq]\n"
"ENVIRONMENT=\\[dq]production\\[dq]\n"
"LOCALE=\\[dq]en_US\\[dq]\n"
"FEATURES=\\[dq]web,database\\[dq]\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"DISTRIBUTION=\\[dq]bookworm\\[dq]\n"
"SYSTEM_TYPE=\\[dq]server\\[dq]\n"
"ENVIRONMENT=\\[dq]production\\[dq]\n"
"LOCALE=\\[dq]en_US\\[dq]\n"
"FEATURES=\\[dq]web,database\\[dq]\\fR\n"
"\n"

#. type: SS
#: condinapt.1:124
#, no-wrap
msgid "Filter mapping file (-m)"
msgstr "File di mappatura filtri (-m)"

#. type: Plain text
#: condinapt.1:132
msgid "Links short prefixes (used in the package list) to variable names from the main configuration file.  This file is \\f[B]optional\\f[R].  If a filter is not present in the filter mapping file, it will be used as a variable name from the main configuration file.  If the variable is not found, CondinAPT will declare it empty.\\fR"
msgstr "Collega prefissi brevi (usati nell'elenco pacchetti) ai nomi delle variabili del file di configurazione principale.  Questo file è \\f[B]opzionale\\f[R].  Se un filtro non è presente nel file di mappatura filtri, verrà usato come nome variabile dal file di configurazione principale.  Se la variabile non viene trovata, CondinAPT la dichiarerà vuota.\\fR"

#. type: Plain text
#: condinapt.1:134
msgid "Example (\\f[B]filters.map\\f[R]):\\fR"
msgstr "Esempio (\\f[B]filters.map\\f[R]):\\fR"

#. type: Plain text
#: condinapt.1:143
#, no-wrap
msgid ""
"\\f[C]\n"
"d=DISTRIBUTION\n"
"st=SYSTEM_TYPE\n"
"env=ENVIRONMENT\n"
"arch=ARCHITECTURE\n"
"feat=FEATURES\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"d=DISTRIBUTION\n"
"st=SYSTEM_TYPE\n"
"env=ENVIRONMENT\n"
"arch=ARCHITECTURE\n"
"feat=FEATURES\\fR\n"
"\n"

#. type: SS
#: condinapt.1:144
#, no-wrap
msgid "Package list file (-l)"
msgstr "File elenco pacchetti (-l)"

#. type: Plain text
#: condinapt.1:147
msgid "The main file describing what to install and under what conditions"
msgstr "Il file principale che descrive cosa installare e in quali condizioni"

#. type: SH
#: condinapt.1:147
#, no-wrap
msgid "PACKAGE LIST SYNTAX"
msgstr "SINTASSI ELENCO PACCHETTI"

#. type: Plain text
#: condinapt.1:150
msgid "Each line in the package list file consists of two main parts:"
msgstr "Ogni riga nel file elenco pacchetti è composta da due parti principali:"

#. type: IP
#: condinapt.1:150
#, no-wrap
msgid "1."
msgstr "1."

#. type: Plain text
#: condinapt.1:152
msgid "Package name with optional version and release specification"
msgstr "Nome del pacchetto con specifica opzionale di versione e rilascio"

#. type: IP
#: condinapt.1:152 condinapt.1:466
#, no-wrap
msgid "2."
msgstr "2."

#. type: Plain text
#: condinapt.1:155
msgid "Condition filters - define the conditions under which the package will be installed"
msgstr "Filtri di condizione - definiscono le condizioni in cui il pacchetto verrà installato"

#. type: SS
#: condinapt.1:155
#, no-wrap
msgid "Package Name Structure"
msgstr "Struttura del nome pacchetto"

#. type: Plain text
#: condinapt.1:158
msgid "\\f[B]Simple name:\\fR"
msgstr "\\f[B]Nome semplice:\\fR"

#. type: Plain text
#: condinapt.1:163
#, no-wrap
msgid ""
"\\f[C]\n"
"vim\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"vim\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:166
msgid "\\f[B]Package version:\\fR"
msgstr "\\f[B]Versione pacchetto:\\fR"

#. type: Plain text
#: condinapt.1:170
msgid "\\f[B]package=version\\f[R] - loose version requirement.  If the required version is unavailable, an available version is installed\\fR"
msgstr "\\f[B]package=version\\f[R] - requisito di versione flessibile.  Se la versione richiesta non è disponibile, verrà installata una versione disponibile\\fR"

#. type: Plain text
#: condinapt.1:173
msgid "\\f[B]package==version\\f[R] - strict requirement.  If the version is not found, installation aborts with an error\\fR"
msgstr "\\f[B]package==version\\f[R] - requisito rigido.  Se la versione non viene trovata, l'installazione viene interrotta con un errore\\fR"

#. type: Plain text
#: condinapt.1:175
msgid "\\f[B]Release specification:\\fR"
msgstr "\\f[B]Specificazione della release:\\fR"

#. type: Plain text
#: condinapt.1:177
msgid "The release is specified using the **\\[at]** symbol:"
msgstr "La release viene specificata utilizzando il simbolo **\\[at]**:"

#. type: Plain text
#: condinapt.1:183
#, no-wrap
msgid ""
"\\f[C]\n"
"telegram\\[at]bookworm-backports\n"
"kernel-image-6.5.0\\[at]trixie-backports\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"telegram\\[at]bookworm-backports\n"
"kernel-image-6.5.0\\[at]trixie-backports\\fR\n"
"\n"

#. type: SS
#: condinapt.1:184
#, no-wrap
msgid "File Structure"
msgstr "Struttura del file"

#. type: Plain text
#: condinapt.1:188
msgid "\\f[B]Package names:\\f[R] Each package or condition is written on a new line\\fR"
msgstr "\\f[B]Nomi dei pacchetti:\\f[R] Ogni pacchetto o condizione viene scritto su una nuova riga\\fR"

#. type: Plain text
#: condinapt.1:191
msgid "\\f[B]Comments:\\f[R] Lines starting with \\f[B]#\\f[R], or text after \\f[B]#\\f[R] on a line, are completely ignored\\fR"
msgstr "\\f[B]Commenti:\\f[R] Le righe che iniziano con \\f[B]#\\f[R], o il testo dopo \\f[B]#\\f[R] su una riga, vengono completamente ignorati\\fR"

#. type: Plain text
#: condinapt.1:193
msgid "\\f[B]Empty lines:\\f[R] Ignored and serve for visual separation\\fR"
msgstr "\\f[B]Righe vuote:\\f[R] Ignorate e utilizzate solo per separazione visiva\\fR"

#. type: SS
#: condinapt.1:193
#, no-wrap
msgid "Filters and Conditions"
msgstr "Filtri e condizioni"

#. type: SS
#: condinapt.1:194
#, no-wrap
msgid "Single Filters"
msgstr "Filtri singoli"

#. type: Plain text
#: condinapt.1:198
msgid "\\f[B]+ (Positive):\\f[R] The condition is true if the variable value \\f[B]matches\\fR"
msgstr "\\f[B]+ (Positivo):\\f[R] La condizione è vera se il valore della variabile \\f[B]corrisponde\\fR"

#. type: Plain text
#: condinapt.1:200
msgid "Format: \\f[B]+=\\fR"
msgstr "Formato: \\f[B]+=\\fR"

#. type: Plain text
#: condinapt.1:202 condinapt.1:215 condinapt.1:306
msgid "Example:"
msgstr "Esempio:"

#. type: Plain text
#: condinapt.1:207
#, no-wrap
msgid ""
"\\f[C]\n"
"nginx +st=server\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"nginx +st=server\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:211
msgid "\\f[B]- (Negative):\\f[R] The condition is true if the variable value \\f[B]does not match\\fR"
msgstr "\\f[B]- (Negativo):\\f[R] La condizione è vera se il valore della variabile \\f[B]non corrisponde\\fR"

#. type: Plain text
#: condinapt.1:213
msgid "Format: \\f[B]-=\\fR"
msgstr "Formato: \\f[B]-=\\fR"

#. type: Plain text
#: condinapt.1:220
#, no-wrap
msgid ""
"\\f[C]\n"
"monitoring-tools -st=desktop\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"monitoring-tools -st=desktop\\fR\n"
"\n"

#. type: SS
#: condinapt.1:221
#, no-wrap
msgid "Group Filters"
msgstr "Filtri di gruppo"

#. type: Plain text
#: condinapt.1:225
msgid "\\f[B]+{a|b} (OR for inclusion):\\f[R] True if \\f[B]at least one\\f[R] of the conditions in the group is true\\fR"
msgstr "\\f[B]+{a|b} (OR per inclusione):\\f[R] Vero se \\f[B]almeno una\\f[R] delle condizioni nel gruppo è vera\\fR"

#. type: Plain text
#: condinapt.1:230
#, no-wrap
msgid ""
"\\f[C]\n"
"web-server +{st=server|st=web-server}\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"web-server +{st=server|st=web-server}\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:234
msgid "\\f[B]+{a&b} (AND for inclusion):\\f[R] True only if \\f[B]all\\f[R] conditions in the group are true\\fR"
msgstr "\\f[B]+{a&b} (AND per inclusione):\\f[R] Vero solo se \\f[B]tutte\\f[R] le condizioni nel gruppo sono vere\\fR"

#. type: Plain text
#: condinapt.1:239
#, no-wrap
msgid ""
"\\f[C]\n"
"database-tools +{d=bookworm&st=server}\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"database-tools +{d=bookworm&st=server}\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:243
msgid "\\f[B]-{a|b} (OR for exclusion):\\f[R] The package is excluded if \\f[B]at least one\\f[R] of the conditions is true\\fR"
msgstr "\\f[B]-{a|b} (OR per esclusione):\\f[R] Il pacchetto viene escluso se \\f[B]almeno una\\f[R] delle condizioni è vera\\fR"

#. type: Plain text
#: condinapt.1:248
#, no-wrap
msgid ""
"\\f[C]\n"
"debug-tools -{env=production|st=minimal}\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"debug-tools -{env=production|st=minimal}\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:252
msgid "\\f[B]-{a&b} (AND for exclusion):\\f[R] The package is excluded only if \\f[B]all\\f[R] conditions are true\\fR"
msgstr "\\f[B]-{a&b} (AND per esclusione):\\f[R] Il pacchetto viene escluso solo se \\f[B]tutte\\f[R] le condizioni sono vere\\fR"

#. type: Plain text
#: condinapt.1:257
#, no-wrap
msgid ""
"\\f[C]\n"
"development-tools -{env=production&st=minimal}\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"development-tools -{env=production&st=minimal}\\fR\n"
"\n"

#. type: SS
#: condinapt.1:258
#, no-wrap
msgid "Logical Operators"
msgstr "Operatori logici"

#. type: Plain text
#: condinapt.1:262
msgid "\\f[B]|| (OR / Fallback):\\f[R] Try to install the left part.  If it fails, try the right part\\fR"
msgstr "\\f[B]|| (OR / Fallback):\\f[R] Tenta di installare la parte sinistra. Se fallisce, prova la parte destra\\fR"

#. type: Plain text
#: condinapt.1:267
#, no-wrap
msgid ""
"\\f[C]\n"
"exfatprogs -d=bookworm || exfat-utils\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"exfatprogs -d=bookworm || exfat-utils\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:271
msgid "\\f[B]&& (AND / Conjunction):\\f[R] All parts must successfully pass filter checks\\fR"
msgstr "\\f[B]&& (AND / Congiunzione):\\f[R] Tutte le parti devono superare con successo i controlli dei filtri\\fR"

#. type: Plain text
#: condinapt.1:276
#, no-wrap
msgid ""
"\\f[C]\n"
"nginx +st=web-server && php-fpm\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"nginx +st=web-server && php-fpm\\fR\n"
"\n"

#. type: SS
#: condinapt.1:277
#, no-wrap
msgid "Special Modifiers"
msgstr "Modificatori speciali"

#. type: Plain text
#: condinapt.1:283
msgid "\\f[B]! (Mandatory Package):\\f[R] If a package is marked with \\f[B]!\\f[R], but cannot be found in repositories, CondinAPT will abort execution with an error\\fR"
msgstr "\\f[B]! (Pacchetto obbligatorio):\\f[R] Se un pacchetto è contrassegnato con \\f[B]!\\f[R], ma non viene trovato nei repository, CondinAPT interrompe l'esecuzione con un errore\\fR"

#. type: Plain text
#: condinapt.1:288
#, no-wrap
msgid ""
"\\f[C]\n"
"!essential-package\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"!essential-package\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:292
msgid "\\f[B]\\[at] (Release Specification):\\f[R] Install a package from a specific Debian/Ubuntu release\\fR"
msgstr "\\f[B]\\[at] (Specificazione della release):\\f[R] Installa un pacchetto da una specifica release Debian/Ubuntu\\fR"

#. type: Plain text
#: condinapt.1:297
#, no-wrap
msgid ""
"\\f[C]\n"
"kernel-image-6.5.0 \\[at]trixie-backports\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"kernel-image-6.5.0 \\[at]trixie-backports\\fR\n"
"\n"

#. type: SS
#: condinapt.1:298
#, no-wrap
msgid "Installation Queues"
msgstr "Code di installazione"

#. type: Plain text
#: condinapt.1:304
msgid "The \\f[B]\\[em]\\f[R] separator on a separate line divides the list into groups (queues).  Packages from one queue are installed together in a single apt call.  Queues are executed strictly sequentially.\\fR"
msgstr "Il separatore \\f[B]\\[em]\\f[R] su una riga separata divide l'elenco in gruppi (code). I pacchetti di una coda vengono installati insieme in una singola chiamata apt. Le code vengono eseguite in modo strettamente sequenziale.\\fR"

#. type: Plain text
#: condinapt.1:320
#, no-wrap
msgid ""
"\\f[C]\n"
"# Queue 1: Base system\n"
"systemd\n"
"network-manager\n"
"---\n"
"# Queue 2: Web server\n"
"nginx\n"
"php-fpm\n"
"---\n"
"# Queue 3: Monitoring\n"
"prometheus\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"# Queue 1: Base system\n"
"systemd\n"
"network-manager\n"
"---\n"
"# Queue 2: Web server\n"
"nginx\n"
"php-fpm\n"
"---\n"
"# Queue 3: Monitoring\n"
"prometheus\\fR\n"
"\n"

#. type: SS
#: condinapt.1:321
#, no-wrap
msgid "Priority Queue"
msgstr "Coda prioritaria"

#. type: Plain text
#: condinapt.1:326
msgid "Packages listed in the file specified by the \\f[B]-P\\f[R] flag (one package per line, no filters) form a special \\[lq]Queue #1\\[rq], which is executed first.\\fR"
msgstr "I pacchetti elencati nel file specificato dall'opzione \\f[B]-P\\f[R] (un pacchetto per riga, senza filtri) costituiscono una speciale \\[lq]Queue #1\\[rq], che viene eseguita per prima.\\fR"

#. type: Plain text
#: condinapt.1:330
msgid "Any package from the priority list is automatically removed from all regular queues.  This ensures it will be installed unconditionally."
msgstr "Qualsiasi pacchetto presente nell'elenco delle priorità viene automaticamente rimosso da tutte le code regolari.  Questo garantisce che venga installato incondizionatamente."

#. type: SS
#: condinapt.1:331
#, no-wrap
msgid "Quick Start"
msgstr "Avvio rapido"

#. type: Plain text
#: condinapt.1:334
msgid "Create the configuration file \\f[B]config.conf\\f[R]:\\fR"
msgstr "Creare il file di configurazione \\\\f[B]config.conf\\\\f[R]:\\\\fR"

#. type: Plain text
#: condinapt.1:341
#, no-wrap
msgid ""
"\\f[C]\n"
"DISTRIBUTION=\\[dq]bookworm\\[dq]\n"
"SYSTEM_TYPE=\\[dq]server\\[dq]\n"
"ENVIRONMENT=\\[dq]production\\[dq]\\fR\n"
"\n"
msgstr ""
"\\\\f[C]\n"
"DISTRIBUTION=\\[dq]bookworm\\[dq]\n"
"SYSTEM_TYPE=\\[dq]server\\[dq]\n"
"ENVIRONMENT=\\[dq]production\\[dq]\\\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:344
msgid "Create the package list \\f[B]packages.list\\f[R]:\\fR"
msgstr "Creare la lista dei pacchetti \\\\f[B]packages.list\\\\f[R]:\\\\fR"

#. type: Plain text
#: condinapt.1:350
#, no-wrap
msgid ""
"\\f[C]\n"
"# Base packages - always installed\n"
"vim\n"
"curl\\fR\n"
msgstr ""
"\\\\f[C]\n"
"# Pacchetti di base - sempre installati\n"
"vim\n"
"curl\\\\fR\n"

#. type: Plain text
#: condinapt.1:354
#, no-wrap
msgid ""
"\\f[C]# Packages only for servers\n"
"nginx +SYSTEM_TYPE=server\n"
"mysql-server +SYSTEM_TYPE=server\\fR\n"
msgstr ""
"\\\\f[C]# Pacchetti solo per server\n"
"nginx +SYSTEM_TYPE=server\n"
"mysql-server +SYSTEM_TYPE=server\\\\fR\n"

#. type: Plain text
#: condinapt.1:358
#, no-wrap
msgid ""
"\\f[C]# Exclude packages for production environment\n"
"debug-tools -ENVIRONMENT=production\\fR\n"
"\n"
msgstr ""
"\\\\f[C]# Escludi pacchetti per ambiente di produzione\n"
"debug-tools -ENVIRONMENT=production\\\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:361
msgid "Run the installation:"
msgstr "Eseguire l'installazione:"

#. type: Plain text
#: condinapt.1:366
#, no-wrap
msgid ""
"\\f[C]\n"
"condinapt -l packages.list -c config.conf\\fR\n"
"\n"
msgstr ""
"\\\\f[C]\n"
"condinapt -l packages.list -c config.conf\\\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:369
msgid "Or test in simulation mode:"
msgstr "Oppure testare in modalità simulazione:"

#. type: Plain text
#: condinapt.1:374
#, no-wrap
msgid ""
"\\f[C]\n"
"condinapt -l packages.list -c config.conf -s\\fR\n"
"\n"
msgstr ""
"\\\\f[C]\n"
"condinapt -l packages.list -c config.conf -s\\\\fR\n"
"\n"

#. type: SS
#: condinapt.1:375
#, no-wrap
msgid "Multimedia Server"
msgstr "Server Multimediale"

#. type: Plain text
#: condinapt.1:378 condinapt.1:400 condinapt-minios.7:142
#: condinapt-minios.7:165 condinapt-minios.7:186 condinapt-minios.7:213
msgid "\\f[B]packages.list:\\fR"
msgstr "\\\\f[B]packages.list:\\\\fR"

#. type: Plain text
#: condinapt.1:384 condinapt-minios.7:148
#, no-wrap
msgid ""
"\\f[C]\n"
"# Basic multimedia codecs - always\n"
"gstreamer1.0-plugins-base\n"
"gstreamer1.0-plugins-good\\fR\n"
msgstr ""
"\\\\f[C]\n"
"# Codec multimediali di base - sempre\n"
"gstreamer1.0-plugins-base\n"
"gstreamer1.0-plugins-good\\\\fR\n"

#. type: Plain text
#: condinapt.1:388
#, no-wrap
msgid ""
"\\f[C]# Additional codecs - not for minimal installation\n"
"gstreamer1.0-plugins-bad -st=minimal\n"
"gstreamer1.0-plugins-ugly -st=minimal\\fR\n"
msgstr ""
"\\\\f[C]# Codec aggiuntivi - non per installazione minimale\n"
"gstreamer1.0-plugins-bad -st=minimal\n"
"gstreamer1.0-plugins-ugly -st=minimal\\\\fR\n"

#. type: Plain text
#: condinapt.1:396
#, no-wrap
msgid ""
"\\f[C]# Professional tools - only for full configuration\n"
"ffmpeg +st=media-server\n"
"vlc +st=media-server\n"
"---\n"
"# Distribution-specific packages from backports\n"
"ffmpeg \\[at]bookworm-backports +d=bookworm\\fR\n"
"\n"
msgstr ""
"\\\\f[C]# Strumenti professionali - solo per configurazione completa\n"
"ffmpeg +st=media-server\n"
"vlc +st=media-server\n"
"---\n"
"# Pacchetti specifici per distribuzione dai backports\n"
"ffmpeg \\[at]bookworm-backports +d=bookworm\\\\fR\n"
"\n"

#. type: SS
#: condinapt.1:397
#, no-wrap
msgid "Web Server with Various Configurations"
msgstr "Server Web con Configurazioni Varie"

#. type: Plain text
#: condinapt.1:406
#, no-wrap
msgid ""
"\\f[C]\n"
"# Basic web server components\n"
"nginx\n"
"openssl\\fR\n"
msgstr ""
"\\\\f[C]\n"
"# Componenti base per server web\n"
"nginx\n"
"openssl\\\\fR\n"

#. type: Plain text
#: condinapt.1:410
#, no-wrap
msgid ""
"\\f[C]# Database - only for full installations\n"
"mysql-server +st=full-server -{env=minimal}\n"
"postgresql +st=database-server\\fR\n"
msgstr ""
"\\\\f[C]# Database - solo per installazioni complete\n"
"mysql-server +st=full-server -{env=minimal}\n"
"postgresql +st=database-server\\\\fR\n"

#. type: Plain text
#: condinapt.1:414
#, no-wrap
msgid ""
"\\f[C]# PHP - for web servers\n"
"php-fpm +feat=php\n"
"php-mysql +{feat=php&st=full-server}\\fR\n"
msgstr ""
"\\\\f[C]# PHP - per server web\n"
"php-fpm +feat=php\n"
"php-mysql +{feat=php&st=full-server}\\\\fR\n"

#. type: Plain text
#: condinapt.1:418
#, no-wrap
msgid ""
"\\f[C]# Monitoring - not for development\n"
"prometheus-node-exporter -env=development\\fR\n"
"\n"
msgstr ""
"\\\\f[C]# Monitoraggio - non per sviluppo\n"
"prometheus-node-exporter -env=development\\\\fR\n"
"\n"

#. type: SH
#: condinapt.1:419
#, no-wrap
msgid "OPERATING MODES"
msgstr "MODALITÀ DI FUNZIONAMENTO"

#. type: SS
#: condinapt.1:420
#, no-wrap
msgid "Simulation Mode"
msgstr "Modalità simulazione"

#. type: Plain text
#: condinapt.1:424
msgid "Allows you to see which packages will be installed without actually installing them:"
msgstr "Permette di visualizzare quali pacchetti verranno installati senza eseguire realmente l'installazione:"

#. type: Plain text
#: condinapt.1:429
#, no-wrap
msgid ""
"\\f[C]\n"
"condinapt -l packages.list -c system.conf -s\\fR\n"
"\n"
msgstr ""
"\\\\f[C]\n"
"condinapt -l packages.list -c system.conf -s\\\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:432
msgid "In simulation mode, the script exits with exit code 1."
msgstr "In modalità simulazione, lo script termina con codice di uscita 1."

#. type: SS
#: condinapt.1:432
#, no-wrap
msgid "Check Mode"
msgstr "Modalità verifica"

#. type: Plain text
#: condinapt.1:435
msgid "Checks which packages from the list are already installed on the system:"
msgstr "Controlla quali pacchetti dell'elenco sono già installati sul sistema:"

#. type: Plain text
#: condinapt.1:440
#, no-wrap
msgid ""
"\\f[C]\n"
"condinapt -l packages.list -c system.conf -C\\fR\n"
"\n"
msgstr ""
"\\\\f[C]\n"
"condinapt -l packages.list -c system.conf -C\\\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:444
msgid "Shows errors for uninstalled packages and returns exit code 1 if there are uninstalled packages."
msgstr "Mostra errori per i pacchetti non installati e restituisce codice di uscita 1 se ci sono pacchetti non installati."

#. type: SS
#: condinapt.1:444
#, no-wrap
msgid "Debugging Modes"
msgstr "Modalità di debug"

#. type: Plain text
#: condinapt.1:447
msgid "\\f[B]Verbose Output (-v):\\fR"
msgstr "\\\\f[B]Output verboso (-v):\\\\fR"

#. type: Plain text
#: condinapt.1:450
msgid "Shows detailed information about filter checks and displays results for each package."
msgstr "Mostra informazioni dettagliate sui controlli dei filtri e visualizza i risultati per ogni pacchetto."

#. type: Plain text
#: condinapt.1:452
msgid "\\f[B]Very Verbose Output (-vv):\\fR"
msgstr "\\\\f[B]Output molto verboso (-vv):\\\\fR"

#. type: Plain text
#: condinapt.1:454
msgid "Maximum process detail, shows all intermediate steps."
msgstr "Dettaglio massimo del processo, mostra tutti i passaggi intermedi."

#. type: Plain text
#: condinapt.1:456
msgid "\\f[B]Command Tracing (-x):\\fR"
msgstr "\\\\f[B]Tracciamento comandi (-x):\\\\fR"

#. type: Plain text
#: condinapt.1:459
msgid "Enables \\f[B]set -x\\f[R] for script debugging, shows each command being executed.\\fR"
msgstr "Abilita \\\\f[B]set -x\\\\f[R] per il debug dello script, mostrando ogni comando eseguito.\\\\fR"

#. type: SH
#: condinapt.1:459
#, no-wrap
msgid "ERROR HANDLING"
msgstr "GESTIONE DEGLI ERRORI"

#. type: SS
#: condinapt.1:460
#, no-wrap
msgid "Mandatory Packages"
msgstr "Pacchetti obbligatori"

#. type: Plain text
#: condinapt.1:464
msgid "If a package is marked as mandatory (\\f[B]!\\f[R]) but not found in repositories, CondinAPT:\\fR"
msgstr "Se un pacchetto è contrassegnato come obbligatorio (\\f[B]!\\f[R]) ma non viene trovato nei repository, CondinAPT:\\fR"

#. type: IP
#: condinapt.1:464
#, no-wrap
msgid "\\f[R]1.\\fR"
msgstr "\\f[R]1.\\fR"

#. type: Plain text
#: condinapt.1:466
msgid "Outputs an error message"
msgstr "Mostra un messaggio di errore"

#. type: Plain text
#: condinapt.1:468
msgid "Aborts execution (unless in simulation mode)"
msgstr "Interrompe l'esecuzione (a meno che non sia in modalità simulazione)"

#. type: IP
#: condinapt.1:468
#, no-wrap
msgid "3."
msgstr "3."

#. type: Plain text
#: condinapt.1:470
msgid "Returns exit code 1"
msgstr "Restituisce il codice di uscita 1"

#. type: SS
#: condinapt.1:470
#, no-wrap
msgid "Handling Unavailable Versions"
msgstr "Gestione delle versioni non disponibili"

#. type: Plain text
#: condinapt.1:473
msgid "\\f[B]Loose Versions (=):\\fR"
msgstr "\\f[B]Versioni flessibili (=):\\fR"

#. type: Plain text
#: condinapt.1:476
msgid "If the exact version is unavailable, any available version is installed with a warning."
msgstr "Se la versione esatta non è disponibile, viene installata qualsiasi versione disponibile con un avviso."

#. type: Plain text
#: condinapt.1:478
msgid "\\f[B]Strict Versions (==):\\fR"
msgstr "\\f[B]Versioni rigide (==):\\fR"

#. type: Plain text
#: condinapt.1:481
msgid "If the exact version is unavailable, the package is skipped.  If the package is mandatory (\\f[B]!\\f[R]), execution aborts.\\fR"
msgstr "Se la versione esatta non è disponibile, il pacchetto viene ignorato.  Se il pacchetto è obbligatorio (\\f[B]!\\f[R]), l'esecuzione viene interrotta.\\fR"

#. type: SS
#: condinapt.1:481
#, no-wrap
msgid "Version Holding"
msgstr "Blocco della versione"

#. type: Plain text
#: condinapt.1:485
msgid "CondinAPT automatically applies \\f[B]apt-mark hold\\f[R] when the exactly requested version was installed, preventing automatic updates.\\fR"
msgstr "CondinAPT applica automaticamente \\f[B]apt-mark hold\\f[R] quando viene installata esattamente la versione richiesta, impedendo aggiornamenti automatici.\\fR"

#. type: SH
#: condinapt.1:485 condinapt-minios.7:297
#, no-wrap
msgid "FILES"
msgstr "FILE"

#. type: TP
#: condinapt.1:486
#, no-wrap
msgid "\\f[B]/etc/condinapt/config.conf\\fR"
msgstr "\\f[B]/etc/condinapt/config.conf\\fR"

#. type: Plain text
#: condinapt.1:489
msgid "Default configuration file"
msgstr "File di configurazione predefinito"

#. type: TP
#: condinapt.1:489
#, no-wrap
msgid "\\f[B]/etc/condinapt/filters.map\\fR"
msgstr "\\f[B]/etc/condinapt/filters.map\\fR"

#. type: Plain text
#: condinapt.1:492
msgid "Default filter mapping file"
msgstr "File di mappatura dei filtri predefinito"

#. type: Plain text
#: condinapt.1:496
msgid "\\f[B]apt\\f[R](8), \\f[B]apt-get\\f[R](8), \\f[B]apt-cache\\f[R](8), \\f[B]condinapt-minios\\f[R](7)\\fR"
msgstr "\\f[B]apt\\f[R](8), \\f[B]apt-get\\f[R](8), \\f[B]apt-cache\\f[R](8), \\f[B]condinapt-minios\\f[R](7)\\fR"
