#. type: TH
#: condinapt-minios.7:17
#, no-wrap
msgid "MiniOS CondinAPT Integration"
msgstr "Integrazione CondinAPT per MiniOS"

#. type: Plain text
#: condinapt-minios.7:22
msgid "condinapt-minios - CondinAPT integration in the MiniOS build system"
msgstr "condinapt-minios - Integrazione CondinAPT nel sistema di build di MiniOS"

#. type: Plain text
#: condinapt-minios.7:26
msgid "This document describes the specific aspects of using \\f[B]condinapt\\f[R](1) in the MiniOS build system.\\fR"
msgstr "Questo documento descrive gli aspetti specifici dell'utilizzo di \\f[B]condinapt\\f[R](1) nel sistema di build di MiniOS.\\fR"

#. type: Plain text
#: condinapt-minios.7:28
msgid "For basic CondinAPT features, see \\f[B]condinapt\\f[R](1).\\fR"
msgstr "Per le funzionalità di base di CondinAPT, consultare \\f[B]condinapt\\f[R](1).\\fR"

#. type: SH
#: condinapt-minios.7:28
#, no-wrap
msgid "INTEGRATION WITH MINIOS BUILD SYSTEM"
msgstr "INTEGRAZIONE CON IL SISTEMA DI BUILD DI MINIOS"

#. type: SS
#: condinapt-minios.7:29
#, no-wrap
msgid "Usage in MiniOS Modules"
msgstr "Utilizzo nei Moduli MiniOS"

#. type: Plain text
#: condinapt-minios.7:34
msgid "CondinAPT is a standard tool for package installation in MiniOS modules.  It integrates into the build process through the standard module interface."
msgstr "CondinAPT è uno strumento standard per l'installazione dei pacchetti nei moduli MiniOS. Si integra nel processo di build tramite l'interfaccia standard dei moduli."

#. type: Plain text
#: condinapt-minios.7:36
msgid "In the module installation script (\\f[B]install\\f[R]):\\fR"
msgstr "Nel script di installazione del modulo (\\f[B]install\\f[R]):\\fR"

#. type: Plain text
#: condinapt-minios.7:41 condinapt-minios.7:280
#, no-wrap
msgid ""
"\\f[C]\n"
"#!/bin/bash\n"
"set -e\\fR\n"
msgstr ""
"\\f[C]\n"
"#!/bin/bash\n"
"set -e\\fR\n"

#. type: Plain text
#: condinapt-minios.7:44 condinapt-minios.7:283
#, no-wrap
msgid ""
"\\f[C]# Load MiniOS library\n"
"\\&. /minioslib || exit 1\\fR\n"
msgstr ""
"\\f[C]# Carica la libreria MiniOS\n"
"\\&. /minioslib || exit 1\\fR\n"

#. type: Plain text
#: condinapt-minios.7:51
#, no-wrap
msgid ""
"\\f[C]# Install packages via CondinAPT\n"
"/usr/share/minios-live/condinapt \\[rs]\n"
"    -l \\[dq]$CWD/packages.list\\[dq] \\[rs]\n"
"    -c /etc/minios-live/build.conf \\[rs]\n"
"    -m /usr/share/minios-live/condinapt.map\\fR\n"
"\n"
msgstr ""
"\\f[C]# Installa i pacchetti tramite CondinAPT\n"
"/usr/share/minios-live/condinapt \\[rs]\n"
"    -l \\[dq]$CWD/packages.list\\[dq] \\[rs]\n"
"    -c /etc/minios-live/build.conf \\[rs]\n"
"    -m /usr/share/minios-live/condinapt.map\\fR\n"
"\n"

#. type: SS
#: condinapt-minios.7:52
#, no-wrap
msgid "MiniOS Module Structure"
msgstr "Struttura del Modulo MiniOS"

#. type: Plain text
#: condinapt-minios.7:56
msgid "Each module in \\f[B]/usr/share/minios-live/scripts/\\f[R] follows a standardized structure:\\fR"
msgstr "Ogni modulo in \\f[B]/usr/share/minios-live/scripts/\\f[R] segue una struttura standardizzata:\\fR"

#. type: Plain text
#: condinapt-minios.7:65
#, no-wrap
msgid ""
"\\f[C]\n"
"XX-module-name/\n"
"\\[u251C]\\[u2500]\\[u2500] packages.list                     # Package list with conditions\n"
"\\[u251C]\\[u2500]\\[u2500] install                           # Installation script (uses CondinAPT)\n"
"\\[u251C]\\[u2500]\\[u2500] rootcopy-install/                 # (optional) Files to copy\n"
"\\[u2514]\\[u2500]\\[u2500] rootcopy-postinstall/             # (optional) Files after installation\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"XX-module-name/\n"
"\\[u251C]\\[u2500]\\[u2500] packages.list                     # Lista pacchetti con condizioni\n"
"\\[u251C]\\[u2500]\\[u2500] install                           # Script di installazione (usa CondinAPT)\n"
"\\[u251C]\\[u2500]\\[u2500] rootcopy-install/                 # (opzionale) File da copiare\n"
"\\[u2514]\\[u2500]\\[u2500] rootcopy-postinstall/             # (opzionale) File dopo l'installazione\\fR\n"
"\n"

