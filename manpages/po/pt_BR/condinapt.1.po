#. type: TH
#: condinapt.1:17
#, no-wrap
msgid "CONDINAPT"
msgstr "CONDINAPT"

#. type: TH
#: condinapt.1:17
#, no-wrap
msgid "CondinAPT Package Manager"
msgstr "Gerenciador de Pacotes CondinAPT"

#. type: Plain text
#: condinapt.1:23
msgid "condinapt - conditional package installation tool for Debian-like systems"
msgstr "condinapt - ferramenta de instalação condicional de pacotes para sistemas baseados em Debian"

#. type: Plain text
#: condinapt.1:26
msgid "\\f[B]condinapt\\f[R] [\\f[I]OPTIONS\\f[R]]\\fR"
msgstr "\\f[B]condinapt\\f[R] [\\f[I]OPTIONS\\f[R]]\\fR"

#. type: Plain text
#: condinapt.1:33
msgid "\\f[B]CondinAPT\\f[R] is a versatile tool for automating package installation in any Debian-like system (Debian, Ubuntu, and their derivatives).  Its key feature is the ability to define complex conditions and rules for installing each package based on arbitrary system configurations.\\fR"
msgstr "\\f[B]CondinAPT\\f[R] é uma ferramenta versátil para automatizar a instalação de pacotes em qualquer sistema baseado em Debian (Debian, Ubuntu e seus derivados). Sua principal característica é a capacidade de definir condições e regras complexas para instalar cada pacote com base em configurações arbitrárias do sistema.\\fR"

#. type: SS
#: condinapt.1:33
#, no-wrap
msgid "Areas of Application"
msgstr "Áreas de Aplicação"

#. type: Plain text
#: condinapt.1:36
msgid "Linux distribution build systems"
msgstr "Sistemas de construção de distribuições Linux"

#. type: Plain text
#: condinapt.1:38
msgid "Automation of server and workstation setup"
msgstr "Automação da configuração de servidores e estações de trabalho"

#. type: Plain text
#: condinapt.1:40
msgid "Deployment of various system configurations"
msgstr "Implantação de diversas configurações de sistema"

#. type: Plain text
#: condinapt.1:42
msgid "Package management in Docker containers"
msgstr "Gerenciamento de pacotes em containers Docker"

#. type: Plain text
#: condinapt.1:44
msgid "CI/CD pipelines for environment setup"
msgstr "Pipelines de CI/CD para preparação de ambientes"

#. type: Plain text
#: condinapt.1:46
msgid "Creation of custom installation images"
msgstr "Criação de imagens de instalação personalizadas"

#. type: SS
#: condinapt.1:46
#, no-wrap
msgid "Key Features"
msgstr "Principais Funcionalidades"

#. type: Plain text
#: condinapt.1:50
msgid "\\f[B]Conditional Installation:\\f[R] Install packages based on flexible filters (+, -)\\fR"
msgstr "\\f[B]Instalação Condicional:\\f[R] Instala pacotes com base em filtros flexíveis (+, -)\\fR"

#. type: Plain text
#: condinapt.1:53
msgid "\\f[B]External Configuration:\\f[R] Complete separation of logic (package list) from data (system parameters)\\fR"
msgstr "\\f[B]Configuração Externa:\\f[R] Separação completa da lógica (lista de pacotes) dos dados (parâmetros do sistema)\\fR"

#. type: Plain text
#: condinapt.1:56
msgid "\\f[B]Installation Queues:\\f[R] Divide the process into sequential stages to resolve dependencies\\fR"
msgstr "\\f[B]Filas de Instalação:\\f[R] Divide o processo em etapas sequenciais para resolver dependências\\fR"

#. type: Plain text
#: condinapt.1:59
msgid "\\f[B]Priority Queue:\\f[R] Guaranteed installation of critical packages first\\fR"
msgstr "\\f[B]Fila de Prioridade:\\f[R] Instalação garantida dos pacotes críticos primeiro\\fR"

#. type: Plain text
#: condinapt.1:62
msgid "\\f[B]Complex Logic:\\f[R] Support for \\[lq]AND\\[rq] (&&), \\[lq]OR\\[rq] (||) operators, as well as group filters (+{a|b}, -{a&b})\\fR"
msgstr "\\f[B]Lógica Complexa:\\f[R] Suporte aos operadores \\[lq]AND\\[rq] (&&), \\[lq]OR\\[rq] (||), além de filtros em grupo (+{a|b}, -{a&b})\\fR"

#. type: Plain text
#: condinapt.1:65
msgid "\\f[B]Readability:\\f[R] Support for comments and empty lines to structure lists\\fR"
msgstr "\\f[B]Legibilidade:\\f[R] Suporte a comentários e linhas em branco para estruturar listas\\fR"

#. type: Plain text
#: condinapt.1:68
msgid "\\f[B]Backward Compatibility:\\f[R] Supports simple package lists without conditions\\fR"
msgstr "\\f[B]Compatibilidade Retroativa:\\f[R] Suporta listas simples de pacotes sem condições\\fR"

#. type: TP
#: condinapt.1:69
#, no-wrap
msgid "\\f[B]-l\\f[R], \\f[B]--package-list\\f[R] \\f[I]PATH\\fR"
msgstr "\\f[B]-l\\f[R], \\f[B]--package-list\\f[R] \\f[I]PATH\\fR"

#. type: Plain text
#: condinapt.1:72
msgid "(Required) Path to the package list file"
msgstr "(Obrigatório) Caminho para o arquivo de lista de pacotes"

#. type: TP
#: condinapt.1:72
#, no-wrap
msgid "\\f[B]-c\\f[R], \\f[B]--config\\f[R] \\f[I]PATH\\fR"
msgstr "\\f[B]-c\\f[R], \\f[B]--config\\f[R] \\f[I]PATH\\fR"

#. type: Plain text
#: condinapt.1:75
msgid "(Required) Path to the main configuration file"
msgstr "(Obrigatório) Caminho para o arquivo principal de configuração"

#. type: TP
#: condinapt.1:75
#, no-wrap
msgid "\\f[B]-m\\f[R], \\f[B]--filter-mapping\\f[R] \\f[I]PATH\\fR"
msgstr "\\f[B]-m\\f[R], \\f[B]--filter-mapping\\f[R] \\f[I]PATH\\fR"

#. type: Plain text
#: condinapt.1:78
msgid "(Optional) Path to the filter mapping file"
msgstr "(Opcional) Caminho para o arquivo de mapeamento de filtros"

#. type: TP
#: condinapt.1:78
#, no-wrap
msgid "\\f[B]-P\\f[R], \\f[B]--priority-list\\f[R] \\f[I]PATH\\fR"
msgstr "\\f[B]-P\\f[R], \\f[B]--priority-list\\f[R] \\f[I]PATH\\fR"

#. type: Plain text
#: condinapt.1:81
msgid "(Optional) Path to the priority package list file"
msgstr "(Opcional) Caminho para o arquivo de lista de pacotes prioritários"

#. type: TP
#: condinapt.1:81
#, no-wrap
msgid "\\f[B]-s\\f[R], \\f[B]--simulation\\fR"
msgstr "\\f[B]-s\\f[R], \\f[B]--simulation\\fR"

#. type: Plain text
#: condinapt.1:85
msgid "Simulation mode.  Packages will not be installed"
msgstr "Modo de simulação. Os pacotes não serão instalados"

#. type: TP
#: condinapt.1:85
#, no-wrap
msgid "\\f[B]-C\\f[R], \\f[B]--check-only\\fR"
msgstr "\\f[B]-C\\f[R], \\f[B]--check-only\\fR"

#. type: Plain text
#: condinapt.1:88
msgid "Only check if packages are already installed"
msgstr "Apenas verifica se os pacotes já estão instalados"

#. type: TP
#: condinapt.1:88
#, no-wrap
msgid "\\f[B]-v\\f[R], \\f[B]--verbose\\fR"
msgstr "\\f[B]-v\\f[R], \\f[B]--verbose\\fR"

#. type: Plain text
#: condinapt.1:91
msgid "Verbose output"
msgstr "Saída detalhada"

#. type: TP
#: condinapt.1:91
#, no-wrap
msgid "\\f[B]-vv\\f[R], \\f[B]--very-verbose\\fR"
msgstr "\\f[B]-vv\\f[R], \\f[B]--very-verbose\\fR"

#. type: Plain text
#: condinapt.1:94
msgid "Very verbose output"
msgstr "Saída muito detalhada"

#. type: TP
#: condinapt.1:94
#, no-wrap
msgid "\\f[B]-x\\f[R], \\f[B]--xtrace\\fR"
msgstr "\\f[B]-x\\f[R], \\f[B]--xtrace\\fR"

#. type: Plain text
#: condinapt.1:97
msgid "Enable \\f[B]set -x\\f[R] command tracing\\fR"
msgstr "Habilita o rastreamento de comandos \\f[B]set -x\\f[R]"

#. type: TP
#: condinapt.1:97
#, no-wrap
msgid "\\f[B]-f\\f[R], \\f[B]--force\\fR"
msgstr "\\f[B]-f\\f[R], \\f[B]--force\\fR"

#. type: Plain text
#: condinapt.1:100
msgid "Force apt cache update (apt update)"
msgstr "Força a atualização do cache do apt (apt update)"

#. type: TP
#: condinapt.1:100
#, no-wrap
msgid "\\f[B]-h\\f[R], \\f[B]--help\\fR"
msgstr "\\f[B]-h\\f[R], \\f[B]--help\\fR"

#. type: Plain text
#: condinapt.1:103
msgid "Show help"
msgstr "Exibe a ajuda"

#. type: SH
#: condinapt.1:103
#, no-wrap
msgid "CORE COMPONENTS"
msgstr "COMPONENTES PRINCIPAIS"

#. type: Plain text
#: condinapt.1:106
msgid "CondinAPT operates with four key files:"
msgstr "O CondinAPT opera com quatro arquivos principais:"

#. type: SS
#: condinapt.1:106
#, no-wrap
msgid "condinapt script"
msgstr "script condinapt"

#. type: Plain text
#: condinapt.1:109
msgid "The core, containing all processing logic"
msgstr "O núcleo, contendo toda a lógica de processamento"

#. type: SS
#: condinapt.1:109
#, no-wrap
msgid "Main configuration file (-c)"
msgstr "Arquivo principal de configuração (-c)"

#. type: Plain text
#: condinapt.1:112
msgid "A file with bash variables describing the current environment"
msgstr "Um arquivo com variáveis bash que descrevem o ambiente atual"

#. type: Plain text
#: condinapt.1:114
msgid "Example (\\f[B]system.conf\\f[R]):\\fR"
msgstr "Exemplo (\\f[B]system.conf\\f[R]):\\fR"

#. type: Plain text
#: condinapt.1:123
#, no-wrap
msgid ""
"\\f[C]\n"
"DISTRIBUTION=\\[dq]bookworm\\[dq]\n"
"SYSTEM_TYPE=\\[dq]server\\[dq]\n"
"ENVIRONMENT=\\[dq]production\\[dq]\n"
"LOCALE=\\[dq]en_US\\[dq]\n"
"FEATURES=\\[dq]web,database\\[dq]\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"DISTRIBUTION=\\[dq]bookworm\\[dq]\n"
"SYSTEM_TYPE=\\[dq]server\\[dq]\n"
"ENVIRONMENT=\\[dq]production\\[dq]\n"
"LOCALE=\\[dq]en_US\\[dq]\n"
"FEATURES=\\[dq]web,database\\[dq]\\fR\n"
"\n"

#. type: SS
#: condinapt.1:124
#, no-wrap
msgid "Filter mapping file (-m)"
msgstr "Arquivo de mapeamento de filtros (-m)"

#. type: Plain text
#: condinapt.1:132
msgid "Links short prefixes (used in the package list) to variable names from the main configuration file.  This file is \\f[B]optional\\f[R].  If a filter is not present in the filter mapping file, it will be used as a variable name from the main configuration file.  If the variable is not found, CondinAPT will declare it empty.\\fR"
msgstr "Associa prefixos curtos (usados na lista de pacotes) a nomes de variáveis do arquivo principal de configuração. Este arquivo é \\f[B]opcional\\f[R]. Caso um filtro não esteja presente no arquivo de mapeamento, ele será utilizado como nome de variável do arquivo de configuração principal. Se a variável não for encontrada, o CondinAPT irá declará-la vazia.\\fR"

#. type: Plain text
#: condinapt.1:134
msgid "Example (\\f[B]filters.map\\f[R]):\\fR"
msgstr "Exemplo (\\f[B]filters.map\\f[R]):\\fR"

#. type: Plain text
#: condinapt.1:143
#, no-wrap
msgid ""
"\\f[C]\n"
"d=DISTRIBUTION\n"
"st=SYSTEM_TYPE\n"
"env=ENVIRONMENT\n"
"arch=ARCHITECTURE\n"
"feat=FEATURES\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"d=DISTRIBUTION\n"
"st=SYSTEM_TYPE\n"
"env=ENVIRONMENT\n"
"arch=ARCHITECTURE\n"
"feat=FEATURES\\fR\n"
"\n"

#. type: SS
#: condinapt.1:144
#, no-wrap
msgid "Package list file (-l)"
msgstr "Arquivo de lista de pacotes (-l)"

#. type: Plain text
#: condinapt.1:147
msgid "The main file describing what to install and under what conditions"
msgstr "Arquivo principal que descreve o que instalar e sob quais condições"

#. type: SH
#: condinapt.1:147
#, no-wrap
msgid "PACKAGE LIST SYNTAX"
msgstr "SINTAXE DA LISTA DE PACOTES"

#. type: Plain text
#: condinapt.1:150
msgid "Each line in the package list file consists of two main parts:"
msgstr "Cada linha do arquivo de lista de pacotes consiste em duas partes principais:"

#. type: IP
#: condinapt.1:150
#, no-wrap
msgid "1."
msgstr "1."

#. type: Plain text
#: condinapt.1:152
msgid "Package name with optional version and release specification"
msgstr "Nome do pacote com especificação opcional de versão e release"

#. type: IP
#: condinapt.1:152 condinapt.1:466
#, no-wrap
msgid "2."
msgstr "2."

#. type: Plain text
#: condinapt.1:155
msgid "Condition filters - define the conditions under which the package will be installed"
msgstr "Filtros de condição – definem as condições sob as quais o pacote será instalado"

#. type: SS
#: condinapt.1:155
#, no-wrap
msgid "Package Name Structure"
msgstr "Estrutura do Nome do Pacote"

#. type: Plain text
#: condinapt.1:158
msgid "\\f[B]Simple name:\\fR"
msgstr "\\f[B]Nome simples:\\fR"

#. type: Plain text
#: condinapt.1:163
#, no-wrap
msgid ""
"\\f[C]\n"
"vim\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"vim\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:166
msgid "\\f[B]Package version:\\fR"
msgstr "\\f[B]Versão do pacote:\\fR"

#. type: Plain text
#: condinapt.1:170
msgid "\\f[B]package=version\\f[R] - loose version requirement.  If the required version is unavailable, an available version is installed\\fR"
msgstr "\\f[B]package=version\\f[R] – requisito de versão flexível. Caso a versão solicitada não esteja disponível, será instalada uma versão disponível\\fR"

#. type: Plain text
#: condinapt.1:173
msgid "\\f[B]package==version\\f[R] - strict requirement.  If the version is not found, installation aborts with an error\\fR"
msgstr "\\f[B]package==version\\f[R] – requisito estrito. Se a versão não for encontrada, a instalação é abortada com erro\\fR"

#. type: Plain text
#: condinapt.1:175
msgid "\\f[B]Release specification:\\fR"
msgstr "\\f[B]Especificação de release:\\fR"

#. type: Plain text
#: condinapt.1:177
msgid "The release is specified using the **\\[at]** symbol:"
msgstr "A release é especificada usando o símbolo **\\[at]**:"

#. type: Plain text
#: condinapt.1:183
#, no-wrap
msgid ""
"\\f[C]\n"
"telegram\\[at]bookworm-backports\n"
"kernel-image-6.5.0\\[at]trixie-backports\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"telegram\\[at]bookworm-backports\n"
"kernel-image-6.5.0\\[at]trixie-backports\\fR\n"
"\n"

#. type: SS
#: condinapt.1:184
#, no-wrap
msgid "File Structure"
msgstr "Estrutura de Arquivo"

#. type: Plain text
#: condinapt.1:188
msgid "\\f[B]Package names:\\f[R] Each package or condition is written on a new line\\fR"
msgstr "\\f[B]Nomes de pacotes:\\f[R] Cada pacote ou condição deve ser escrito em uma nova linha\\fR"

#. type: Plain text
#: condinapt.1:191
msgid "\\f[B]Comments:\\f[R] Lines starting with \\f[B]#\\f[R], or text after \\f[B]#\\f[R] on a line, are completely ignored\\fR"
msgstr "\\f[B]Comentários:\\f[R] Linhas iniciadas com \\f[B]#\\f[R], ou texto após \\f[B]#\\f[R] em uma linha, são completamente ignorados\\fR"

#. type: Plain text
#: condinapt.1:193
msgid "\\f[B]Empty lines:\\f[R] Ignored and serve for visual separation\\fR"
msgstr "\\f[B]Linhas em branco:\\f[R] Ignoradas e servem para separação visual\\fR"

#. type: SS
#: condinapt.1:193
#, no-wrap
msgid "Filters and Conditions"
msgstr "Filtros e Condições"

#. type: SS
#: condinapt.1:194
#, no-wrap
msgid "Single Filters"
msgstr "Filtros Simples"

#. type: Plain text
#: condinapt.1:198
msgid "\\f[B]+ (Positive):\\f[R] The condition is true if the variable value \\f[B]matches\\fR"
msgstr "\\f[B]+ (Positivo):\\f[R] A condição é verdadeira se o valor da variável \\f[B]corresponder\\fR"

#. type: Plain text
#: condinapt.1:200
msgid "Format: \\f[B]+=\\fR"
msgstr "Formato: \\f[B]+=\\fR"

#. type: Plain text
#: condinapt.1:202 condinapt.1:215 condinapt.1:306
msgid "Example:"
msgstr "Exemplo:"

#. type: Plain text
#: condinapt.1:207
#, no-wrap
msgid ""
"\\f[C]\n"
"nginx +st=server\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"nginx +st=server\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:211
msgid "\\f[B]- (Negative):\\f[R] The condition is true if the variable value \\f[B]does not match\\fR"
msgstr "\\f[B]- (Negativo):\\f[R] A condição é verdadeira se o valor da variável \\f[B]não corresponder\\fR"

#. type: Plain text
#: condinapt.1:213
msgid "Format: \\f[B]-=\\fR"
msgstr "Formato: \\f[B]-=\\fR"

#. type: Plain text
#: condinapt.1:220
#, no-wrap
msgid ""
"\\f[C]\n"
"monitoring-tools -st=desktop\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"monitoring-tools -st=desktop\\fR\n"
"\n"

#. type: SS
#: condinapt.1:221
#, no-wrap
msgid "Group Filters"
msgstr "Filtros de Grupo"

#. type: Plain text
#: condinapt.1:225
msgid "\\f[B]+{a|b} (OR for inclusion):\\f[R] True if \\f[B]at least one\\f[R] of the conditions in the group is true\\fR"
msgstr "\\f[B]+{a|b} (OU para inclusão):\\f[R] Verdadeiro se \\f[B]ao menos uma\\f[R] das condições do grupo for verdadeira\\fR"

#. type: Plain text
#: condinapt.1:230
#, no-wrap
msgid ""
"\\f[C]\n"
"web-server +{st=server|st=web-server}\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"web-server +{st=server|st=web-server}\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:234
msgid "\\f[B]+{a&b} (AND for inclusion):\\f[R] True only if \\f[B]all\\f[R] conditions in the group are true\\fR"
msgstr "\\f[B]+{a&b} (E para inclusão):\\f[R] Verdadeiro somente se \\f[B]todas\\f[R] as condições do grupo forem verdadeiras\\fR"

#. type: Plain text
#: condinapt.1:239
#, no-wrap
msgid ""
"\\f[C]\n"
"database-tools +{d=bookworm&st=server}\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"database-tools +{d=bookworm&st=server}\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:243
msgid "\\f[B]-{a|b} (OR for exclusion):\\f[R] The package is excluded if \\f[B]at least one\\f[R] of the conditions is true\\fR"
msgstr "\\f[B]-{a|b} (OU para exclusão):\\f[R] O pacote é excluído se \\f[B]ao menos uma\\f[R] das condições for verdadeira\\fR"

#. type: Plain text
#: condinapt.1:248
#, no-wrap
msgid ""
"\\f[C]\n"
"debug-tools -{env=production|st=minimal}\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"debug-tools -{env=production|st=minimal}\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:252
msgid "\\f[B]-{a&b} (AND for exclusion):\\f[R] The package is excluded only if \\f[B]all\\f[R] conditions are true\\fR"
msgstr "\\f[B]-{a&b} (E para exclusão):\\f[R] O pacote é excluído somente se \\f[B]todas\\f[R] as condições forem verdadeiras\\fR"

#. type: Plain text
#: condinapt.1:257
#, no-wrap
msgid ""
"\\f[C]\n"
"development-tools -{env=production&st=minimal}\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"development-tools -{env=production&st=minimal}\\fR\n"
"\n"

#. type: SS
#: condinapt.1:258
#, no-wrap
msgid "Logical Operators"
msgstr "Operadores Lógicos"

#. type: Plain text
#: condinapt.1:262
msgid "\\f[B]|| (OR / Fallback):\\f[R] Try to install the left part.  If it fails, try the right part\\fR"
msgstr "\\f[B]|| (OU / Alternativa):\\f[R] Tenta instalar a parte à esquerda. Se falhar, tenta a parte à direita\\fR"

#. type: Plain text
#: condinapt.1:267
#, no-wrap
msgid ""
"\\f[C]\n"
"exfatprogs -d=bookworm || exfat-utils\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"exfatprogs -d=bookworm || exfat-utils\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:271
msgid "\\f[B]&& (AND / Conjunction):\\f[R] All parts must successfully pass filter checks\\fR"
msgstr "\\f[B]&& (E / Conjunção):\\f[R] Todas as partes devem passar com sucesso pelas verificações de filtro\\fR"

#. type: Plain text
#: condinapt.1:276
#, no-wrap
msgid ""
"\\f[C]\n"
"nginx +st=web-server && php-fpm\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"nginx +st=web-server && php-fpm\\fR\n"
"\n"

#. type: SS
#: condinapt.1:277
#, no-wrap
msgid "Special Modifiers"
msgstr "Modificadores Especiais"

#. type: Plain text
#: condinapt.1:283
msgid "\\f[B]! (Mandatory Package):\\f[R] If a package is marked with \\f[B]!\\f[R], but cannot be found in repositories, CondinAPT will abort execution with an error\\fR"
msgstr "\\f[B]! (Pacote obrigatório):\\f[R] Se um pacote estiver marcado com \\f[B]!\\f[R], mas não for encontrado nos repositórios, o CondinAPT abortará a execução com erro\\fR"

#. type: Plain text
#: condinapt.1:288
#, no-wrap
msgid ""
"\\f[C]\n"
"!essential-package\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"!essential-package\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:292
msgid "\\f[B]\\[at] (Release Specification):\\f[R] Install a package from a specific Debian/Ubuntu release\\fR"
msgstr "\\f[B]\\[at] (Especificação de release):\\f[R] Instala um pacote de uma release específica do Debian/Ubuntu\\fR"

#. type: Plain text
#: condinapt.1:297
#, no-wrap
msgid ""
"\\f[C]\n"
"kernel-image-6.5.0 \\[at]trixie-backports\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"kernel-image-6.5.0 \\[at]trixie-backports\\fR\n"
"\n"

#. type: SS
#: condinapt.1:298
#, no-wrap
msgid "Installation Queues"
msgstr "Filas de Instalação"

#. type: Plain text
#: condinapt.1:304
msgid "The \\f[B]\\[em]\\f[R] separator on a separate line divides the list into groups (queues).  Packages from one queue are installed together in a single apt call.  Queues are executed strictly sequentially.\\fR"
msgstr "O separador \\f[B]\\[em]\\f[R] em uma linha separada divide a lista em grupos (filas). Pacotes de uma mesma fila são instalados juntos em uma única chamada do apt. As filas são executadas estritamente em sequência.\\fR"

#. type: Plain text
#: condinapt.1:320
#, no-wrap
msgid ""
"\\f[C]\n"
"# Queue 1: Base system\n"
"systemd\n"
"network-manager\n"
"---\n"
"# Queue 2: Web server\n"
"nginx\n"
"php-fpm\n"
"---\n"
"# Queue 3: Monitoring\n"
"prometheus\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"# Queue 1: Base system\n"
"systemd\n"
"network-manager\n"
"---\n"
"# Queue 2: Web server\n"
"nginx\n"
"php-fpm\n"
"---\n"
"# Queue 3: Monitoring\n"
"prometheus\\fR\n"
"\n"

#. type: SS
#: condinapt.1:321
#, no-wrap
msgid "Priority Queue"
msgstr "Fila de Prioridade"

#. type: Plain text
#: condinapt.1:326
msgid "Packages listed in the file specified by the \\f[B]-P\\f[R] flag (one package per line, no filters) form a special \\[lq]Queue #1\\[rq], which is executed first.\\fR"
msgstr "Pacotes listados no arquivo especificado pela opção \\f[B]-P\\f[R] (um pacote por linha, sem filtros) formam uma \\[lq]Fila #1\\[rq] especial, que é executada primeiro.\\fR"

#. type: Plain text
#: condinapt.1:330
msgid "Any package from the priority list is automatically removed from all regular queues.  This ensures it will be installed unconditionally."
msgstr "Qualquer pacote da lista de prioridades é removido automaticamente de todas as filas regulares. Isso garante que ele será instalado incondicionalmente."

#. type: SS
#: condinapt.1:331
#, no-wrap
msgid "Quick Start"
msgstr "Início Rápido"

#. type: Plain text
#: condinapt.1:334
msgid "Create the configuration file \\f[B]config.conf\\f[R]:\\fR"
msgstr "Crie o arquivo de configuração \\f[B]config.conf\\f[R]:\\fR"

#. type: Plain text
#: condinapt.1:341
#, no-wrap
msgid ""
"\\f[C]\n"
"DISTRIBUTION=\\[dq]bookworm\\[dq]\n"
"SYSTEM_TYPE=\\[dq]server\\[dq]\n"
"ENVIRONMENT=\\[dq]production\\[dq]\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"DISTRIBUTION=\\[dq]bookworm\\[dq]\n"
"SYSTEM_TYPE=\\[dq]server\\[dq]\n"
"ENVIRONMENT=\\[dq]production\\[dq]\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:344
msgid "Create the package list \\f[B]packages.list\\f[R]:\\fR"
msgstr "Crie a lista de pacotes \\f[B]packages.list\\f[R]:\\fR"

#. type: Plain text
#: condinapt.1:350
#, no-wrap
msgid ""
"\\f[C]\n"
"# Base packages - always installed\n"
"vim\n"
"curl\\fR\n"
msgstr ""
"\\f[C]\n"
"# Pacotes base - sempre instalados\n"
"vim\n"
"curl\\fR\n"

#. type: Plain text
#: condinapt.1:354
#, no-wrap
msgid ""
"\\f[C]# Packages only for servers\n"
"nginx +SYSTEM_TYPE=server\n"
"mysql-server +SYSTEM_TYPE=server\\fR\n"
msgstr ""
"\\f[C]# Pacotes apenas para servidores\n"
"nginx +SYSTEM_TYPE=server\n"
"mysql-server +SYSTEM_TYPE=server\\fR\n"

#. type: Plain text
#: condinapt.1:358
#, no-wrap
msgid ""
"\\f[C]# Exclude packages for production environment\n"
"debug-tools -ENVIRONMENT=production\\fR\n"
"\n"
msgstr ""
"\\f[C]# Excluir pacotes para ambiente de produção\n"
"debug-tools -ENVIRONMENT=production\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:361
msgid "Run the installation:"
msgstr "Execute a instalação:"

#. type: Plain text
#: condinapt.1:366
#, no-wrap
msgid ""
"\\f[C]\n"
"condinapt -l packages.list -c config.conf\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"condinapt -l packages.list -c config.conf\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:369
msgid "Or test in simulation mode:"
msgstr "Ou teste em modo de simulação:"

#. type: Plain text
#: condinapt.1:374
#, no-wrap
msgid ""
"\\f[C]\n"
"condinapt -l packages.list -c config.conf -s\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"condinapt -l packages.list -c config.conf -s\\fR\n"
"\n"

#. type: SS
#: condinapt.1:375
#, no-wrap
msgid "Multimedia Server"
msgstr "Servidor Multimídia"

#. type: Plain text
#: condinapt.1:378 condinapt.1:400 condinapt-minios.7:142
#: condinapt-minios.7:165 condinapt-minios.7:186 condinapt-minios.7:213
msgid "\\f[B]packages.list:\\fR"
msgstr "\\f[B]packages.list:\\fR"

#. type: Plain text
#: condinapt.1:384 condinapt-minios.7:148
#, no-wrap
msgid ""
"\\f[C]\n"
"# Basic multimedia codecs - always\n"
"gstreamer1.0-plugins-base\n"
"gstreamer1.0-plugins-good\\fR\n"
msgstr ""
"\\f[C]\n"
"# Codecs multimídia básicos - sempre\n"
"gstreamer1.0-plugins-base\n"
"gstreamer1.0-plugins-good\\fR\n"

#. type: Plain text
#: condinapt.1:388
#, no-wrap
msgid ""
"\\f[C]# Additional codecs - not for minimal installation\n"
"gstreamer1.0-plugins-bad -st=minimal\n"
"gstreamer1.0-plugins-ugly -st=minimal\\fR\n"
msgstr ""
"\\f[C]# Codecs adicionais - não para instalação mínima\n"
"gstreamer1.0-plugins-bad -st=minimal\n"
"gstreamer1.0-plugins-ugly -st=minimal\\fR\n"

#. type: Plain text
#: condinapt.1:396
#, no-wrap
msgid ""
"\\f[C]# Professional tools - only for full configuration\n"
"ffmpeg +st=media-server\n"
"vlc +st=media-server\n"
"---\n"
"# Distribution-specific packages from backports\n"
"ffmpeg \\[at]bookworm-backports +d=bookworm\\fR\n"
"\n"
msgstr ""
"\\f[C]# Ferramentas profissionais - apenas para configuração completa\n"
"ffmpeg +st=media-server\n"
"vlc +st=media-server\n"
"---\n"
"# Pacotes específicos da distribuição dos backports\n"
"ffmpeg \\[at]bookworm-backports +d=bookworm\\fR\n"
"\n"

#. type: SS
#: condinapt.1:397
#, no-wrap
msgid "Web Server with Various Configurations"
msgstr "Servidor Web com Várias Configurações"

#. type: Plain text
#: condinapt.1:406
#, no-wrap
msgid ""
"\\f[C]\n"
"# Basic web server components\n"
"nginx\n"
"openssl\\fR\n"
msgstr ""
"\\f[C]\n"
"# Componentes básicos de servidor web\n"
"nginx\n"
"openssl\\fR\n"

#. type: Plain text
#: condinapt.1:410
#, no-wrap
msgid ""
"\\f[C]# Database - only for full installations\n"
"mysql-server +st=full-server -{env=minimal}\n"
"postgresql +st=database-server\\fR\n"
msgstr ""
"\\f[C]# Banco de dados - apenas para instalações completas\n"
"mysql-server +st=full-server -{env=minimal}\n"
"postgresql +st=database-server\\fR\n"

#. type: Plain text
#: condinapt.1:414
#, no-wrap
msgid ""
"\\f[C]# PHP - for web servers\n"
"php-fpm +feat=php\n"
"php-mysql +{feat=php&st=full-server}\\fR\n"
msgstr ""
"\\f[C]# PHP - para servidores web\n"
"php-fpm +feat=php\n"
"php-mysql +{feat=php&st=full-server}\\fR\n"

#. type: Plain text
#: condinapt.1:418
#, no-wrap
msgid ""
"\\f[C]# Monitoring - not for development\n"
"prometheus-node-exporter -env=development\\fR\n"
"\n"
msgstr ""
"\\f[C]# Monitoramento - não para desenvolvimento\n"
"prometheus-node-exporter -env=development\\fR\n"
"\n"

#. type: SH
#: condinapt.1:419
#, no-wrap
msgid "OPERATING MODES"
msgstr "MODOS DE OPERAÇÃO"

#. type: SS
#: condinapt.1:420
#, no-wrap
msgid "Simulation Mode"
msgstr "Modo de Simulação"

#. type: Plain text
#: condinapt.1:424
msgid "Allows you to see which packages will be installed without actually installing them:"
msgstr "Permite visualizar quais pacotes serão instalados sem realmente instalá-los:"

#. type: Plain text
#: condinapt.1:429
#, no-wrap
msgid ""
"\\f[C]\n"
"condinapt -l packages.list -c system.conf -s\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"condinapt -l packages.list -c system.conf -s\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:432
msgid "In simulation mode, the script exits with exit code 1."
msgstr "No modo de simulação, o script termina com código de saída 1."

#. type: SS
#: condinapt.1:432
#, no-wrap
msgid "Check Mode"
msgstr "Modo de Verificação"

#. type: Plain text
#: condinapt.1:435
msgid "Checks which packages from the list are already installed on the system:"
msgstr "Verifica quais pacotes da lista já estão instalados no sistema:"

#. type: Plain text
#: condinapt.1:440
#, no-wrap
msgid ""
"\\f[C]\n"
"condinapt -l packages.list -c system.conf -C\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"condinapt -l packages.list -c system.conf -C\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:444
msgid "Shows errors for uninstalled packages and returns exit code 1 if there are uninstalled packages."
msgstr "Exibe erros para pacotes não instalados e retorna código de saída 1 se houver pacotes não instalados."

#. type: SS
#: condinapt.1:444
#, no-wrap
msgid "Debugging Modes"
msgstr "Modos de Depuração"

#. type: Plain text
#: condinapt.1:447
msgid "\\f[B]Verbose Output (-v):\\fR"
msgstr "\\f[B]Saída Verbosa (-v):\\fR"

#. type: Plain text
#: condinapt.1:450
msgid "Shows detailed information about filter checks and displays results for each package."
msgstr "Exibe informações detalhadas sobre as verificações de filtros e mostra resultados para cada pacote."

#. type: Plain text
#: condinapt.1:452
msgid "\\f[B]Very Verbose Output (-vv):\\fR"
msgstr "\\f[B]Saída Muito Verbosa (-vv):\\fR"

#. type: Plain text
#: condinapt.1:454
msgid "Maximum process detail, shows all intermediate steps."
msgstr "Detalhamento máximo do processo, mostra todas as etapas intermediárias."

#. type: Plain text
#: condinapt.1:456
msgid "\\f[B]Command Tracing (-x):\\fR"
msgstr "\\f[B]Rastreamento de Comandos (-x):\\fR"

#. type: Plain text
#: condinapt.1:459
msgid "Enables \\f[B]set -x\\f[R] for script debugging, shows each command being executed.\\fR"
msgstr "Ativa \\f[B]set -x\\f[R] para depuração do script, mostrando cada comando executado.\\fR"

#. type: SH
#: condinapt.1:459
#, no-wrap
msgid "ERROR HANDLING"
msgstr "TRATAMENTO DE ERROS"

#. type: SS
#: condinapt.1:460
#, no-wrap
msgid "Mandatory Packages"
msgstr "Pacotes Obrigatórios"

#. type: Plain text
#: condinapt.1:464
msgid "If a package is marked as mandatory (\\f[B]!\\f[R]) but not found in repositories, CondinAPT:\\fR"
msgstr "Se um pacote for marcado como obrigatório (\\f[B]!\\f[R]) mas não for encontrado nos repositórios, o CondinAPT:\\fR"

#. type: IP
#: condinapt.1:464
#, no-wrap
msgid "\\f[R]1.\\fR"
msgstr "\\f[R]1.\\fR"

#. type: Plain text
#: condinapt.1:466
msgid "Outputs an error message"
msgstr "Exibe uma mensagem de erro"

#. type: Plain text
#: condinapt.1:468
msgid "Aborts execution (unless in simulation mode)"
msgstr "Interrompe a execução (a menos que esteja em modo de simulação)"

#. type: IP
#: condinapt.1:468
#, no-wrap
msgid "3."
msgstr "3."

#. type: Plain text
#: condinapt.1:470
msgid "Returns exit code 1"
msgstr "Retorna o código de saída 1"

#. type: SS
#: condinapt.1:470
#, no-wrap
msgid "Handling Unavailable Versions"
msgstr "Tratamento de Versões Indisponíveis"

#. type: Plain text
#: condinapt.1:473
msgid "\\f[B]Loose Versions (=):\\fR"
msgstr "\\f[B]Versões Flexíveis (=):\\fR"

#. type: Plain text
#: condinapt.1:476
msgid "If the exact version is unavailable, any available version is installed with a warning."
msgstr "Se a versão exata não estiver disponível, qualquer versão disponível será instalada com um aviso."

#. type: Plain text
#: condinapt.1:478
msgid "\\f[B]Strict Versions (==):\\fR"
msgstr "\\f[B]Versões Estritas (==):\\fR"

#. type: Plain text
#: condinapt.1:481
msgid "If the exact version is unavailable, the package is skipped.  If the package is mandatory (\\f[B]!\\f[R]), execution aborts.\\fR"
msgstr "Se a versão exata não estiver disponível, o pacote é ignorado. Se o pacote for obrigatório (\\f[B]!\\f[R]), a execução é interrompida.\\fR"

#. type: SS
#: condinapt.1:481
#, no-wrap
msgid "Version Holding"
msgstr "Retenção de Versão"

#. type: Plain text
#: condinapt.1:485
msgid "CondinAPT automatically applies \\f[B]apt-mark hold\\f[R] when the exactly requested version was installed, preventing automatic updates.\\fR"
msgstr "O CondinAPT aplica automaticamente o \\f[B]apt-mark hold\\f[R] quando a versão solicitada exatamente é instalada, prevenindo atualizações automáticas.\\fR"

#. type: SH
#: condinapt.1:485 condinapt-minios.7:297
#, no-wrap
msgid "FILES"
msgstr "ARQUIVOS"

#. type: TP
#: condinapt.1:486
#, no-wrap
msgid "\\f[B]/etc/condinapt/config.conf\\fR"
msgstr "\\f[B]/etc/condinapt/config.conf\\fR"

#. type: Plain text
#: condinapt.1:489
msgid "Default configuration file"
msgstr "Arquivo de configuração padrão"

#. type: TP
#: condinapt.1:489
#, no-wrap
msgid "\\f[B]/etc/condinapt/filters.map\\fR"
msgstr "\\f[B]/etc/condinapt/filters.map\\fR"

#. type: Plain text
#: condinapt.1:492
msgid "Default filter mapping file"
msgstr "Arquivo padrão de mapeamento de filtros"

#. type: Plain text
#: condinapt.1:496
msgid "\\f[B]apt\\f[R](8), \\f[B]apt-get\\f[R](8), \\f[B]apt-cache\\f[R](8), \\f[B]condinapt-minios\\f[R](7)\\fR"
msgstr "\\f[B]apt\\f[R](8), \\f[B]apt-get\\f[R](8), \\f[B]apt-cache\\f[R](8), \\f[B]condinapt-minios\\f[R](7)\\fR"
