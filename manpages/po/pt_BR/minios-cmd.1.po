#. type: SH
#: minios-cmd.1:221
#, no-wrap
msgid "GENERATING AND USING CONFIGURATION FILES"
msgstr "GERAÇÃO E USO DE ARQUIVOS DE CONFIGURAÇÃO"

#. type: Plain text
#: minios-cmd.1:224
msgid "Generate a configuration file:"
msgstr "Gerar um arquivo de configuração:"

#. type: Plain text
#: minios-cmd.1:229
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-cmd --config-only --config-file myconfig.conf -d bookworm -a amd64 -de xfce -pv standard\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-cmd --config-only --config-file myconfig.conf -d bookworm -a amd64 -de xfce -pv standard\\fR\n"
"\n"

#. type: Plain text
#: minios-cmd.1:232
msgid "Use the configuration file with \\f[B]minios-live\\f[R]:\\fR"
msgstr "Utilize o arquivo de configuração com \\f[B]minios-live\\f[R]:\\fR"

#. type: Plain text
#: minios-cmd.1:237
#, no-wrap
msgid ""
"\\f[C]\n"
"BUILD_CONF=/path/to/myconfig.conf minios-live -\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"BUILD_CONF=/path/to/myconfig.conf minios-live -\\fR\n"
"\n"

#. type: Plain text
#: minios-cmd.1:240
msgid "or:"
msgstr "ou:"

#. type: Plain text
#: minios-cmd.1:246
#, no-wrap
msgid ""
"\\f[C]\n"
"export BUILD_CONF=/path/to/myconfig.conf\n"
"minios-live -\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"export BUILD_CONF=/path/to/myconfig.conf\n"
"minios-live -\\fR\n"
"\n"

#. type: Plain text
#: minios-cmd.1:251
msgid "\\f[B]minios-live\\f[R](1), \\f[B]condinapt\\f[R](1), \\f[B]condinapt-minios\\f[R](7)\\fR"
msgstr "\\f[B]minios-live\\f[R](1), \\f[B]condinapt\\f[R](1), \\f[B]condinapt-minios\\f[R](7)\\fR"
