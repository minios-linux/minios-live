#. type: TH
#: minios-cmd.1:17
#, no-wrap
msgid "MINIOS-CMD"
msgstr "MINIOS-CMD"

#. type: TH
#: minios-cmd.1:17
#, no-wrap
msgid "MiniOS Command-Line Builder"
msgstr "Construtor de Linha de Comando do MiniOS"

#. type: Plain text
#: minios-cmd.1:23
msgid "minios-cmd - command-line utility for configuring and building customized MiniOS system images"
msgstr "minios-cmd - utilitário de linha de comando para configurar e construir imagens de sistema MiniOS personalizadas"

#. type: Plain text
#: minios-cmd.1:26
msgid "\\f[B]minios-cmd\\f[R] [\\f[I]OPTIONS\\f[R]]\\fR"
msgstr "\\f[B]minios-cmd\\f[R] [\\f[I]OPTIONS\\f[R]]\\fR"

#. type: Plain text
#: minios-cmd.1:33
msgid "\\f[B]minios-cmd\\f[R] is a command-line utility designed to simplify the process of configuring and building customized MiniOS system images.  Acting as a frontend for \\f[B]minios-live\\f[R](1), it manages the configuration and invokes \\f[B]minios-live\\f[R] to execute the actual build steps.\\fR"
msgstr "\\f[B]minios-cmd\\f[R] é um utilitário de linha de comando projetado para simplificar o processo de configuração e construção de imagens de sistema MiniOS personalizadas. Atuando como frontend para \\f[B]minios-live\\f[R](1), gerencia a configuração e invoca o \\f[B]minios-live\\f[R] para executar as etapas reais da construção.\\fR"

#. type: Plain text
#: minios-cmd.1:37
msgid "With \\f[B]minios-cmd\\f[R], you can customize various aspects of your MiniOS image, including:\\fR"
msgstr "Com o \\f[B]minios-cmd\\f[R], é possível personalizar vários aspectos da sua imagem MiniOS, incluindo:\\fR"

#. type: Plain text
#: minios-cmd.1:41
msgid "\\f[B]Distribution:\\f[R] Choose from Debian releases (\\f[B]buster\\f[R], \\f[B]bullseye\\f[R], \\f[B]bookworm\\f[R], \\f[B]trixie\\f[R]) and Ubuntu releases (\\f[B]jammy\\f[R], \\f[B]noble\\f[R])\\fR"
msgstr "\\f[B]Distribuição:\\f[R] Escolha entre versões do Debian (\\f[B]buster\\f[R], \\f[B]bullseye\\f[R], \\f[B]bookworm\\f[R], \\f[B]trixie\\f[R]) e versões do Ubuntu (\\f[B]jammy\\f[R], \\f[B]noble\\f[R])\\fR"

#. type: Plain text
#: minios-cmd.1:44
msgid "\\f[B]Architecture:\\f[R] Specify the target architecture (\\f[B]amd64\\f[R], \\f[B]i386\\f[R] for older distributions)\\fR"
msgstr "\\f[B]Arquitetura:\\f[R] Especifique a arquitetura de destino (\\f[B]amd64\\f[R], \\f[B]i386\\f[R] para distribuições antigas)\\fR"

#. type: Plain text
#: minios-cmd.1:46
msgid "\\f[B]Desktop Environment:\\fR"
msgstr "\\f[B]Ambiente de Desktop:\\fR"

#. type: Plain text
#: minios-cmd.1:50
msgid "\\f[B]Debian:\\f[R] \\f[B]xfce\\f[R] (standard), \\f[B]flux\\f[R] (minimum), \\f[B]lxqt\\f[R] (bookworm/trixie only)\\fR"
msgstr "\\f[B]Debian:\\f[R] \\f[B]xfce\\f[R] (padrão), \\f[B]flux\\f[R] (mínimo), \\f[B]lxqt\\f[R] (apenas bookworm/trixie)\\fR"

#. type: Plain text
#: minios-cmd.1:52
msgid "\\f[B]Ubuntu:\\f[R] \\f[B]xfce\\f[R] only\\fR"
msgstr "\\f[B]Ubuntu:\\f[R] apenas \\f[B]xfce\\f[R]\\fR"

#. type: Plain text
#: minios-cmd.1:55
msgid "\\f[B]Package Variant:\\fR"
msgstr "\\f[B]Variante de Pacote:\\fR"

#. type: Plain text
#: minios-cmd.1:59
msgid "\\f[B]All Debian:\\f[R] \\f[B]standard\\f[R] (xfce), \\f[B]minimum\\f[R] (flux)\\fR"
msgstr "\\f[B]Todos Debian:\\f[R] \\f[B]standard\\f[R] (xfce), \\f[B]minimum\\f[R] (flux)\\fR"

#. type: Plain text
#: minios-cmd.1:61
msgid "\\f[B]Bookworm/Trixie only:\\f[R] \\f[B]toolbox\\f[R], \\f[B]ultra\\fR"
msgstr "\\f[B]Apenas Bookworm/Trixie:\\f[R] \\f[B]toolbox\\f[R], \\f[B]ultra\\fR"

#. type: Plain text
#: minios-cmd.1:63
msgid "\\f[B]Ubuntu:\\f[R] \\f[B]standard\\f[R] only\\fR"
msgstr "\\f[B]Ubuntu:\\f[R] apenas \\f[B]standard\\f[R]\\fR"

#. type: Plain text
#: minios-cmd.1:67
msgid "\\f[B]Compression Type:\\f[R] Specify the image compression method (\\f[B]zstd\\f[R])\\fR"
msgstr "\\f[B]Tipo de Compressão:\\f[R] Especifique o método de compressão da imagem (\\f[B]zstd\\f[R])\\fR"

#. type: Plain text
#: minios-cmd.1:70
msgid "\\f[B]Kernel:\\f[R] Configure kernel type, enable AUFS support, and DKMS module compilation\\fR"
msgstr "\\f[B]Kernel:\\f[R] Configure o tipo de kernel, habilite suporte a AUFS e compilação de módulos DKMS\\fR"

#. type: Plain text
#: minios-cmd.1:73
msgid "\\f[B]Locale and Timezone:\\f[R] Set the system locale and timezone with multilingual support\\fR"
msgstr "\\f[B]Localidade e Fuso Horário:\\f[R] Defina o locale e o fuso horário do sistema com suporte multilíngue\\fR"

#. type: SH
#: minios-cmd.1:73 condinapt.1:68
#, no-wrap
msgid "OPTIONS"
msgstr "OPÇÕES"

#. type: SS
#: minios-cmd.1:74
#, no-wrap
msgid "Configuration Options"
msgstr "Opções de Configuração"

#. type: TP
#: minios-cmd.1:75
#, no-wrap
msgid "\\f[B]--config-file\\f[R] \\f[I]FILE\\fR"
msgstr "\\f[B]--config-file\\f[R] \\f[I]FILE\\fR"

#. type: Plain text
#: minios-cmd.1:79
msgid "Specify the configuration file path.  All other options are ignored."
msgstr "Especifique o caminho do arquivo de configuração. Todas as outras opções serão ignoradas."

#. type: TP
#: minios-cmd.1:79
#, no-wrap
msgid "\\f[B]--config-only\\fR"
msgstr "\\f[B]--config-only\\fR"

#. type: Plain text
#: minios-cmd.1:82
msgid "Generate the configuration file only and do not start the build process."
msgstr "Gera apenas o arquivo de configuração e não inicia o processo de construção."

#. type: TP
#: minios-cmd.1:83
#, no-wrap
msgid "\\f[B]-b\\f[R], \\f[B]--build-dir\\f[R] \\f[I]DIR\\fR"
msgstr "\\f[B]-b\\f[R], \\f[B]--build-dir\\f[R] \\f[I]DIR\\fR"

#. type: Plain text
#: minios-cmd.1:86
msgid "Specify the build directory."
msgstr "Especifique o diretório de construção."

#. type: SS
#: minios-cmd.1:86
#, no-wrap
msgid "System Options"
msgstr "Opções de Sistema"

#. type: Plain text
#: minios-cmd.1:90
msgid "These options \\f[B]must be provided\\f[R] unless a configuration file is used:\\fR"
msgstr "Essas opções \\f[B]devem ser fornecidas\\f[R] a menos que um arquivo de configuração seja utilizado:\\fR"

#. type: TP
#: minios-cmd.1:90
#, no-wrap
msgid "\\f[B]-d\\f[R], \\f[B]--distribution\\f[R] \\f[I]NAME\\fR"
msgstr "\\f[B]-d\\f[R], \\f[B]--distribution\\f[R] \\f[I]NAME\\fR"

#. type: Plain text
#: minios-cmd.1:94
msgid "Specify the distribution name (e.g., `bookworm').  \\f[B]REQUIRED\\fR"
msgstr "Especifique o nome da distribuição (ex.: `bookworm').  \\f[B]OBRIGATÓRIO\\fR"

#. type: TP
#: minios-cmd.1:94
#, no-wrap
msgid "\\f[B]-a\\f[R], \\f[B]--architecture\\f[R] \\f[I]NAME\\fR"
msgstr "\\f[B]-a\\f[R], \\f[B]--architecture\\f[R] \\f[I]NAME\\fR"

#. type: Plain text
#: minios-cmd.1:98
msgid "Specify the architecture (e.g., `amd64').  \\f[B]REQUIRED\\fR"
msgstr "Especifique a arquitetura (ex.: `amd64').  \\f[B]OBRIGATÓRIO\\fR"

#. type: TP
#: minios-cmd.1:98
#, no-wrap
msgid "\\f[B]-de\\f[R], \\f[B]--desktop-environment\\f[R] \\f[I]NAME\\fR"
msgstr "\\f[B]-de\\f[R], \\f[B]--desktop-environment\\f[R] \\f[I]NAME\\fR"

#. type: Plain text
#: minios-cmd.1:102
msgid "Specify the desktop environment (e.g., `xfce').  \\f[B]REQUIRED\\fR"
msgstr "Especifique o ambiente de área de trabalho (ex.: `xfce').  \\f[B]OBRIGATÓRIO\\fR"

#. type: TP
#: minios-cmd.1:102
#, no-wrap
msgid "\\f[B]-pv\\f[R], \\f[B]--package-variant\\f[R] \\f[I]NAME\\fR"
msgstr "\\f[B]-pv\\f[R], \\f[B]--package-variant\\f[R] \\f[I]NAME\\fR"

#. type: Plain text
#: minios-cmd.1:106
msgid "Specify the package variant (e.g., `standard').  \\f[B]REQUIRED\\fR"
msgstr "Especifique a variante de pacote (ex.: `standard').  \\f[B]OBRIGATÓRIO\\fR"

#. type: TP
#: minios-cmd.1:106
#, no-wrap
msgid "\\f[B]-c\\f[R], \\f[B]--compression-type\\f[R] \\f[I]NAME\\fR"
msgstr "\\f[B]-c\\f[R], \\f[B]--compression-type\\f[R] \\f[I]NAME\\fR"

#. type: Plain text
#: minios-cmd.1:109
msgid "Specify the compression type (e.g., `zstd')."
msgstr "Especifique o tipo de compactação (ex.: `zstd')."

#. type: SS
#: minios-cmd.1:109
#, no-wrap
msgid "Kernel Options"
msgstr "Opções do Kernel"

#. type: TP
#: minios-cmd.1:110
#, no-wrap
msgid "\\f[B]-kf\\f[R], \\f[B]--kernel-flavour\\f[R] \\f[I]NAME\\fR"
msgstr "\\f[B]-kf\\f[R], \\f[B]--kernel-flavour\\f[R] \\f[I]NAME\\fR"

#. type: Plain text
#: minios-cmd.1:113
msgid "Specify the kernel flavour (e.g., `none')."
msgstr "Especifique o tipo de kernel (ex.: `none')."

#. type: TP
#: minios-cmd.1:113
#, no-wrap
msgid "\\f[B]-aufs\\f[R], \\f[B]--kernel-aufs\\fR"
msgstr "\\f[B]-aufs\\f[R], \\f[B]--kernel-aufs\\fR"

#. type: Plain text
#: minios-cmd.1:116
msgid "Enable AUFS support in the kernel."
msgstr "Habilita o suporte a AUFS no kernel."

#. type: TP
#: minios-cmd.1:116
#, no-wrap
msgid "\\f[B]-dkms\\f[R], \\f[B]--kernel-build-dkms\\fR"
msgstr "\\f[B]-dkms\\f[R], \\f[B]--kernel-build-dkms\\fR"

#. type: Plain text
#: minios-cmd.1:119
msgid "Enable compilation of additional drivers during kernel installation."
msgstr "Habilita a compilação de drivers adicionais durante a instalação do kernel."

#. type: SS
#: minios-cmd.1:119
#, no-wrap
msgid "Locale and Timezone Options"
msgstr "Opções de Localidade e Fuso Horário"

#. type: TP
#: minios-cmd.1:120
#, no-wrap
msgid "\\f[B]-l\\f[R], \\f[B]--locale\\f[R] \\f[I]NAME\\fR"
msgstr "\\f[B]-l\\f[R], \\f[B]--locale\\f[R] \\f[I]NAME\\fR"

#. type: Plain text
#: minios-cmd.1:123
msgid "Specify the system locale (e.g., `en_US')."
msgstr "Especifique a localidade do sistema (ex.: `en_US')."

#. type: TP
#: minios-cmd.1:123
#, no-wrap
msgid "\\f[B]-ml\\f[R], \\f[B]--multilingual\\fR"
msgstr "\\f[B]-ml\\f[R], \\f[B]--multilingual\\fR"

#. type: Plain text
#: minios-cmd.1:126
msgid "Enable multilingual support."
msgstr "Habilita o suporte multilíngue."

#. type: TP
#: minios-cmd.1:126
#, no-wrap
msgid "\\f[B]-kl\\f[R], \\f[B]--keep-locales\\fR"
msgstr "\\f[B]-kl\\f[R], \\f[B]--keep-locales\\fR"

#. type: Plain text
#: minios-cmd.1:129
msgid "Keep all available locales."
msgstr "Mantém todas as localidades disponíveis."

#. type: TP
#: minios-cmd.1:129
#, no-wrap
msgid "\\f[B]-tz\\f[R], \\f[B]--timezone\\f[R] \\f[I]NAME\\fR"
msgstr "\\f[B]-tz\\f[R], \\f[B]--timezone\\f[R] \\f[I]NAME\\fR"

#. type: Plain text
#: minios-cmd.1:132
msgid "Specify the timezone (e.g., `Etc/UTC')."
msgstr "Especifique o fuso horário (ex.: `Etc/UTC')."

#. type: SS
#: minios-cmd.1:132
#, no-wrap
msgid "Boot Menu Options"
msgstr "Opções do Menu de Boot"

#. type: TP
#: minios-cmd.1:133
#, no-wrap
msgid "\\f[B]-mln\\f[R], \\f[B]--menu-language\\f[R] \\f[I]NAME\\fR"
msgstr "\\f[B]-mln\\f[R], \\f[B]--menu-language\\f[R] \\f[I]NAME\\fR"

#. type: Plain text
#: minios-cmd.1:137
msgid "Specify the boot menu language (`multilang' for language selection or specific language code like `ru_RU')."
msgstr "Especifique o idioma do menu de boot (`multilang' para seleção de idioma ou código de idioma específico, como `ru_RU')."

#. type: SH
#: minios-cmd.1:137
#, no-wrap
msgid "DEFAULT SETTINGS"
msgstr "CONFIGURAÇÕES PADRÃO"

#. type: SS
#: minios-cmd.1:138
#, no-wrap
msgid "Kernel Settings"
msgstr "Configurações do Kernel"

#. type: Plain text
#: minios-cmd.1:141
msgid "\\f[B]KERNEL_FLAVOUR\\f[R]: \\[lq]none\\[rq]\\fR"
msgstr "\\f[B]KERNEL_FLAVOUR\\f[R]: \\[lq]none\\[rq]\\fR"

#. type: SS
#: minios-cmd.1:141
#, no-wrap
msgid "Locale & Timezone Settings"
msgstr "Configurações de Localidade & Fuso Horário"

#. type: Plain text
#: minios-cmd.1:145
msgid "\\f[B]LOCALE\\f[R]: \\[lq]en_US\\[rq] \\f[B]LIVE_TIMEZONE\\f[R]: \\[lq]Etc/UTC\\[rq]\\fR"
msgstr "\\f[B]LOCALE\\f[R]: \\[lq]en_US\\[rq] \\f[B]LIVE_TIMEZONE\\f[R]: \\[lq]Etc/UTC\\[rq]\\fR"

#. type: SS
#: minios-cmd.1:145
#, no-wrap
msgid "Boot Menu Settings"
msgstr "Configurações do Menu de Boot"

#. type: Plain text
#: minios-cmd.1:148
msgid "\\f[B]MENU_LANG\\f[R]: \\[lq]multilang\\[rq]\\fR"
msgstr "\\f[B]MENU_LANG\\f[R]: \\[lq]multilang\\[rq]\\fR"

#. type: SH
#: minios-cmd.1:148
#, no-wrap
msgid "INTERACTION WITH MINIOS-LIVE"
msgstr "INTERAÇÃO COM O MINIOS-LIVE"

#. type: Plain text
#: minios-cmd.1:154
msgid "\\f[B]minios-cmd\\f[R] prepares the build environment and generates a \\f[B]build.conf\\f[R] configuration file based on the options provided.  It then calls \\f[B]minios-live\\f[R] with the relevant environment variables, delegating the build execution to \\f[B]minios-live\\f[R].\\fR"
msgstr "\\f[B]minios-cmd\\f[R] prepara o ambiente de compilação e gera um arquivo de configuração \\f[B]build.conf\\f[R] com base nas opções fornecidas. Em seguida, chama o \\f[B]minios-live\\f[R] com as variáveis de ambiente relevantes, delegando a execução da compilação ao \\f[B]minios-live\\f[R].\\fR"

#. type: Plain text
#: minios-cmd.1:157
msgid "Create a MiniOS Standard system image with default settings:"
msgstr "Cria uma imagem de sistema MiniOS Standard com as configurações padrão:"

#. type: Plain text
#: minios-cmd.1:162
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-cmd -d bookworm -a amd64 -de xfce -pv standard -c zstd -aufs -dkms -kl\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-cmd -d bookworm -a amd64 -de xfce -pv standard -c zstd -aufs -dkms -kl\\fR\n"
"\n"

#. type: Plain text
#: minios-cmd.1:165
msgid "Create a MiniOS Toolbox system image with default settings:"
msgstr "Cria uma imagem de sistema MiniOS Toolbox com as configurações padrão:"

#. type: Plain text
#: minios-cmd.1:170
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-cmd -d bookworm -a amd64 -de xfce -pv toolbox -c zstd -aufs -dkms -kl\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-cmd -d bookworm -a amd64 -de xfce -pv toolbox -c zstd -aufs -dkms -kl\\fR\n"
"\n"

#. type: Plain text
#: minios-cmd.1:173
msgid "Create a system image with Russian locale:"
msgstr "Crie uma imagem de sistema com localidade russa:"

#. type: Plain text
#: minios-cmd.1:178
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-cmd -d bookworm -a amd64 -de xfce -pv toolbox -l ru_RU\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-cmd -d bookworm -a amd64 -de xfce -pv toolbox -l ru_RU\\fR\n"
"\n"

#. type: Plain text
#: minios-cmd.1:181
msgid "Create a system image with LXQt desktop environment:"
msgstr "Crie uma imagem de sistema com o ambiente de desktop LXQt:"

#. type: Plain text
#: minios-cmd.1:186
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-cmd -d bookworm -a amd64 -de lxqt -pv standard\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-cmd -d bookworm -a amd64 -de lxqt -pv standard\\fR\n"
"\n"

#. type: Plain text
#: minios-cmd.1:189
msgid "Create a system image for 32-bit architecture:"
msgstr "Crie uma imagem de sistema para arquitetura 32 bits:"

#. type: Plain text
#: minios-cmd.1:194
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-cmd -d buster -a i386 -de xfce -pv standard\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-cmd -d buster -a i386 -de xfce -pv standard\\fR\n"
"\n"

#. type: Plain text
#: minios-cmd.1:197
msgid "Create a system image with Ubuntu Jammy:"
msgstr "Crie uma imagem de sistema com Ubuntu Jammy:"

#. type: Plain text
#: minios-cmd.1:202
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-cmd -d jammy -pv standard -a amd64 -de xfce\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-cmd -d jammy -pv standard -a amd64 -de xfce\\fR\n"
"\n"

#. type: Plain text
#: minios-cmd.1:207
msgid "Enable multilingual support (generates locales for English, Spanish, German, French, Italian, Portuguese, Brazilian Portuguese, Russian, and Indonesian):"
msgstr "Habilite suporte multilíngue (gera localidades para inglês, espanhol, alemão, francês, italiano, português, português do Brasil, russo e indonésio):"

#. type: Plain text
#: minios-cmd.1:212
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-cmd -d trixie -a amd64 -de xfce -pv standard -ml\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-cmd -d trixie -a amd64 -de xfce -pv standard -ml\\fR\n"
"\n"

#. type: Plain text
#: minios-cmd.1:215
msgid "Create a system image with Russian boot menu language:"
msgstr "Crie uma imagem de sistema com idioma do menu de boot em russo:"

#. type: Plain text
#: minios-cmd.1:220
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-cmd -d bookworm -a amd64 -de xfce -pv standard -mln ru_RU\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-cmd -d bookworm -a amd64 -de xfce -pv standard -mln ru_RU\\fR\n"
