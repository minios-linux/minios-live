#. type: TH
#: minios-live.1:17
#, no-wrap
msgid "MINIOS-LIVE"
msgstr "MINIOS-LIVE"

#. type: TH
#: minios-live.1:17 minios-cmd.1:17 condinapt.1:17 condinapt-minios.7:17
#, no-wrap
msgid "October 2025"
msgstr "octubre de 2025"

#. type: TH
#: minios-live.1:17
#, no-wrap
msgid "MiniOS Live System Builder"
msgstr "Constructor del sistema MiniOS Live"

#. type: SH
#: minios-live.1:19 minios-cmd.1:19 condinapt.1:19 condinapt-minios.7:19
#, no-wrap
msgid "NAME"
msgstr "NOMBRE"

#. type: Plain text
#: minios-live.1:23
msgid "minios-live - step-by-step build tool for creating bootable MiniOS ISO images"
msgstr "minios-live - herramienta de construcción paso a paso para crear imágenes ISO arrancables de MiniOS"

#. type: SH
#: minios-live.1:23 minios-cmd.1:23 condinapt.1:23
#, no-wrap
msgid "SYNOPSIS"
msgstr "SINOPSIS"

#. type: Plain text
#: minios-live.1:27
msgid "\\f[B]minios-live\\f[R] [\\f[I]start_cmd\\f[R]] \\f[B]-\\f[R] [\\f[I]end_cmd\\f[R]]\\fR"
msgstr "\\f[B]minios-live\\f[R] [\\f[I]start_cmd\\f[R]] \\f[B]-\\f[R] [\\f[I]end_cmd\\f[R]]\\fR"

#. type: SH
#: minios-live.1:27 minios-cmd.1:26 condinapt.1:26 condinapt-minios.7:22
#, no-wrap
msgid "DESCRIPTION"
msgstr "DESCRIPCIÓN"

#. type: Plain text
#: minios-live.1:35
msgid "\\f[B]minios-live\\f[R] is a step-by-step build tool that builds bootable MiniOS ISO images.  It uses pre-defined configurations to create a customized MiniOS live system with a controlled and modular build process, including the ability to add software layered on top of the base system using SquashFS modules.\\fR"
msgstr "\\f[B]minios-live\\f[R] es una herramienta de construcción paso a paso que genera imágenes ISO arrancables de MiniOS. Utiliza configuraciones predefinidas para crear un sistema MiniOS live personalizado con un proceso de construcción controlado y modular, incluyendo la capacidad de añadir software adicional sobre el sistema base mediante módulos SquashFS.\\fR"

#. type: SS
#: minios-live.1:35 minios-cmd.1:33 minios-cmd.1:82
#, no-wrap
msgid "Build Options"
msgstr "Opciones de construcción"

#. type: Plain text
#: minios-live.1:39
msgid "Using \\f[B]minios-live\\f[R], you can build various configurations including:\\fR"
msgstr "Con \\f[B]minios-live\\f[R], puede construir varias configuraciones, incluyendo:\\fR"

#. type: IP
#: minios-live.1:39 minios-live.1:42 minios-live.1:44 minios-live.1:47
#: minios-live.1:50 minios-live.1:53 minios-live.1:56 minios-live.1:58
#: minios-live.1:60 minios-live.1:63 minios-live.1:118 minios-live.1:120
#: minios-live.1:123 minios-live.1:125 minios-live.1:127 minios-cmd.1:37
#: minios-cmd.1:41 minios-cmd.1:44 minios-cmd.1:47 minios-cmd.1:50
#: minios-cmd.1:53 minios-cmd.1:56 minios-cmd.1:59 minios-cmd.1:61
#: minios-cmd.1:64 minios-cmd.1:67 minios-cmd.1:70 condinapt.1:50
#: condinapt.1:53 condinapt.1:56 condinapt.1:59 condinapt.1:62 condinapt.1:65
#: condinapt.1:166 condinapt.1:170 condinapt.1:188 condinapt.1:191
#: condinapt-minios.7:133 condinapt-minios.7:135
#, no-wrap
msgid "\\f[R]\\[bu]\\fR"
msgstr "\\f[R]\\[bu]\\fR"

#. type: Plain text
#: minios-live.1:42
msgid "\\f[B]Debian distributions:\\f[R] Buster (10), Bullseye (11), Bookworm (12), Trixie (13)\\fR"
msgstr "\\f[B]Distribuciones Debian:\\f[R] Buster (10), Bullseye (11), Bookworm (12), Trixie (13)\\fR"

#. type: Plain text
#: minios-live.1:44
msgid "\\f[B]Ubuntu distributions:\\f[R] Jammy (22.04), Noble (24.04)\\fR"
msgstr "\\f[B]Distribuciones Ubuntu:\\f[R] Jammy (22.04), Noble (24.04)\\fR"

#. type: Plain text
#: minios-live.1:46
msgid "\\f[B]Desktop environments:\\fR"
msgstr "\\f[B]Entornos de escritorio:\\fR"

#. type: Plain text
#: minios-live.1:50
msgid "\\f[B]Debian:\\f[R] Xfce (standard), Flux (minimum), LXQt (Bookworm/Trixie only)\\fR"
msgstr "\\f[B]Debian:\\f[R] Xfce (estándar), Flux (mínimo), LXQt (solo Bookworm/Trixie)\\fR"

#. type: Plain text
#: minios-live.1:52
msgid "\\f[B]Ubuntu:\\f[R] Xfce only\\fR"
msgstr "\\f[B]Ubuntu:\\f[R] solo Xfce\\fR"

#. type: Plain text
#: minios-live.1:55
msgid "\\f[B]Package variants:\\fR"
msgstr "\\f[B]Variantes de paquetes:\\fR"

#. type: Plain text
#: minios-live.1:58
msgid "\\f[B]All Debian:\\f[R] Standard (xfce), Minimum (flux)\\fR"
msgstr "\\f[B]Todos los Debian:\\f[R] Estándar (xfce), Mínimo (flux)\\fR"

#. type: Plain text
#: minios-live.1:60
msgid "\\f[B]Bookworm/Trixie only:\\f[R] Toolbox, Ultra\\fR"
msgstr "\\f[B]Solo Bookworm/Trixie:\\f[R] Toolbox, Ultra\\fR"

#. type: Plain text
#: minios-live.1:62
msgid "\\f[B]Ubuntu:\\f[R] Standard only\\fR"
msgstr "\\f[B]Ubuntu:\\f[R] solo estándar\\fR"

#. type: Plain text
#: minios-live.1:65
msgid "\\f[B]Architectures:\\f[R] amd64, i386 (for older distributions)\\fR"
msgstr "\\f[B]Arquitecturas:\\f[R] amd64, i386 (para distribuciones antiguas)\\fR"

#. type: SS
#: minios-live.1:65
#, no-wrap
msgid "Prerequisites"
msgstr "Requisitos previos"

#. type: IP
#: minios-live.1:66 minios-live.1:69 minios-live.1:116 condinapt.1:34
#: condinapt.1:36 condinapt.1:38 condinapt.1:40 condinapt.1:42 condinapt.1:44
#: condinapt.1:47 condinapt.1:185 condinapt-minios.7:131
#, no-wrap
msgid "\\[bu]"
msgstr "\\[bu]"

#. type: Plain text
#: minios-live.1:69
msgid "It is advisable to use the latest version of Debian or Ubuntu for building."
msgstr "Se recomienda utilizar la versión más reciente de Debian o Ubuntu para la construcción."

#. type: Plain text
#: minios-live.1:73
msgid "\\f[B]WARNING\\f[R]: Never run scripts from the \\f[B]linux-live\\f[R] folder directly.  It will break your system.\\fR"
msgstr "\\f[B]ADVERTENCIA\\f[R]: Nunca ejecute scripts directamente desde la carpeta \\f[B]linux-live\\f[R].  Esto dañará su sistema.\\fR"

#. type: SH
#: minios-live.1:73
#, no-wrap
msgid "COMMANDS"
msgstr "COMANDOS"

#. type: Plain text
#: minios-live.1:76
msgid "\\f[B]minios-live\\f[R] breaks down the build process into discrete steps:\\fR"
msgstr "\\f[B]minios-live\\f[R] divide el proceso de construcción en pasos independientes:\\fR"

#. type: TP
#: minios-live.1:76
#, no-wrap
msgid "\\f[B]build-bootstrap\\fR"
msgstr "\\f[B]build-bootstrap\\fR"

#. type: Plain text
#: minios-live.1:79
msgid "Installs a minimal base system using \\f[B]debootstrap\\fR"
msgstr "Instala un sistema base mínimo utilizando \\f[B]debootstrap\\fR"

#. type: TP
#: minios-live.1:79
#, no-wrap
msgid "\\f[B]build-chroot\\fR"
msgstr "\\f[B]build-chroot\\fR"

#. type: Plain text
#: minios-live.1:83
msgid "Installs the remaining core components and chosen desktop environment within the chroot environment"
msgstr "Instala los componentes principales restantes y el entorno de escritorio seleccionado dentro del entorno chroot"

#. type: TP
#: minios-live.1:83
#, no-wrap
msgid "\\f[B]build-live\\fR"
msgstr "\\f[B]build-live\\fR"

#. type: Plain text
#: minios-live.1:86
msgid "Creates the main SquashFS image containing the core MiniOS system"
msgstr "Crea la imagen principal SquashFS que contiene el sistema MiniOS principal"

#. type: TP
#: minios-live.1:86
#, no-wrap
msgid "\\f[B]build-modules\\fR"
msgstr "\\f[B]build-modules\\fR"

#. type: Plain text
#: minios-live.1:89
msgid "Builds additional SquashFS modules containing extra software packages"
msgstr "Construye módulos SquashFS adicionales que contienen paquetes de software extra"

#. type: TP
#: minios-live.1:89
#, no-wrap
msgid "\\f[B]build-boot\\fR"
msgstr "\\f[B]build-boot\\fR"

#. type: Plain text
#: minios-live.1:93
msgid "Copies the boot files, generates the initrd and the necessary boot configuration files"
msgstr "Copia los archivos de arranque, genera el initrd y los archivos de configuración de arranque necesarios"

#. type: TP
#: minios-live.1:93
#, no-wrap
msgid "\\f[B]build-config\\fR"
msgstr "\\f[B]build-config\\fR"

#. type: Plain text
#: minios-live.1:96
msgid "Generates configuration files for the build"
msgstr "Genera los archivos de configuración para la construcción"

#. type: TP
#: minios-live.1:96
#, no-wrap
msgid "\\f[B]build-iso\\fR"
msgstr "\\f[B]build-iso\\fR"

#. type: Plain text
#: minios-live.1:100
msgid "Creates the final ISO image, incorporating both the core SquashFS image and any additional modules"
msgstr "Crea la imagen ISO final, incorporando tanto la imagen principal SquashFS como cualquier módulo adicional"

#. type: TP
#: minios-live.1:100
#, no-wrap
msgid "\\f[B]remove-sources\\fR"
msgstr "\\f[B]remove-sources\\fR"

#. type: Plain text
#: minios-live.1:103
msgid "Removes source files after the build"
msgstr "Elimina los archivos fuente después de la compilación"

#. type: SH
#: minios-live.1:103
#, no-wrap
msgid "USAGE"
msgstr "USO"

#. type: TP
#: minios-live.1:104
#, no-wrap
msgid "\\f[B]start_cmd\\fR"
msgstr "\\f[B]start_cmd\\fR"

#. type: Plain text
#: minios-live.1:108
msgid "(Optional) The build stage to start from.  If omitted, starts from the first command"
msgstr "(Opcional) La etapa de compilación desde la que iniciar. Si se omite, comienza desde el primer comando"

#. type: TP
#: minios-live.1:108
#, no-wrap
msgid "\\f[B]-\\fR"
msgstr "\\f[B]-\\fR"

#. type: Plain text
#: minios-live.1:111
msgid "(Optional) A range operator for running command sequences"
msgstr "(Opcional) Operador de rango para ejecutar secuencias de comandos"

#. type: TP
#: minios-live.1:111
#, no-wrap
msgid "\\f[B]end_cmd\\fR"
msgstr "\\f[B]end_cmd\\fR"

#. type: Plain text
#: minios-live.1:115
msgid "(Optional) The build stage to end with.  If omitted, ends with the last command"
msgstr "(Opcional) La etapa de compilación en la que finalizar. Si se omite, finaliza con el último comando"

#. type: SS
#: minios-live.1:115
#, no-wrap
msgid "How it works"
msgstr "Cómo funciona"

#. type: Plain text
#: minios-live.1:118
msgid "\\f[B]No arguments (./minios-live)\\f[R]: Displays help information\\fR"
msgstr "\\f[B]Sin argumentos (./minios-live)\\f[R]: Muestra la información de ayuda\\fR"

#. type: Plain text
#: minios-live.1:120
msgid "\\f[B]Single command\\f[R]: Runs only that specific command\\fR"
msgstr "\\f[B]Comando único\\f[R]: Ejecuta solo ese comando específico\\fR"

#. type: Plain text
#: minios-live.1:123
msgid "\\f[B]start_cmd - end_cmd\\f[R]: Runs all commands from start_cmd to end_cmd\\fR"
msgstr "\\f[B]start_cmd - end_cmd\\f[R]: Ejecuta todos los comandos desde start_cmd hasta end_cmd\\fR"

#. type: Plain text
#: minios-live.1:125
msgid "\\f[B]- end_cmd\\f[R]: Runs from the beginning up to end_cmd\\fR"
msgstr "\\f[B]- end_cmd\\f[R]: Ejecuta desde el principio hasta end_cmd\\fR"

#. type: Plain text
#: minios-live.1:127
msgid "\\f[B]start_cmd -\\f[R]: Runs from start_cmd to completion\\fR"
msgstr "\\f[B]start_cmd -\\f[R]: Ejecuta desde start_cmd hasta completar\\fR"

#. type: Plain text
#: minios-live.1:129
msgid "\\f[B]- only\\f[R]: Runs the entire build process from start to finish\\fR"
msgstr "\\f[B]- only\\f[R]: Ejecuta todo el proceso de compilación de principio a fin\\fR"

#. type: SH
#: minios-live.1:129 minios-cmd.1:154 condinapt.1:330 condinapt-minios.7:138
#, no-wrap
msgid "EXAMPLES"
msgstr "EJEMPLOS"

#. type: Plain text
#: minios-live.1:132
msgid "Run the build from start to finish:"
msgstr "Ejecutar la compilación de principio a fin:"

#. type: Plain text
#: minios-live.1:137
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-live -\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-live -\\fR\n"
"\n"

#. type: Plain text
#: minios-live.1:141
msgid "Start the build by building the base environment and finish by installing the entire system in chroot:"
msgstr "Iniciar la compilación construyendo el entorno base y finalizar instalando todo el sistema en chroot:"

#. type: Plain text
#: minios-live.1:146
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-live build-bootstrap - build-chroot\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-live build-bootstrap - build-chroot\\fR\n"
"\n"

#. type: Plain text
#: minios-live.1:150
msgid "Start the build from the beginning and finish by installing the entire system in chroot:"
msgstr "Iniciar la compilación desde el principio y finalizar instalando todo el sistema en chroot:"

#. type: Plain text
#: minios-live.1:155
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-live - build-chroot\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-live - build-chroot\\fR\n"
"\n"

#. type: Plain text
#: minios-live.1:158
msgid "Start the build by building the base environment and run to completion:"
msgstr "Iniciar la compilación construyendo el entorno base y ejecutar hasta completar:"

#. type: Plain text
#: minios-live.1:163
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-live build-bootstrap -\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-live build-bootstrap -\\fR\n"
"\n"

#. type: Plain text
#: minios-live.1:166
msgid "Build only ISO image from previously prepared data:"
msgstr "Construir solo la imagen ISO a partir de datos preparados previamente:"

#. type: Plain text
#: minios-live.1:171
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-live build-iso\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-live build-iso\\fR\n"
"\n"

#. type: SH
#: minios-live.1:172
#, no-wrap
msgid "CONFIGURATION"
msgstr "CONFIGURACIÓN"

#. type: Plain text
#: minios-live.1:179
msgid "Edit the configuration file \\f[B]/etc/minios-live/build.conf\\f[R] to specify your preferred distribution, desktop environment, and additional software to be included in the SquashFS modules.  Alternatively, use \\f[B]minios-cmd\\f[R](1) for an easier configuration experience.\\fR"
msgstr "Edite el archivo de configuración \\f[B]/etc/minios-live/build.conf\\fR para especificar la distribución preferida, el entorno de escritorio y el software adicional que se incluirá en los módulos SquashFS. Alternativamente, utilice \\f[B]minios-cmd\\fR(1) para una experiencia de configuración más sencilla.\\fR"

#. type: Plain text
#: minios-live.1:185
msgid "This modular approach allows for greater flexibility and maintainability when customizing your MiniOS live system.  You can easily add or update software by modifying the SquashFS module configurations and rebuilding only the affected modules using the appropriate \\f[B]minios-live\\f[R] command.\\fR"
msgstr "Este enfoque modular permite una mayor flexibilidad y facilidad de mantenimiento al personalizar su sistema live MiniOS. Puede agregar o actualizar fácilmente software modificando la configuración de los módulos SquashFS y reconstruyendo solo los módulos afectados usando el comando adecuado de \\f[B]minios-live\\fR.\\fR"

#. type: SH
#: minios-live.1:185 minios-cmd.1:247 condinapt.1:492 condinapt-minios.7:310
#, no-wrap
msgid "SEE ALSO"
msgstr "VÉASE TAMBIÉN"

