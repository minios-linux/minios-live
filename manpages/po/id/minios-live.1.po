#. type: TH
#: minios-live.1:17
#, no-wrap
msgid "MINIOS-LIVE"
msgstr "MINIOS-LIVE"

#. type: TH
#: minios-live.1:17 minios-cmd.1:17 condinapt.1:17 condinapt-minios.7:17
#, no-wrap
msgid "October 2025"
msgstr "Oktober 2025"

#. type: TH
#: minios-live.1:17
#, no-wrap
msgid "MiniOS Live System Builder"
msgstr "Pembuat Sistem MiniOS Live"

#. type: SH
#: minios-live.1:19 minios-cmd.1:19 condinapt.1:19 condinapt-minios.7:19
#, no-wrap
msgid "NAME"
msgstr "NAMA"

#. type: Plain text
#: minios-live.1:23
msgid "minios-live - step-by-step build tool for creating bootable MiniOS ISO images"
msgstr "minios-live - alat pembuatan bertahap untuk membuat citra ISO MiniOS yang dapat di-boot"

#. type: SH
#: minios-live.1:23 minios-cmd.1:23 condinapt.1:23
#, no-wrap
msgid "SYNOPSIS"
msgstr "SINOPSIS"

#. type: Plain text
#: minios-live.1:27
msgid "\\f[B]minios-live\\f[R] [\\f[I]start_cmd\\f[R]] \\f[B]-\\f[R] [\\f[I]end_cmd\\f[R]]\\fR"
msgstr "\\f[B]minios-live\\f[R] [\\f[I]start_cmd\\f[R]] \\f[B]-\\f[R] [\\f[I]end_cmd\\f[R]]\\fR"

#. type: SH
#: minios-live.1:27 minios-cmd.1:26 condinapt.1:26 condinapt-minios.7:22
#, no-wrap
msgid "DESCRIPTION"
msgstr "DESKRIPSI"

#. type: Plain text
#: minios-live.1:35
msgid "\\f[B]minios-live\\f[R] is a step-by-step build tool that builds bootable MiniOS ISO images.  It uses pre-defined configurations to create a customized MiniOS live system with a controlled and modular build process, including the ability to add software layered on top of the base system using SquashFS modules.\\fR"
msgstr "\\f[B]minios-live\\f[R] adalah alat pembuatan bertahap yang membangun citra ISO MiniOS yang dapat di-boot. Utilitas ini menggunakan konfigurasi yang telah ditentukan sebelumnya untuk membuat sistem live MiniOS yang dikustomisasi dengan proses build yang terkontrol dan modular, termasuk kemampuan menambahkan perangkat lunak yang dilapiskan di atas sistem dasar menggunakan modul SquashFS.\\fR"

#. type: SS
#: minios-live.1:35 minios-cmd.1:33 minios-cmd.1:82
#, no-wrap
msgid "Build Options"
msgstr "Opsi Pembuatan"

#. type: Plain text
#: minios-live.1:39
msgid "Using \\f[B]minios-live\\f[R], you can build various configurations including:\\fR"
msgstr "Dengan menggunakan \\f[B]minios-live\\f[R], Anda dapat membangun berbagai konfigurasi termasuk:\\fR"

#. type: IP
#: minios-live.1:39 minios-live.1:42 minios-live.1:44 minios-live.1:47
#: minios-live.1:50 minios-live.1:53 minios-live.1:56 minios-live.1:58
#: minios-live.1:60 minios-live.1:63 minios-live.1:118 minios-live.1:120
#: minios-live.1:123 minios-live.1:125 minios-live.1:127 minios-cmd.1:37
#: minios-cmd.1:41 minios-cmd.1:44 minios-cmd.1:47 minios-cmd.1:50
#: minios-cmd.1:53 minios-cmd.1:56 minios-cmd.1:59 minios-cmd.1:61
#: minios-cmd.1:64 minios-cmd.1:67 minios-cmd.1:70 condinapt.1:50
#: condinapt.1:53 condinapt.1:56 condinapt.1:59 condinapt.1:62 condinapt.1:65
#: condinapt.1:166 condinapt.1:170 condinapt.1:188 condinapt.1:191
#: condinapt-minios.7:133 condinapt-minios.7:135
#, no-wrap
msgid "\\f[R]\\[bu]\\fR"
msgstr "\\f[R]\\[bu]\\fR"

#. type: Plain text
#: minios-live.1:42
msgid "\\f[B]Debian distributions:\\f[R] Buster (10), Bullseye (11), Bookworm (12), Trixie (13)\\fR"
msgstr "\\f[B]Distribusi Debian:\\f[R] Buster (10), Bullseye (11), Bookworm (12), Trixie (13)\\fR"

#. type: Plain text
#: minios-live.1:44
msgid "\\f[B]Ubuntu distributions:\\f[R] Jammy (22.04), Noble (24.04)\\fR"
msgstr "\\f[B]Distribusi Ubuntu:\\f[R] Jammy (22.04), Noble (24.04)\\fR"

#. type: Plain text
#: minios-live.1:46
msgid "\\f[B]Desktop environments:\\fR"
msgstr "\\f[B]Lingkungan desktop:\\fR"

#. type: Plain text
#: minios-live.1:50
msgid "\\f[B]Debian:\\f[R] Xfce (standard), Flux (minimum), LXQt (Bookworm/Trixie only)\\fR"
msgstr "\\f[B]Debian:\\f[R] Xfce (standar), Flux (minimum), LXQt (hanya Bookworm/Trixie)\\fR"

#. type: Plain text
#: minios-live.1:52
msgid "\\f[B]Ubuntu:\\f[R] Xfce only\\fR"
msgstr "\\f[B]Ubuntu:\\f[R] hanya Xfce\\fR"

#. type: Plain text
#: minios-live.1:55
msgid "\\f[B]Package variants:\\fR"
msgstr "\\f[B]Varian paket:\\fR"

#. type: Plain text
#: minios-live.1:58
msgid "\\f[B]All Debian:\\f[R] Standard (xfce), Minimum (flux)\\fR"
msgstr "\\f[B]Semua Debian:\\f[R] Standar (xfce), Minimum (flux)\\fR"

#. type: Plain text
#: minios-live.1:60
msgid "\\f[B]Bookworm/Trixie only:\\f[R] Toolbox, Ultra\\fR"
msgstr "\\f[B]Hanya Bookworm/Trixie:\\f[R] Toolbox, Ultra\\fR"

#. type: Plain text
#: minios-live.1:62
msgid "\\f[B]Ubuntu:\\f[R] Standard only\\fR"
msgstr "\\f[B]Ubuntu:\\f[R] hanya Standar\\fR"

#. type: Plain text
#: minios-live.1:65
msgid "\\f[B]Architectures:\\f[R] amd64, i386 (for older distributions)\\fR"
msgstr "\\f[B]Arsitektur:\\f[R] amd64, i386 (untuk distribusi lama)\\fR"

#. type: SS
#: minios-live.1:65
#, no-wrap
msgid "Prerequisites"
msgstr "Prasyarat"

#. type: IP
#: minios-live.1:66 minios-live.1:69 minios-live.1:116 condinapt.1:34
#: condinapt.1:36 condinapt.1:38 condinapt.1:40 condinapt.1:42 condinapt.1:44
#: condinapt.1:47 condinapt.1:185 condinapt-minios.7:131
#, no-wrap
msgid "\\[bu]"
msgstr "\\[bu]"

#. type: Plain text
#: minios-live.1:69
msgid "It is advisable to use the latest version of Debian or Ubuntu for building."
msgstr "Disarankan menggunakan versi terbaru Debian atau Ubuntu untuk proses pembuatan."

#. type: Plain text
#: minios-live.1:73
msgid "\\f[B]WARNING\\f[R]: Never run scripts from the \\f[B]linux-live\\f[R] folder directly.  It will break your system.\\fR"
msgstr "\\f[B]PERINGATAN\\f[R]: Jangan pernah menjalankan skrip dari folder \\f[B]linux-live\\f[R] secara langsung. Hal ini dapat merusak sistem Anda.\\fR"

#. type: SH
#: minios-live.1:73
#, no-wrap
msgid "COMMANDS"
msgstr "PERINTAH"

#. type: Plain text
#: minios-live.1:76
msgid "\\f[B]minios-live\\f[R] breaks down the build process into discrete steps:\\fR"
msgstr "\\f[B]minios-live\\f[R] membagi proses pembuatan menjadi beberapa langkah terpisah:\\fR"

#. type: TP
#: minios-live.1:76
#, no-wrap
msgid "\\f[B]build-bootstrap\\fR"
msgstr "\\f[B]build-bootstrap\\fR"

#. type: Plain text
#: minios-live.1:79
msgid "Installs a minimal base system using \\f[B]debootstrap\\fR"
msgstr "Menginstal sistem dasar minimal menggunakan \\f[B]debootstrap\\fR"

#. type: TP
#: minios-live.1:79
#, no-wrap
msgid "\\f[B]build-chroot\\fR"
msgstr "\\f[B]build-chroot\\fR"

#. type: Plain text
#: minios-live.1:83
msgid "Installs the remaining core components and chosen desktop environment within the chroot environment"
msgstr "Menginstal komponen inti yang tersisa dan lingkungan desktop pilihan di dalam lingkungan chroot"

#. type: TP
#: minios-live.1:83
#, no-wrap
msgid "\\f[B]build-live\\fR"
msgstr "\\f[B]build-live\\fR"

#. type: Plain text
#: minios-live.1:86
msgid "Creates the main SquashFS image containing the core MiniOS system"
msgstr "Membuat citra SquashFS utama yang berisi sistem inti MiniOS"

#. type: TP
#: minios-live.1:86
#, no-wrap
msgid "\\f[B]build-modules\\fR"
msgstr "\\f[B]build-modules\\fR"

#. type: Plain text
#: minios-live.1:89
msgid "Builds additional SquashFS modules containing extra software packages"
msgstr "Membangun modul SquashFS tambahan yang berisi paket perangkat lunak ekstra"

#. type: TP
#: minios-live.1:89
#, no-wrap
msgid "\\f[B]build-boot\\fR"
msgstr "\\f[B]build-boot\\fR"

#. type: Plain text
#: minios-live.1:93
msgid "Copies the boot files, generates the initrd and the necessary boot configuration files"
msgstr "Menyalin berkas boot, menghasilkan initrd dan berkas konfigurasi boot yang diperlukan"

#. type: TP
#: minios-live.1:93
#, no-wrap
msgid "\\f[B]build-config\\fR"
msgstr "\\f[B]build-config\\fR"

#. type: Plain text
#: minios-live.1:96
msgid "Generates configuration files for the build"
msgstr "Menghasilkan berkas konfigurasi untuk proses build"

#. type: TP
#: minios-live.1:96
#, no-wrap
msgid "\\f[B]build-iso\\fR"
msgstr "\\f[B]build-iso\\fR"

#. type: Plain text
#: minios-live.1:100
msgid "Creates the final ISO image, incorporating both the core SquashFS image and any additional modules"
msgstr "Membuat citra ISO final, yang menggabungkan citra SquashFS inti beserta modul tambahan apa pun"

#. type: TP
#: minios-live.1:100
#, no-wrap
msgid "\\f[B]remove-sources\\fR"
msgstr "\\f[B]remove-sources\\fR"

#. type: Plain text
#: minios-live.1:103
msgid "Removes source files after the build"
msgstr "Menghapus berkas sumber setelah proses pembuatan selesai"

#. type: SH
#: minios-live.1:103
#, no-wrap
msgid "USAGE"
msgstr "PENGGUNAAN"

#. type: TP
#: minios-live.1:104
#, no-wrap
msgid "\\f[B]start_cmd\\fR"
msgstr "\\f[B]start_cmd\\fR"

#. type: Plain text
#: minios-live.1:108
msgid "(Optional) The build stage to start from.  If omitted, starts from the first command"
msgstr "(Opsional) Tahap pembuatan yang akan dijalankan mulai dari sini. Jika tidak disebutkan, proses akan dimulai dari perintah pertama"

#. type: TP
#: minios-live.1:108
#, no-wrap
msgid "\\f[B]-\\fR"
msgstr "\\f[B]-\\fR"

#. type: Plain text
#: minios-live.1:111
msgid "(Optional) A range operator for running command sequences"
msgstr "(Opsional) Operator rentang untuk menjalankan rangkaian perintah"

#. type: TP
#: minios-live.1:111
#, no-wrap
msgid "\\f[B]end_cmd\\fR"
msgstr "\\f[B]end_cmd\\fR"

#. type: Plain text
#: minios-live.1:115
msgid "(Optional) The build stage to end with.  If omitted, ends with the last command"
msgstr "(Opsional) Tahap pembuatan yang akan diakhiri di sini. Jika tidak disebutkan, proses akan berakhir pada perintah terakhir"

#. type: SS
#: minios-live.1:115
#, no-wrap
msgid "How it works"
msgstr "Cara kerja"

#. type: Plain text
#: minios-live.1:118
msgid "\\f[B]No arguments (./minios-live)\\f[R]: Displays help information\\fR"
msgstr "\\f[B]Tanpa argumen (./minios-live)\\f[R]: Menampilkan informasi bantuan\\fR"

#. type: Plain text
#: minios-live.1:120
msgid "\\f[B]Single command\\f[R]: Runs only that specific command\\fR"
msgstr "\\f[B]Satu perintah\\f[R]: Menjalankan hanya perintah tersebut saja\\fR"

#. type: Plain text
#: minios-live.1:123
msgid "\\f[B]start_cmd - end_cmd\\f[R]: Runs all commands from start_cmd to end_cmd\\fR"
msgstr "\\f[B]start_cmd - end_cmd\\f[R]: Menjalankan semua perintah dari start_cmd hingga end_cmd\\fR"

#. type: Plain text
#: minios-live.1:125
msgid "\\f[B]- end_cmd\\f[R]: Runs from the beginning up to end_cmd\\fR"
msgstr "\\f[B]- end_cmd\\f[R]: Menjalankan dari awal hingga end_cmd\\fR"

#. type: Plain text
#: minios-live.1:127
msgid "\\f[B]start_cmd -\\f[R]: Runs from start_cmd to completion\\fR"
msgstr "\\f[B]start_cmd -\\f[R]: Menjalankan dari start_cmd hingga selesai\\fR"

#. type: Plain text
#: minios-live.1:129
msgid "\\f[B]- only\\f[R]: Runs the entire build process from start to finish\\fR"
msgstr "\\f[B]- only\\f[R]: Menjalankan seluruh proses pembuatan dari awal hingga akhir\\fR"

#. type: SH
#: minios-live.1:129 minios-cmd.1:154 condinapt.1:330 condinapt-minios.7:138
#, no-wrap
msgid "EXAMPLES"
msgstr "CONTOH"

#. type: Plain text
#: minios-live.1:132
msgid "Run the build from start to finish:"
msgstr "Jalankan proses pembuatan dari awal hingga akhir:"

#. type: Plain text
#: minios-live.1:137
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-live -\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-live -\\fR\n"
"\n"

#. type: Plain text
#: minios-live.1:141
msgid "Start the build by building the base environment and finish by installing the entire system in chroot:"
msgstr "Mulai proses pembuatan dengan membangun lingkungan dasar dan akhiri dengan menginstal seluruh sistem di chroot:"

#. type: Plain text
#: minios-live.1:146
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-live build-bootstrap - build-chroot\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-live build-bootstrap - build-chroot\\fR\n"
"\n"

#. type: Plain text
#: minios-live.1:150
msgid "Start the build from the beginning and finish by installing the entire system in chroot:"
msgstr "Mulai proses pembuatan dari awal dan akhiri dengan menginstal seluruh sistem di chroot:"

#. type: Plain text
#: minios-live.1:155
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-live - build-chroot\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-live - build-chroot\\fR\n"
"\n"

#. type: Plain text
#: minios-live.1:158
msgid "Start the build by building the base environment and run to completion:"
msgstr "Mulai proses pembuatan dengan membangun lingkungan dasar dan jalankan hingga selesai:"

#. type: Plain text
#: minios-live.1:163
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-live build-bootstrap -\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-live build-bootstrap -\\fR\n"
"\n"

#. type: Plain text
#: minios-live.1:166
msgid "Build only ISO image from previously prepared data:"
msgstr "Bangun hanya citra ISO dari data yang telah dipersiapkan sebelumnya:"

#. type: Plain text
#: minios-live.1:171
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-live build-iso\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-live build-iso\\fR\n"
"\n"

#. type: SH
#: minios-live.1:172
#, no-wrap
msgid "CONFIGURATION"
msgstr "KONFIGURASI"

#. type: Plain text
#: minios-live.1:179
msgid "Edit the configuration file \\f[B]/etc/minios-live/build.conf\\f[R] to specify your preferred distribution, desktop environment, and additional software to be included in the SquashFS modules.  Alternatively, use \\f[B]minios-cmd\\f[R](1) for an easier configuration experience.\\fR"
msgstr "Edit berkas konfigurasi \\f[B]/etc/minios-live/build.conf\\fR untuk menentukan distribusi yang diinginkan, lingkungan desktop, dan perangkat lunak tambahan yang akan disertakan dalam modul SquashFS.  Sebagai alternatif, gunakan \\f[B]minios-cmd\\fR(1) untuk pengalaman konfigurasi yang lebih mudah.\\fR"

#. type: Plain text
#: minios-live.1:185
msgid "This modular approach allows for greater flexibility and maintainability when customizing your MiniOS live system.  You can easily add or update software by modifying the SquashFS module configurations and rebuilding only the affected modules using the appropriate \\f[B]minios-live\\f[R] command.\\fR"
msgstr "Pendekatan modular ini memungkinkan fleksibilitas dan kemudahan pemeliharaan yang lebih baik saat menyesuaikan sistem live MiniOS Anda.  Anda dapat dengan mudah menambah atau memperbarui perangkat lunak dengan mengubah konfigurasi modul SquashFS dan membangun ulang hanya modul yang terdampak menggunakan perintah \\f[B]minios-live\\fR yang sesuai.\\fR"

#. type: SH
#: minios-live.1:185 minios-cmd.1:247 condinapt.1:492 condinapt-minios.7:310
#, no-wrap
msgid "SEE ALSO"
msgstr "LIHAT JUGA"

