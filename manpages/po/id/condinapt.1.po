#. type: TH
#: condinapt.1:17
#, no-wrap
msgid "CONDINAPT"
msgstr "CONDINAPT"

#. type: TH
#: condinapt.1:17
#, no-wrap
msgid "CondinAPT Package Manager"
msgstr "Manajer Paket CondinAPT"

#. type: Plain text
#: condinapt.1:23
msgid "condinapt - conditional package installation tool for Debian-like systems"
msgstr "condinapt - alat instalasi paket bersyarat untuk sistem mirip Debian"

#. type: Plain text
#: condinapt.1:26
msgid "\\f[B]condinapt\\f[R] [\\f[I]OPTIONS\\f[R]]\\fR"
msgstr "\\f[B]condinapt\\f[R] [\\f[I]OPTIONS\\f[R]]\\fR"

#. type: Plain text
#: condinapt.1:33
msgid "\\f[B]CondinAPT\\f[R] is a versatile tool for automating package installation in any Debian-like system (Debian, Ubuntu, and their derivatives).  Its key feature is the ability to define complex conditions and rules for installing each package based on arbitrary system configurations.\\fR"
msgstr "\\f[B]CondinAPT\\f[R] adalah alat serbaguna untuk mengotomatisasi instalasi paket pada sistem mirip Debian (Debian, Ubuntu, dan turunannya). Fitur utamanya adalah kemampuan untuk mendefinisikan kondisi dan aturan kompleks dalam menginstal setiap paket berdasarkan konfigurasi sistem yang beragam.\\fR"

#. type: SS
#: condinapt.1:33
#, no-wrap
msgid "Areas of Application"
msgstr "Area Penerapan"

#. type: Plain text
#: condinapt.1:36
msgid "Linux distribution build systems"
msgstr "Sistem pembuatan distribusi Linux"

#. type: Plain text
#: condinapt.1:38
msgid "Automation of server and workstation setup"
msgstr "Otomatisasi penyiapan server dan workstation"

#. type: Plain text
#: condinapt.1:40
msgid "Deployment of various system configurations"
msgstr "Penerapan berbagai konfigurasi sistem"

#. type: Plain text
#: condinapt.1:42
msgid "Package management in Docker containers"
msgstr "Manajemen paket dalam kontainer Docker"

#. type: Plain text
#: condinapt.1:44
msgid "CI/CD pipelines for environment setup"
msgstr "Pipeline CI/CD untuk penyiapan lingkungan"

#. type: Plain text
#: condinapt.1:46
msgid "Creation of custom installation images"
msgstr "Pembuatan citra instalasi kustom"

#. type: SS
#: condinapt.1:46
#, no-wrap
msgid "Key Features"
msgstr "Fitur Utama"

#. type: Plain text
#: condinapt.1:50
msgid "\\f[B]Conditional Installation:\\f[R] Install packages based on flexible filters (+, -)\\fR"
msgstr "\\f[B]Instalasi Bersyarat:\\f[R] Instal paket berdasarkan filter yang fleksibel (+, -)\\fR"

#. type: Plain text
#: condinapt.1:53
msgid "\\f[B]External Configuration:\\f[R] Complete separation of logic (package list) from data (system parameters)\\fR"
msgstr "\\f[B]Konfigurasi Eksternal:\\f[R] Pemisahan penuh antara logika (daftar paket) dan data (parameter sistem)\\fR"

#. type: Plain text
#: condinapt.1:56
msgid "\\f[B]Installation Queues:\\f[R] Divide the process into sequential stages to resolve dependencies\\fR"
msgstr "\\f[B]Antrean Instalasi:\\f[R] Membagi proses menjadi beberapa tahap berurutan untuk menyelesaikan dependensi\\fR"

#. type: Plain text
#: condinapt.1:59
msgid "\\f[B]Priority Queue:\\f[R] Guaranteed installation of critical packages first\\fR"
msgstr "\\f[B]Antrean Prioritas:\\f[R] Menjamin instalasi paket kritis terlebih dahulu\\fR"

#. type: Plain text
#: condinapt.1:62
msgid "\\f[B]Complex Logic:\\f[R] Support for \\[lq]AND\\[rq] (&&), \\[lq]OR\\[rq] (||) operators, as well as group filters (+{a|b}, -{a&b})\\fR"
msgstr "\\f[B]Logika Kompleks:\\f[R] Mendukung operator \\[lq]AND\\[rq] (&&), \\[lq]OR\\[rq] (||), serta filter grup (+{a|b}, -{a&b})\\fR"

#. type: Plain text
#: condinapt.1:65
msgid "\\f[B]Readability:\\f[R] Support for comments and empty lines to structure lists\\fR"
msgstr "\\f[B]Keterbacaan:\\f[R] Mendukung komentar dan baris kosong untuk menstrukturkan daftar\\fR"

#. type: Plain text
#: condinapt.1:68
msgid "\\f[B]Backward Compatibility:\\f[R] Supports simple package lists without conditions\\fR"
msgstr "\\f[B]Kompatibilitas Mundur:\\f[R] Mendukung daftar paket sederhana tanpa kondisi\\fR"

#. type: TP
#: condinapt.1:69
#, no-wrap
msgid "\\f[B]-l\\f[R], \\f[B]--package-list\\f[R] \\f[I]PATH\\fR"
msgstr "\\f[B]-l\\f[R], \\f[B]--package-list\\f[R] \\f[I]PATH\\fR"

#. type: Plain text
#: condinapt.1:72
msgid "(Required) Path to the package list file"
msgstr "(Wajib) Lokasi file daftar paket"

#. type: TP
#: condinapt.1:72
#, no-wrap
msgid "\\f[B]-c\\f[R], \\f[B]--config\\f[R] \\f[I]PATH\\fR"
msgstr "\\f[B]-c\\f[R], \\f[B]--config\\f[R] \\f[I]PATH\\fR"

#. type: Plain text
#: condinapt.1:75
msgid "(Required) Path to the main configuration file"
msgstr "(Wajib) Lokasi file konfigurasi utama"

#. type: TP
#: condinapt.1:75
#, no-wrap
msgid "\\f[B]-m\\f[R], \\f[B]--filter-mapping\\f[R] \\f[I]PATH\\fR"
msgstr "\\f[B]-m\\f[R], \\f[B]--filter-mapping\\f[R] \\f[I]PATH\\fR"

#. type: Plain text
#: condinapt.1:78
msgid "(Optional) Path to the filter mapping file"
msgstr "(Opsional) Lokasi file pemetaan filter"

#. type: TP
#: condinapt.1:78
#, no-wrap
msgid "\\f[B]-P\\f[R], \\f[B]--priority-list\\f[R] \\f[I]PATH\\fR"
msgstr "\\f[B]-P\\f[R], \\f[B]--priority-list\\f[R] \\f[I]PATH\\fR"

#. type: Plain text
#: condinapt.1:81
msgid "(Optional) Path to the priority package list file"
msgstr "(Opsional) Lokasi file daftar paket prioritas"

#. type: TP
#: condinapt.1:81
#, no-wrap
msgid "\\f[B]-s\\f[R], \\f[B]--simulation\\fR"
msgstr "\\f[B]-s\\f[R], \\f[B]--simulation\\fR"

#. type: Plain text
#: condinapt.1:85
msgid "Simulation mode.  Packages will not be installed"
msgstr "Mode simulasi. Paket tidak akan diinstal"

#. type: TP
#: condinapt.1:85
#, no-wrap
msgid "\\f[B]-C\\f[R], \\f[B]--check-only\\fR"
msgstr "\\f[B]-C\\f[R], \\f[B]--check-only\\fR"

#. type: Plain text
#: condinapt.1:88
msgid "Only check if packages are already installed"
msgstr "Hanya memeriksa apakah paket sudah terinstal"

#. type: TP
#: condinapt.1:88
#, no-wrap
msgid "\\f[B]-v\\f[R], \\f[B]--verbose\\fR"
msgstr "\\f[B]-v\\f[R], \\f[B]--verbose\\fR"

#. type: Plain text
#: condinapt.1:91
msgid "Verbose output"
msgstr "Keluaran rinci"

#. type: TP
#: condinapt.1:91
#, no-wrap
msgid "\\f[B]-vv\\f[R], \\f[B]--very-verbose\\fR"
msgstr "\\f[B]-vv\\f[R], \\f[B]--very-verbose\\fR"

#. type: Plain text
#: condinapt.1:94
msgid "Very verbose output"
msgstr "Keluaran sangat rinci"

#. type: TP
#: condinapt.1:94
#, no-wrap
msgid "\\f[B]-x\\f[R], \\f[B]--xtrace\\fR"
msgstr "\\f[B]-x\\f[R], \\f[B]--xtrace\\fR"

#. type: Plain text
#: condinapt.1:97
msgid "Enable \\f[B]set -x\\f[R] command tracing\\fR"
msgstr "Aktifkan penelusuran perintah \\f[B]set -x\\f[R]\\fR"

#. type: TP
#: condinapt.1:97
#, no-wrap
msgid "\\f[B]-f\\f[R], \\f[B]--force\\fR"
msgstr "\\f[B]-f\\f[R], \\f[B]--force\\fR"

#. type: Plain text
#: condinapt.1:100
msgid "Force apt cache update (apt update)"
msgstr "Paksa pembaruan cache apt (apt update)"

#. type: TP
#: condinapt.1:100
#, no-wrap
msgid "\\f[B]-h\\f[R], \\f[B]--help\\fR"
msgstr "\\f[B]-h\\f[R], \\f[B]--help\\fR"

#. type: Plain text
#: condinapt.1:103
msgid "Show help"
msgstr "Tampilkan bantuan"

#. type: SH
#: condinapt.1:103
#, no-wrap
msgid "CORE COMPONENTS"
msgstr "KOMPONEN INTI"

#. type: Plain text
#: condinapt.1:106
msgid "CondinAPT operates with four key files:"
msgstr "CondinAPT beroperasi dengan empat berkas kunci:"

#. type: SS
#: condinapt.1:106
#, no-wrap
msgid "condinapt script"
msgstr "skrip condinapt"

#. type: Plain text
#: condinapt.1:109
msgid "The core, containing all processing logic"
msgstr "Inti, berisi seluruh logika pemrosesan"

#. type: SS
#: condinapt.1:109
#, no-wrap
msgid "Main configuration file (-c)"
msgstr "Berkas konfigurasi utama (-c)"

#. type: Plain text
#: condinapt.1:112
msgid "A file with bash variables describing the current environment"
msgstr "Berkas berisi variabel bash yang mendeskripsikan lingkungan saat ini"

#. type: Plain text
#: condinapt.1:114
msgid "Example (\\f[B]system.conf\\f[R]):\\fR"
msgstr "Contoh (\\f[B]system.conf\\f[R]):\\fR"

#. type: Plain text
#: condinapt.1:123
#, no-wrap
msgid ""
"\\f[C]\n"
"DISTRIBUTION=\\[dq]bookworm\\[dq]\n"
"SYSTEM_TYPE=\\[dq]server\\[dq]\n"
"ENVIRONMENT=\\[dq]production\\[dq]\n"
"LOCALE=\\[dq]en_US\\[dq]\n"
"FEATURES=\\[dq]web,database\\[dq]\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"DISTRIBUTION=\\[dq]bookworm\\[dq]\n"
"SYSTEM_TYPE=\\[dq]server\\[dq]\n"
"ENVIRONMENT=\\[dq]production\\[dq]\n"
"LOCALE=\\[dq]en_US\\[dq]\n"
"FEATURES=\\[dq]web,database\\[dq]\\fR\n"
"\n"

#. type: SS
#: condinapt.1:124
#, no-wrap
msgid "Filter mapping file (-m)"
msgstr "Berkas pemetaan filter (-m)"

#. type: Plain text
#: condinapt.1:132
msgid "Links short prefixes (used in the package list) to variable names from the main configuration file.  This file is \\f[B]optional\\f[R].  If a filter is not present in the filter mapping file, it will be used as a variable name from the main configuration file.  If the variable is not found, CondinAPT will declare it empty.\\fR"
msgstr "Menghubungkan prefiks singkat (yang digunakan dalam daftar paket) ke nama variabel dari berkas konfigurasi utama. Berkas ini \\f[B]opsional\\f[R]. Jika sebuah filter tidak ada di berkas pemetaan filter, filter tersebut akan digunakan sebagai nama variabel dari berkas konfigurasi utama. Jika variabel tidak ditemukan, CondinAPT akan mendeklarasikannya kosong.\\fR"

#. type: Plain text
#: condinapt.1:134
msgid "Example (\\f[B]filters.map\\f[R]):\\fR"
msgstr "Contoh (\\f[B]filters.map\\f[R]):\\fR"

#. type: Plain text
#: condinapt.1:143
#, no-wrap
msgid ""
"\\f[C]\n"
"d=DISTRIBUTION\n"
"st=SYSTEM_TYPE\n"
"env=ENVIRONMENT\n"
"arch=ARCHITECTURE\n"
"feat=FEATURES\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"d=DISTRIBUTION\n"
"st=SYSTEM_TYPE\n"
"env=ENVIRONMENT\n"
"arch=ARCHITECTURE\n"
"feat=FEATURES\\fR\n"
"\n"

#. type: SS
#: condinapt.1:144
#, no-wrap
msgid "Package list file (-l)"
msgstr "Berkas daftar paket (-l)"

#. type: Plain text
#: condinapt.1:147
msgid "The main file describing what to install and under what conditions"
msgstr "Berkas utama yang mendeskripsikan apa yang akan diinstal dan dalam kondisi apa"

#. type: SH
#: condinapt.1:147
#, no-wrap
msgid "PACKAGE LIST SYNTAX"
msgstr "SINTAKS DAFTAR PAKET"

#. type: Plain text
#: condinapt.1:150
msgid "Each line in the package list file consists of two main parts:"
msgstr "Setiap baris dalam berkas daftar paket terdiri dari dua bagian utama:"

#. type: IP
#: condinapt.1:150
#, no-wrap
msgid "1."
msgstr "1."

#. type: Plain text
#: condinapt.1:152
msgid "Package name with optional version and release specification"
msgstr "Nama paket dengan spesifikasi versi dan rilis opsional"

#. type: IP
#: condinapt.1:152 condinapt.1:466
#, no-wrap
msgid "2."
msgstr "2."

#. type: Plain text
#: condinapt.1:155
msgid "Condition filters - define the conditions under which the package will be installed"
msgstr "Filter kondisi - mendefinisikan kondisi di mana paket akan diinstal"

#. type: SS
#: condinapt.1:155
#, no-wrap
msgid "Package Name Structure"
msgstr "Struktur Nama Paket"

#. type: Plain text
#: condinapt.1:158
msgid "\\f[B]Simple name:\\fR"
msgstr "\\f[B]Nama sederhana:\\fR"

#. type: Plain text
#: condinapt.1:163
#, no-wrap
msgid ""
"\\f[C]\n"
"vim\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"vim\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:166
msgid "\\f[B]Package version:\\fR"
msgstr "\\f[B]Versi paket:\\fR"

#. type: Plain text
#: condinapt.1:170
msgid "\\f[B]package=version\\f[R] - loose version requirement.  If the required version is unavailable, an available version is installed\\fR"
msgstr "\\f[B]package=version\\f[R] - kebutuhan versi longgar. Jika versi yang diminta tidak tersedia, versi yang tersedia akan diinstal\\fR"

#. type: Plain text
#: condinapt.1:173
msgid "\\f[B]package==version\\f[R] - strict requirement.  If the version is not found, installation aborts with an error\\fR"
msgstr "\\f[B]package==version\\f[R] - kebutuhan ketat. Jika versi tidak ditemukan, instalasi dibatalkan dengan galat\\fR"

#. type: Plain text
#: condinapt.1:175
msgid "\\f[B]Release specification:\\fR"
msgstr "\\f[B]Spesifikasi rilis:\\fR"

#. type: Plain text
#: condinapt.1:177
msgid "The release is specified using the **\\[at]** symbol:"
msgstr "Rilis ditentukan menggunakan simbol **\\[at]**:"

#. type: Plain text
#: condinapt.1:183
#, no-wrap
msgid ""
"\\f[C]\n"
"telegram\\[at]bookworm-backports\n"
"kernel-image-6.5.0\\[at]trixie-backports\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"telegram\\[at]bookworm-backports\n"
"kernel-image-6.5.0\\[at]trixie-backports\\fR\n"
"\n"

#. type: SS
#: condinapt.1:184
#, no-wrap
msgid "File Structure"
msgstr "Struktur Berkas"

#. type: Plain text
#: condinapt.1:188
msgid "\\f[B]Package names:\\f[R] Each package or condition is written on a new line\\fR"
msgstr "\\f[B]Nama paket:\\f[R] Setiap paket atau kondisi ditulis pada baris baru\\fR"

#. type: Plain text
#: condinapt.1:191
msgid "\\f[B]Comments:\\f[R] Lines starting with \\f[B]#\\f[R], or text after \\f[B]#\\f[R] on a line, are completely ignored\\fR"
msgstr "\\f[B]Komentar:\\f[R] Baris yang diawali dengan \\f[B]#\\f[R], atau teks setelah \\f[B]#\\f[R] pada sebuah baris, akan sepenuhnya diabaikan\\fR"

#. type: Plain text
#: condinapt.1:193
msgid "\\f[B]Empty lines:\\f[R] Ignored and serve for visual separation\\fR"
msgstr "\\f[B]Baris kosong:\\f[R] Diabaikan dan digunakan untuk pemisah visual\\fR"

#. type: SS
#: condinapt.1:193
#, no-wrap
msgid "Filters and Conditions"
msgstr "Filter dan Kondisi"

#. type: SS
#: condinapt.1:194
#, no-wrap
msgid "Single Filters"
msgstr "Filter Tunggal"

#. type: Plain text
#: condinapt.1:198
msgid "\\f[B]+ (Positive):\\f[R] The condition is true if the variable value \\f[B]matches\\fR"
msgstr "\\f[B]+ (Positif):\\f[R] Kondisi bernilai benar jika nilai variabel \\f[B]sesuai\\fR"

#. type: Plain text
#: condinapt.1:200
msgid "Format: \\f[B]+=\\fR"
msgstr "Format: \\f[B]+=\\fR"

#. type: Plain text
#: condinapt.1:202 condinapt.1:215 condinapt.1:306
msgid "Example:"
msgstr "Contoh:"

#. type: Plain text
#: condinapt.1:207
#, no-wrap
msgid ""
"\\f[C]\n"
"nginx +st=server\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"nginx +st=server\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:211
msgid "\\f[B]- (Negative):\\f[R] The condition is true if the variable value \\f[B]does not match\\fR"
msgstr "\\f[B]- (Negatif):\\f[R] Kondisi bernilai benar jika nilai variabel \\f[B]tidak sesuai\\fR"

#. type: Plain text
#: condinapt.1:213
msgid "Format: \\f[B]-=\\fR"
msgstr "Format: \\f[B]-=\\fR"

#. type: Plain text
#: condinapt.1:220
#, no-wrap
msgid ""
"\\f[C]\n"
"monitoring-tools -st=desktop\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"monitoring-tools -st=desktop\\fR\n"
"\n"

#. type: SS
#: condinapt.1:221
#, no-wrap
msgid "Group Filters"
msgstr "Filter Grup"

#. type: Plain text
#: condinapt.1:225
msgid "\\f[B]+{a|b} (OR for inclusion):\\f[R] True if \\f[B]at least one\\f[R] of the conditions in the group is true\\fR"
msgstr "\\f[B]+{a|b} (OR untuk inklusi):\\f[R] Benar jika \\f[B]setidaknya satu\\f[R] kondisi dalam grup bernilai benar\\fR"

#. type: Plain text
#: condinapt.1:230
#, no-wrap
msgid ""
"\\f[C]\n"
"web-server +{st=server|st=web-server}\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"web-server +{st=server|st=web-server}\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:234
msgid "\\f[B]+{a&b} (AND for inclusion):\\f[R] True only if \\f[B]all\\f[R] conditions in the group are true\\fR"
msgstr "\\f[B]+{a&b} (AND untuk inklusi):\\f[R] Benar hanya jika \\f[B]semua\\f[R] kondisi dalam grup bernilai benar\\fR"

#. type: Plain text
#: condinapt.1:239
#, no-wrap
msgid ""
"\\f[C]\n"
"database-tools +{d=bookworm&st=server}\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"database-tools +{d=bookworm&st=server}\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:243
msgid "\\f[B]-{a|b} (OR for exclusion):\\f[R] The package is excluded if \\f[B]at least one\\f[R] of the conditions is true\\fR"
msgstr "\\f[B]-{a|b} (OR untuk eksklusi):\\f[R] Paket dikecualikan jika \\f[B]setidaknya satu\\f[R] kondisi bernilai benar\\fR"

#. type: Plain text
#: condinapt.1:248
#, no-wrap
msgid ""
"\\f[C]\n"
"debug-tools -{env=production|st=minimal}\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"debug-tools -{env=production|st=minimal}\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:252
msgid "\\f[B]-{a&b} (AND for exclusion):\\f[R] The package is excluded only if \\f[B]all\\f[R] conditions are true\\fR"
msgstr "\\f[B]-{a&b} (AND untuk eksklusi):\\f[R] Paket dikecualikan hanya jika \\f[B]semua\\f[R] kondisi bernilai benar\\fR"

#. type: Plain text
#: condinapt.1:257
#, no-wrap
msgid ""
"\\f[C]\n"
"development-tools -{env=production&st=minimal}\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"development-tools -{env=production&st=minimal}\\fR\n"
"\n"

#. type: SS
#: condinapt.1:258
#, no-wrap
msgid "Logical Operators"
msgstr "Operator Logika"

#. type: Plain text
#: condinapt.1:262
msgid "\\f[B]|| (OR / Fallback):\\f[R] Try to install the left part.  If it fails, try the right part\\fR"
msgstr "\\f[B]|| (OR / Fallback):\\f[R] Coba instal bagian kiri. Jika gagal, coba bagian kanan\\fR"

#. type: Plain text
#: condinapt.1:267
#, no-wrap
msgid ""
"\\f[C]\n"
"exfatprogs -d=bookworm || exfat-utils\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"exfatprogs -d=bookworm || exfat-utils\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:271
msgid "\\f[B]&& (AND / Conjunction):\\f[R] All parts must successfully pass filter checks\\fR"
msgstr "\\f[B]&& (AND / Konjungsi):\\f[R] Semua bagian harus berhasil melewati pemeriksaan filter\\fR"

#. type: Plain text
#: condinapt.1:276
#, no-wrap
msgid ""
"\\f[C]\n"
"nginx +st=web-server && php-fpm\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"nginx +st=web-server && php-fpm\\fR\n"
"\n"

#. type: SS
#: condinapt.1:277
#, no-wrap
msgid "Special Modifiers"
msgstr "Modifikator Khusus"

#. type: Plain text
#: condinapt.1:283
msgid "\\f[B]! (Mandatory Package):\\f[R] If a package is marked with \\f[B]!\\f[R], but cannot be found in repositories, CondinAPT will abort execution with an error\\fR"
msgstr "\\f[B]! (Paket Wajib):\\f[R] Jika sebuah paket diberi tanda \\f[B]!\\f[R], namun tidak ditemukan di repositori, CondinAPT akan membatalkan eksekusi dengan galat\\fR"

#. type: Plain text
#: condinapt.1:288
#, no-wrap
msgid ""
"\\f[C]\n"
"!essential-package\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"!essential-package\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:292
msgid "\\f[B]\\[at] (Release Specification):\\f[R] Install a package from a specific Debian/Ubuntu release\\fR"
msgstr "\\f[B]\\[at] (Spesifikasi Rilis):\\f[R] Instal paket dari rilis Debian/Ubuntu tertentu\\fR"

#. type: Plain text
#: condinapt.1:297
#, no-wrap
msgid ""
"\\f[C]\n"
"kernel-image-6.5.0 \\[at]trixie-backports\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"kernel-image-6.5.0 \\[at]trixie-backports\\fR\n"
"\n"

#. type: SS
#: condinapt.1:298
#, no-wrap
msgid "Installation Queues"
msgstr "Antrian Instalasi"

#. type: Plain text
#: condinapt.1:304
msgid "The \\f[B]\\[em]\\f[R] separator on a separate line divides the list into groups (queues).  Packages from one queue are installed together in a single apt call.  Queues are executed strictly sequentially.\\fR"
msgstr "Pemisah \\f[B]\\[em]\\f[R] pada baris terpisah membagi daftar menjadi grup (antrian). Paket dari satu antrian akan diinstal bersama dalam satu pemanggilan apt. Antrian dieksekusi secara berurutan."

#. type: Plain text
#: condinapt.1:320
#, no-wrap
msgid ""
"\\f[C]\n"
"# Queue 1: Base system\n"
"systemd\n"
"network-manager\n"
"---\n"
"# Queue 2: Web server\n"
"nginx\n"
"php-fpm\n"
"---\n"
"# Queue 3: Monitoring\n"
"prometheus\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"# Queue 1: Base system\n"
"systemd\n"
"network-manager\n"
"---\n"
"# Queue 2: Web server\n"
"nginx\n"
"php-fpm\n"
"---\n"
"# Queue 3: Monitoring\n"
"prometheus\\fR\n"
"\n"

#. type: SS
#: condinapt.1:321
#, no-wrap
msgid "Priority Queue"
msgstr "Antrian Prioritas"

#. type: Plain text
#: condinapt.1:326
msgid "Packages listed in the file specified by the \\f[B]-P\\f[R] flag (one package per line, no filters) form a special \\[lq]Queue #1\\[rq], which is executed first.\\fR"
msgstr "Paket yang tercantum dalam berkas yang ditentukan oleh flag \\f[B]-P\\f[R] (satu paket per baris, tanpa filter) membentuk \\[lq]Queue #1\\[rq] khusus, yang akan dijalankan pertama kali.\\fR"

#. type: Plain text
#: condinapt.1:330
msgid "Any package from the priority list is automatically removed from all regular queues.  This ensures it will be installed unconditionally."
msgstr "Setiap paket dari daftar prioritas akan otomatis dihapus dari seluruh antrean reguler.  Hal ini memastikan paket tersebut akan dipasang tanpa syarat."

#. type: SS
#: condinapt.1:331
#, no-wrap
msgid "Quick Start"
msgstr "Mulai Cepat"

#. type: Plain text
#: condinapt.1:334
msgid "Create the configuration file \\f[B]config.conf\\f[R]:\\fR"
msgstr "Buat berkas konfigurasi \\f[B]config.conf\\f[R]:\\fR"

#. type: Plain text
#: condinapt.1:341
#, no-wrap
msgid ""
"\\f[C]\n"
"DISTRIBUTION=\\[dq]bookworm\\[dq]\n"
"SYSTEM_TYPE=\\[dq]server\\[dq]\n"
"ENVIRONMENT=\\[dq]production\\[dq]\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"DISTRIBUTION=\\[dq]bookworm\\[dq]\n"
"SYSTEM_TYPE=\\[dq]server\\[dq]\n"
"ENVIRONMENT=\\[dq]production\\[dq]\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:344
msgid "Create the package list \\f[B]packages.list\\f[R]:\\fR"
msgstr "Buat daftar paket \\f[B]packages.list\\f[R]:\\fR"

#. type: Plain text
#: condinapt.1:350
#, no-wrap
msgid ""
"\\f[C]\n"
"# Base packages - always installed\n"
"vim\n"
"curl\\fR\n"
msgstr ""
"\\f[C]\n"
"# Paket dasar - selalu dipasang\n"
"vim\n"
"curl\\fR\n"

#. type: Plain text
#: condinapt.1:354
#, no-wrap
msgid ""
"\\f[C]# Packages only for servers\n"
"nginx +SYSTEM_TYPE=server\n"
"mysql-server +SYSTEM_TYPE=server\\fR\n"
msgstr ""
"\\f[C]# Paket hanya untuk server\n"
"nginx +SYSTEM_TYPE=server\n"
"mysql-server +SYSTEM_TYPE=server\\fR\n"

#. type: Plain text
#: condinapt.1:358
#, no-wrap
msgid ""
"\\f[C]# Exclude packages for production environment\n"
"debug-tools -ENVIRONMENT=production\\fR\n"
"\n"
msgstr ""
"\\f[C]# Kecualikan paket untuk lingkungan produksi\n"
"debug-tools -ENVIRONMENT=production\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:361
msgid "Run the installation:"
msgstr "Jalankan instalasi:"

#. type: Plain text
#: condinapt.1:366
#, no-wrap
msgid ""
"\\f[C]\n"
"condinapt -l packages.list -c config.conf\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"condinapt -l packages.list -c config.conf\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:369
msgid "Or test in simulation mode:"
msgstr "Atau uji dalam mode simulasi:"

#. type: Plain text
#: condinapt.1:374
#, no-wrap
msgid ""
"\\f[C]\n"
"condinapt -l packages.list -c config.conf -s\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"condinapt -l packages.list -c config.conf -s\\fR\n"
"\n"

#. type: SS
#: condinapt.1:375
#, no-wrap
msgid "Multimedia Server"
msgstr "Server Multimedia"

#. type: Plain text
#: condinapt.1:378 condinapt.1:400 condinapt-minios.7:142
#: condinapt-minios.7:165 condinapt-minios.7:186 condinapt-minios.7:213
msgid "\\f[B]packages.list:\\fR"
msgstr "\\f[B]packages.list:\\fR"

#. type: Plain text
#: condinapt.1:384 condinapt-minios.7:148
#, no-wrap
msgid ""
"\\f[C]\n"
"# Basic multimedia codecs - always\n"
"gstreamer1.0-plugins-base\n"
"gstreamer1.0-plugins-good\\fR\n"
msgstr ""
"\\f[C]\n"
"# Codec multimedia dasar - selalu\n"
"gstreamer1.0-plugins-base\n"
"gstreamer1.0-plugins-good\\fR\n"

#. type: Plain text
#: condinapt.1:388
#, no-wrap
msgid ""
"\\f[C]# Additional codecs - not for minimal installation\n"
"gstreamer1.0-plugins-bad -st=minimal\n"
"gstreamer1.0-plugins-ugly -st=minimal\\fR\n"
msgstr ""
"\\f[C]# Codec tambahan - tidak untuk instalasi minimal\n"
"gstreamer1.0-plugins-bad -st=minimal\n"
"gstreamer1.0-plugins-ugly -st=minimal\\fR\n"

#. type: Plain text
#: condinapt.1:396
#, no-wrap
msgid ""
"\\f[C]# Professional tools - only for full configuration\n"
"ffmpeg +st=media-server\n"
"vlc +st=media-server\n"
"---\n"
"# Distribution-specific packages from backports\n"
"ffmpeg \\[at]bookworm-backports +d=bookworm\\fR\n"
"\n"
msgstr ""
"\\f[C]# Alat profesional - hanya untuk konfigurasi penuh\n"
"ffmpeg +st=media-server\n"
"vlc +st=media-server\n"
"---\n"
"# Paket khusus distribusi dari backports\n"
"ffmpeg \\[at]bookworm-backports +d=bookworm\\fR\n"
"\n"

#. type: SS
#: condinapt.1:397
#, no-wrap
msgid "Web Server with Various Configurations"
msgstr "Server Web dengan Berbagai Konfigurasi"

#. type: Plain text
#: condinapt.1:406
#, no-wrap
msgid ""
"\\f[C]\n"
"# Basic web server components\n"
"nginx\n"
"openssl\\fR\n"
msgstr ""
"\\f[C]\n"
"# Komponen server web dasar\n"
"nginx\n"
"openssl\\fR\n"

#. type: Plain text
#: condinapt.1:410
#, no-wrap
msgid ""
"\\f[C]# Database - only for full installations\n"
"mysql-server +st=full-server -{env=minimal}\n"
"postgresql +st=database-server\\fR\n"
msgstr ""
"\\f[C]# Basis data - hanya untuk instalasi penuh\n"
"mysql-server +st=full-server -{env=minimal}\n"
"postgresql +st=database-server\\fR\n"

#. type: Plain text
#: condinapt.1:414
#, no-wrap
msgid ""
"\\f[C]# PHP - for web servers\n"
"php-fpm +feat=php\n"
"php-mysql +{feat=php&st=full-server}\\fR\n"
msgstr ""
"\\f[C]# PHP - untuk server web\n"
"php-fpm +feat=php\n"
"php-mysql +{feat=php&st=full-server}\\fR\n"

#. type: Plain text
#: condinapt.1:418
#, no-wrap
msgid ""
"\\f[C]# Monitoring - not for development\n"
"prometheus-node-exporter -env=development\\fR\n"
"\n"
msgstr ""
"\\f[C]# Monitoring - tidak untuk pengembangan\n"
"prometheus-node-exporter -env=development\\fR\n"
"\n"

#. type: SH
#: condinapt.1:419
#, no-wrap
msgid "OPERATING MODES"
msgstr "MODE OPERASI"

#. type: SS
#: condinapt.1:420
#, no-wrap
msgid "Simulation Mode"
msgstr "Mode Simulasi"

#. type: Plain text
#: condinapt.1:424
msgid "Allows you to see which packages will be installed without actually installing them:"
msgstr "Memungkinkan Anda melihat paket mana yang akan dipasang tanpa benar-benar memasangnya:"

#. type: Plain text
#: condinapt.1:429
#, no-wrap
msgid ""
"\\f[C]\n"
"condinapt -l packages.list -c system.conf -s\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"condinapt -l packages.list -c system.conf -s\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:432
msgid "In simulation mode, the script exits with exit code 1."
msgstr "Pada mode simulasi, skrip keluar dengan kode keluar 1."

#. type: SS
#: condinapt.1:432
#, no-wrap
msgid "Check Mode"
msgstr "Mode Pemeriksaan"

#. type: Plain text
#: condinapt.1:435
msgid "Checks which packages from the list are already installed on the system:"
msgstr "Memeriksa paket mana dari daftar yang sudah terpasang di sistem:"

#. type: Plain text
#: condinapt.1:440
#, no-wrap
msgid ""
"\\f[C]\n"
"condinapt -l packages.list -c system.conf -C\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"condinapt -l packages.list -c system.conf -C\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:444
msgid "Shows errors for uninstalled packages and returns exit code 1 if there are uninstalled packages."
msgstr "Menampilkan galat untuk paket yang belum terpasang dan mengembalikan kode keluar 1 jika ada paket yang belum terpasang."

#. type: SS
#: condinapt.1:444
#, no-wrap
msgid "Debugging Modes"
msgstr "Mode Debugging"

#. type: Plain text
#: condinapt.1:447
msgid "\\f[B]Verbose Output (-v):\\fR"
msgstr "\\f[B]Keluaran Verbose (-v):\\fR"

#. type: Plain text
#: condinapt.1:450
msgid "Shows detailed information about filter checks and displays results for each package."
msgstr "Menampilkan informasi detail tentang pemeriksaan filter dan hasil untuk setiap paket."

#. type: Plain text
#: condinapt.1:452
msgid "\\f[B]Very Verbose Output (-vv):\\fR"
msgstr "\\f[B]Keluaran Sangat Verbose (-vv):\\fR"

#. type: Plain text
#: condinapt.1:454
msgid "Maximum process detail, shows all intermediate steps."
msgstr "Detail proses maksimum, menampilkan semua langkah perantara."

#. type: Plain text
#: condinapt.1:456
msgid "\\f[B]Command Tracing (-x):\\fR"
msgstr "\\f[B]Pelacakan Perintah (-x):\\fR"

#. type: Plain text
#: condinapt.1:459
msgid "Enables \\f[B]set -x\\f[R] for script debugging, shows each command being executed.\\fR"
msgstr "Mengaktifkan \\f[B]set -x\\f[R] untuk debug skrip, menampilkan setiap perintah yang dieksekusi.\\fR"

#. type: SH
#: condinapt.1:459
#, no-wrap
msgid "ERROR HANDLING"
msgstr "PENANGANAN GALAT"

#. type: SS
#: condinapt.1:460
#, no-wrap
msgid "Mandatory Packages"
msgstr "Paket Wajib"

#. type: Plain text
#: condinapt.1:464
msgid "If a package is marked as mandatory (\\f[B]!\\f[R]) but not found in repositories, CondinAPT:\\fR"
msgstr "Jika sebuah paket ditandai sebagai wajib (\\f[B]!\\f[R]) namun tidak ditemukan di repositori, CondinAPT:\\fR"

#. type: IP
#: condinapt.1:464
#, no-wrap
msgid "\\f[R]1.\\fR"
msgstr "\\f[R]1.\\fR"

#. type: Plain text
#: condinapt.1:466
msgid "Outputs an error message"
msgstr "Menampilkan pesan galat"

#. type: Plain text
#: condinapt.1:468
msgid "Aborts execution (unless in simulation mode)"
msgstr "Menghentikan eksekusi (kecuali dalam mode simulasi)"

#. type: IP
#: condinapt.1:468
#, no-wrap
msgid "3."
msgstr "3."

#. type: Plain text
#: condinapt.1:470
msgid "Returns exit code 1"
msgstr "Mengembalikan kode keluar 1"

#. type: SS
#: condinapt.1:470
#, no-wrap
msgid "Handling Unavailable Versions"
msgstr "Penanganan Versi yang Tidak Tersedia"

#. type: Plain text
#: condinapt.1:473
msgid "\\f[B]Loose Versions (=):\\fR"
msgstr "\\f[B]Versi Longgar (=):\\fR"

#. type: Plain text
#: condinapt.1:476
msgid "If the exact version is unavailable, any available version is installed with a warning."
msgstr "Jika versi yang persis diminta tidak tersedia, versi apa pun yang tersedia akan dipasang disertai peringatan."

#. type: Plain text
#: condinapt.1:478
msgid "\\f[B]Strict Versions (==):\\fR"
msgstr "\\f[B]Versi Ketat (==):\\fR"

#. type: Plain text
#: condinapt.1:481
msgid "If the exact version is unavailable, the package is skipped.  If the package is mandatory (\\f[B]!\\f[R]), execution aborts.\\fR"
msgstr "Jika versi yang persis diminta tidak tersedia, paket akan dilewati. Jika paket tersebut wajib (\\f[B]!\\f[R]), eksekusi akan dihentikan.\\fR"

#. type: SS
#: condinapt.1:481
#, no-wrap
msgid "Version Holding"
msgstr "Penahanan Versi"

#. type: Plain text
#: condinapt.1:485
msgid "CondinAPT automatically applies \\f[B]apt-mark hold\\f[R] when the exactly requested version was installed, preventing automatic updates.\\fR"
msgstr "CondinAPT secara otomatis menerapkan \\f[B]apt-mark hold\\f[R] ketika versi yang diminta secara tepat telah dipasang, sehingga mencegah pembaruan otomatis.\\fR"

#. type: SH
#: condinapt.1:485 condinapt-minios.7:297
#, no-wrap
msgid "FILES"
msgstr "BERKAS"

#. type: TP
#: condinapt.1:486
#, no-wrap
msgid "\\f[B]/etc/condinapt/config.conf\\fR"
msgstr "\\f[B]/etc/condinapt/config.conf\\fR"

#. type: Plain text
#: condinapt.1:489
msgid "Default configuration file"
msgstr "Berkas konfigurasi default"

#. type: TP
#: condinapt.1:489
#, no-wrap
msgid "\\f[B]/etc/condinapt/filters.map\\fR"
msgstr "\\f[B]/etc/condinapt/filters.map\\fR"

#. type: Plain text
#: condinapt.1:492
msgid "Default filter mapping file"
msgstr "Berkas pemetaan filter default"

#. type: Plain text
#: condinapt.1:496
msgid "\\f[B]apt\\f[R](8), \\f[B]apt-get\\f[R](8), \\f[B]apt-cache\\f[R](8), \\f[B]condinapt-minios\\f[R](7)\\fR"
msgstr "\\f[B]apt\\f[R](8), \\f[B]apt-get\\f[R](8), \\f[B]apt-cache\\f[R](8), \\f[B]condinapt-minios\\f[R](7)\\fR"
