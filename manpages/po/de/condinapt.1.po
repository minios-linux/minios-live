#. type: TH
#: condinapt.1:17
#, no-wrap
msgid "CONDINAPT"
msgstr "CONDINAPT"

#. type: TH
#: condinapt.1:17
#, no-wrap
msgid "CondinAPT Package Manager"
msgstr "CondinAPT Paketmanager"

#. type: Plain text
#: condinapt.1:23
msgid "condinapt - conditional package installation tool for Debian-like systems"
msgstr "condinapt - Werkzeug zur bedingten Paketinstallation für Debian-ähnliche Systeme"

#. type: Plain text
#: condinapt.1:26
msgid "\\f[B]condinapt\\f[R] [\\f[I]OPTIONS\\f[R]]\\fR"
msgstr "\\f[B]condinapt\\f[R] [\\f[I]OPTIONEN\\f[R]]\\fR"

#. type: Plain text
#: condinapt.1:33
msgid "\\f[B]CondinAPT\\f[R] is a versatile tool for automating package installation in any Debian-like system (Debian, Ubuntu, and their derivatives).  Its key feature is the ability to define complex conditions and rules for installing each package based on arbitrary system configurations.\\fR"
msgstr "\\f[B]CondinAPT\\f[R] ist ein vielseitiges Werkzeug zur Automatisierung der Paketinstallation auf jedem Debian-ähnlichen System (Debian, Ubuntu und deren Derivate).  Das Hauptmerkmal ist die Möglichkeit, komplexe Bedingungen und Regeln für die Installation einzelner Pakete basierend auf beliebigen Systemkonfigurationen zu definieren.\\fR"

#. type: SS
#: condinapt.1:33
#, no-wrap
msgid "Areas of Application"
msgstr "Anwendungsbereiche"

#. type: Plain text
#: condinapt.1:36
msgid "Linux distribution build systems"
msgstr "Build-Systeme für Linux-Distributionen"

#. type: Plain text
#: condinapt.1:38
msgid "Automation of server and workstation setup"
msgstr "Automatisierung der Server- und Arbeitsplatzinstallation"

#. type: Plain text
#: condinapt.1:40
msgid "Deployment of various system configurations"
msgstr "Ausrollen verschiedener Systemkonfigurationen"

#. type: Plain text
#: condinapt.1:42
msgid "Package management in Docker containers"
msgstr "Paketverwaltung in Docker-Containern"

#. type: Plain text
#: condinapt.1:44
msgid "CI/CD pipelines for environment setup"
msgstr "CI/CD-Pipelines zur Umgebungseinrichtung"

#. type: Plain text
#: condinapt.1:46
msgid "Creation of custom installation images"
msgstr "Erstellung von benutzerdefinierten Installationsabbildern"

#. type: SS
#: condinapt.1:46
#, no-wrap
msgid "Key Features"
msgstr "Hauptfunktionen"

#. type: Plain text
#: condinapt.1:50
msgid "\\f[B]Conditional Installation:\\f[R] Install packages based on flexible filters (+, -)\\fR"
msgstr "\\f[B]Bedingte Installation:\\f[R] Pakete werden anhand flexibler Filter (+, -) installiert\\fR"

#. type: Plain text
#: condinapt.1:53
msgid "\\f[B]External Configuration:\\f[R] Complete separation of logic (package list) from data (system parameters)\\fR"
msgstr "\\f[B]Externe Konfiguration:\\f[R] Vollständige Trennung von Logik (Paketliste) und Daten (Systemparameter)\\fR"

#. type: Plain text
#: condinapt.1:56
msgid "\\f[B]Installation Queues:\\f[R] Divide the process into sequential stages to resolve dependencies\\fR"
msgstr "\\f[B]Installationswarteschlangen:\\f[R] Prozess in aufeinanderfolgende Phasen unterteilen, um Abhängigkeiten aufzulösen\\fR"

#. type: Plain text
#: condinapt.1:59
msgid "\\f[B]Priority Queue:\\f[R] Guaranteed installation of critical packages first\\fR"
msgstr "\\f[B]Prioritätswarteschlange:\\f[R] Kritische Pakete werden garantiert zuerst installiert\\fR"

#. type: Plain text
#: condinapt.1:62
msgid "\\f[B]Complex Logic:\\f[R] Support for \\[lq]AND\\[rq] (&&), \\[lq]OR\\[rq] (||) operators, as well as group filters (+{a|b}, -{a&b})\\fR"
msgstr "\\f[B]Komplexe Logik:\\f[R] Unterstützung für \\[lq]UND\\[rq] (&&), \\[lq]ODER\\[rq] (||) Operatoren sowie Gruppenfilter (+{a|b}, -{a&b})\\fR"

#. type: Plain text
#: condinapt.1:65
msgid "\\f[B]Readability:\\f[R] Support for comments and empty lines to structure lists\\fR"
msgstr "\\f[B]Lesbarkeit:\\f[R] Unterstützung für Kommentare und Leerzeilen zur Strukturierung von Listen\\fR"

#. type: Plain text
#: condinapt.1:68
msgid "\\f[B]Backward Compatibility:\\f[R] Supports simple package lists without conditions\\fR"
msgstr "\\f[B]Abwärtskompatibilität:\\f[R] Unterstützt einfache Paketlisten ohne Bedingungen\\fR"

#. type: TP
#: condinapt.1:69
#, no-wrap
msgid "\\f[B]-l\\f[R], \\f[B]--package-list\\f[R] \\f[I]PATH\\fR"
msgstr "\\f[B]-l\\f[R], \\f[B]--package-list\\f[R] \\f[I]PATH\\fR"

#. type: Plain text
#: condinapt.1:72
msgid "(Required) Path to the package list file"
msgstr "(Erforderlich) Pfad zur Paketlisten-Datei"

#. type: TP
#: condinapt.1:72
#, no-wrap
msgid "\\f[B]-c\\f[R], \\f[B]--config\\f[R] \\f[I]PATH\\fR"
msgstr "\\f[B]-c\\f[R], \\f[B]--config\\f[R] \\f[I]PATH\\fR"

#. type: Plain text
#: condinapt.1:75
msgid "(Required) Path to the main configuration file"
msgstr "(Erforderlich) Pfad zur Hauptkonfigurationsdatei"

#. type: TP
#: condinapt.1:75
#, no-wrap
msgid "\\f[B]-m\\f[R], \\f[B]--filter-mapping\\f[R] \\f[I]PATH\\fR"
msgstr "\\f[B]-m\\f[R], \\f[B]--filter-mapping\\f[R] \\f[I]PATH\\fR"

#. type: Plain text
#: condinapt.1:78
msgid "(Optional) Path to the filter mapping file"
msgstr "(Optional) Pfad zur Filter-Mapping-Datei"

#. type: TP
#: condinapt.1:78
#, no-wrap
msgid "\\f[B]-P\\f[R], \\f[B]--priority-list\\f[R] \\f[I]PATH\\fR"
msgstr "\\f[B]-P\\f[R], \\f[B]--priority-list\\f[R] \\f[I]PATH\\fR"

#. type: Plain text
#: condinapt.1:81
msgid "(Optional) Path to the priority package list file"
msgstr "(Optional) Pfad zur Prioritäten-Paketlisten-Datei"

#. type: TP
#: condinapt.1:81
#, no-wrap
msgid "\\f[B]-s\\f[R], \\f[B]--simulation\\fR"
msgstr "\\f[B]-s\\f[R], \\f[B]--simulation\\fR"

#. type: Plain text
#: condinapt.1:85
msgid "Simulation mode.  Packages will not be installed"
msgstr "Simulationsmodus. Pakete werden nicht installiert"

#. type: TP
#: condinapt.1:85
#, no-wrap
msgid "\\f[B]-C\\f[R], \\f[B]--check-only\\fR"
msgstr "\\f[B]-C\\f[R], \\f[B]--check-only\\fR"

#. type: Plain text
#: condinapt.1:88
msgid "Only check if packages are already installed"
msgstr "Prüft nur, ob Pakete bereits installiert sind"

#. type: TP
#: condinapt.1:88
#, no-wrap
msgid "\\f[B]-v\\f[R], \\f[B]--verbose\\fR"
msgstr "\\f[B]-v\\f[R], \\f[B]--verbose\\fR"

#. type: Plain text
#: condinapt.1:91
msgid "Verbose output"
msgstr "Ausführliche Ausgabe"

#. type: TP
#: condinapt.1:91
#, no-wrap
msgid "\\f[B]-vv\\f[R], \\f[B]--very-verbose\\fR"
msgstr "\\f[B]-vv\\f[R], \\f[B]--very-verbose\\fR"

#. type: Plain text
#: condinapt.1:94
msgid "Very verbose output"
msgstr "Sehr ausführliche Ausgabe"

#. type: TP
#: condinapt.1:94
#, no-wrap
msgid "\\f[B]-x\\f[R], \\f[B]--xtrace\\fR"
msgstr "\\f[B]-x\\f[R], \\f[B]--xtrace\\fR"

#. type: Plain text
#: condinapt.1:97
msgid "Enable \\f[B]set -x\\f[R] command tracing\\fR"
msgstr "Aktiviert die \\f[B]set -x\\f[R] Befehlsverfolgung\\fR"

#. type: TP
#: condinapt.1:97
#, no-wrap
msgid "\\f[B]-f\\f[R], \\f[B]--force\\fR"
msgstr "\\f[B]-f\\f[R], \\f[B]--force\\fR"

#. type: Plain text
#: condinapt.1:100
msgid "Force apt cache update (apt update)"
msgstr "Erzwingt das Aktualisieren des apt-Caches (apt update)"

#. type: TP
#: condinapt.1:100
#, no-wrap
msgid "\\f[B]-h\\f[R], \\f[B]--help\\fR"
msgstr "\\f[B]-h\\f[R], \\f[B]--help\\fR"

#. type: Plain text
#: condinapt.1:103
msgid "Show help"
msgstr "Hilfe anzeigen"

#. type: SH
#: condinapt.1:103
#, no-wrap
msgid "CORE COMPONENTS"
msgstr "KERNKOMPONENTEN"

#. type: Plain text
#: condinapt.1:106
msgid "CondinAPT operates with four key files:"
msgstr "CondinAPT arbeitet mit vier zentralen Dateien:"

#. type: SS
#: condinapt.1:106
#, no-wrap
msgid "condinapt script"
msgstr "condinapt-Skript"

#. type: Plain text
#: condinapt.1:109
msgid "The core, containing all processing logic"
msgstr "Das Kernstück, das die gesamte Verarbeitungslogik enthält"

#. type: SS
#: condinapt.1:109
#, no-wrap
msgid "Main configuration file (-c)"
msgstr "Hauptkonfigurationsdatei (-c)"

#. type: Plain text
#: condinapt.1:112
msgid "A file with bash variables describing the current environment"
msgstr "Eine Datei mit Bash-Variablen, die die aktuelle Umgebung beschreibt"

#. type: Plain text
#: condinapt.1:114
msgid "Example (\\f[B]system.conf\\f[R]):\\fR"
msgstr "Beispiel (\\f[B]system.conf\\f[R]):\\fR"

#. type: Plain text
#: condinapt.1:123
#, no-wrap
msgid ""
"\\f[C]\n"
"DISTRIBUTION=\\[dq]bookworm\\[dq]\n"
"SYSTEM_TYPE=\\[dq]server\\[dq]\n"
"ENVIRONMENT=\\[dq]production\\[dq]\n"
"LOCALE=\\[dq]en_US\\[dq]\n"
"FEATURES=\\[dq]web,database\\[dq]\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"DISTRIBUTION=\\[dq]bookworm\\[dq]\n"
"SYSTEM_TYPE=\\[dq]server\\[dq]\n"
"ENVIRONMENT=\\[dq]production\\[dq]\n"
"LOCALE=\\[dq]en_US\\[dq]\n"
"FEATURES=\\[dq]web,database\\[dq]\\fR\n"
"\n"

#. type: SS
#: condinapt.1:124
#, no-wrap
msgid "Filter mapping file (-m)"
msgstr "Filter-Zuordnungsdatei (-m)"

#. type: Plain text
#: condinapt.1:132
msgid "Links short prefixes (used in the package list) to variable names from the main configuration file.  This file is \\f[B]optional\\f[R].  If a filter is not present in the filter mapping file, it will be used as a variable name from the main configuration file.  If the variable is not found, CondinAPT will declare it empty.\\fR"
msgstr "Verknüpft kurze Präfixe (wie in der Paketliste verwendet) mit Variablennamen aus der Hauptkonfigurationsdatei. Diese Datei ist \\f[B]optional\\f[R]. Ist ein Filter nicht in der Filter-Zuordnungsdatei vorhanden, wird er als Variablenname aus der Hauptkonfigurationsdatei verwendet. Wird die Variable nicht gefunden, setzt CondinAPT sie auf leer.\\fR"

#. type: Plain text
#: condinapt.1:134
msgid "Example (\\f[B]filters.map\\f[R]):\\fR"
msgstr "Beispiel (\\f[B]filters.map\\f[R]):\\fR"

#. type: Plain text
#: condinapt.1:143
#, no-wrap
msgid ""
"\\f[C]\n"
"d=DISTRIBUTION\n"
"st=SYSTEM_TYPE\n"
"env=ENVIRONMENT\n"
"arch=ARCHITECTURE\n"
"feat=FEATURES\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"d=DISTRIBUTION\n"
"st=SYSTEM_TYPE\n"
"env=ENVIRONMENT\n"
"arch=ARCHITECTURE\n"
"feat=FEATURES\\fR\n"
"\n"

#. type: SS
#: condinapt.1:144
#, no-wrap
msgid "Package list file (-l)"
msgstr "Paketlistendatei (-l)"

#. type: Plain text
#: condinapt.1:147
msgid "The main file describing what to install and under what conditions"
msgstr "Die Hauptdatei, die beschreibt, was installiert werden soll und unter welchen Bedingungen"

#. type: SH
#: condinapt.1:147
#, no-wrap
msgid "PACKAGE LIST SYNTAX"
msgstr "PAKETLISTEN-SYNTAX"

#. type: Plain text
#: condinapt.1:150
msgid "Each line in the package list file consists of two main parts:"
msgstr "Jede Zeile in der Paketlistendatei besteht aus zwei Hauptteilen:"

#. type: IP
#: condinapt.1:150
#, no-wrap
msgid "1."
msgstr "1."

#. type: Plain text
#: condinapt.1:152
msgid "Package name with optional version and release specification"
msgstr "Paketname mit optionaler Versions- und Release-Angabe"

#. type: IP
#: condinapt.1:152 condinapt.1:466
#, no-wrap
msgid "2."
msgstr "2."

#. type: Plain text
#: condinapt.1:155
msgid "Condition filters - define the conditions under which the package will be installed"
msgstr "Bedingungsfilter – legen fest, unter welchen Bedingungen das Paket installiert wird"

#. type: SS
#: condinapt.1:155
#, no-wrap
msgid "Package Name Structure"
msgstr "Paketnamenstruktur"

#. type: Plain text
#: condinapt.1:158
msgid "\\f[B]Simple name:\\fR"
msgstr "\\f[B]Einfacher Name:\\fR"

#. type: Plain text
#: condinapt.1:163
#, no-wrap
msgid ""
"\\f[C]\n"
"vim\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"vim\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:166
msgid "\\f[B]Package version:\\fR"
msgstr "\\f[B]Paketversion:\\fR"

#. type: Plain text
#: condinapt.1:170
msgid "\\f[B]package=version\\f[R] - loose version requirement.  If the required version is unavailable, an available version is installed\\fR"
msgstr "\\f[B]package=version\\f[R] – lockere Versionsvorgabe. Ist die geforderte Version nicht verfügbar, wird eine verfügbare Version installiert\\fR"

#. type: Plain text
#: condinapt.1:173
msgid "\\f[B]package==version\\f[R] - strict requirement.  If the version is not found, installation aborts with an error\\fR"
msgstr "\\f[B]package==version\\f[R] – strikte Vorgabe. Wird die Version nicht gefunden, bricht die Installation mit einem Fehler ab\\fR"

#. type: Plain text
#: condinapt.1:175
msgid "\\f[B]Release specification:\\fR"
msgstr "\\f[B]Releasespezifikation:\\fR"

#. type: Plain text
#: condinapt.1:177
msgid "The release is specified using the **\\[at]** symbol:"
msgstr "Die Release wird mit dem Symbol **\\[at]** angegeben:"

#. type: Plain text
#: condinapt.1:183
#, no-wrap
msgid ""
"\\f[C]\n"
"telegram\\[at]bookworm-backports\n"
"kernel-image-6.5.0\\[at]trixie-backports\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"telegram\\[at]bookworm-backports\n"
"kernel-image-6.5.0\\[at]trixie-backports\\fR\n"
"\n"

#. type: SS
#: condinapt.1:184
#, no-wrap
msgid "File Structure"
msgstr "Dateistruktur"

#. type: Plain text
#: condinapt.1:188
msgid "\\f[B]Package names:\\f[R] Each package or condition is written on a new line\\fR"
msgstr "\\f[B]Paketnamen:\\f[R] Jedes Paket oder jede Bedingung wird in einer neuen Zeile geschrieben\\fR"

#. type: Plain text
#: condinapt.1:191
msgid "\\f[B]Comments:\\f[R] Lines starting with \\f[B]#\\f[R], or text after \\f[B]#\\f[R] on a line, are completely ignored\\fR"
msgstr "\\f[B]Kommentare:\\f[R] Zeilen, die mit \\f[B]#\\f[R] beginnen, oder Text nach \\f[B]#\\f[R] in einer Zeile, werden vollständig ignoriert\\fR"

#. type: Plain text
#: condinapt.1:193
msgid "\\f[B]Empty lines:\\f[R] Ignored and serve for visual separation\\fR"
msgstr "\\f[B]Leere Zeilen:\\f[R] Werden ignoriert und dienen der optischen Trennung\\fR"

#. type: SS
#: condinapt.1:193
#, no-wrap
msgid "Filters and Conditions"
msgstr "Filter und Bedingungen"

#. type: SS
#: condinapt.1:194
#, no-wrap
msgid "Single Filters"
msgstr "Einzelne Filter"

#. type: Plain text
#: condinapt.1:198
msgid "\\f[B]+ (Positive):\\f[R] The condition is true if the variable value \\f[B]matches\\fR"
msgstr "\\f[B]+ (Positiv):\\f[R] Die Bedingung ist erfüllt, wenn der Variablenwert \\f[B]übereinstimmt\\fR"

#. type: Plain text
#: condinapt.1:200
msgid "Format: \\f[B]+=\\fR"
msgstr "Format: \\f[B]+=\\fR"

#. type: Plain text
#: condinapt.1:202 condinapt.1:215 condinapt.1:306
msgid "Example:"
msgstr "Beispiel:"

#. type: Plain text
#: condinapt.1:207
#, no-wrap
msgid ""
"\\f[C]\n"
"nginx +st=server\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"nginx +st=server\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:211
msgid "\\f[B]- (Negative):\\f[R] The condition is true if the variable value \\f[B]does not match\\fR"
msgstr "\\f[B]- (Negativ):\\f[R] Die Bedingung ist erfüllt, wenn der Variablenwert \\f[B]nicht übereinstimmt\\fR"

#. type: Plain text
#: condinapt.1:213
msgid "Format: \\f[B]-=\\fR"
msgstr "Format: \\f[B]-=\\fR"

#. type: Plain text
#: condinapt.1:220
#, no-wrap
msgid ""
"\\f[C]\n"
"monitoring-tools -st=desktop\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"monitoring-tools -st=desktop\\fR\n"
"\n"

#. type: SS
#: condinapt.1:221
#, no-wrap
msgid "Group Filters"
msgstr "Gruppenfilter"

#. type: Plain text
#: condinapt.1:225
msgid "\\f[B]+{a|b} (OR for inclusion):\\f[R] True if \\f[B]at least one\\f[R] of the conditions in the group is true\\fR"
msgstr "\\f[B]+{a|b} (ODER für Einschluss):\\f[R] Wahr, wenn \\f[B]mindestens eine\\f[R] der Bedingungen in der Gruppe erfüllt ist\\fR"

#. type: Plain text
#: condinapt.1:230
#, no-wrap
msgid ""
"\\f[C]\n"
"web-server +{st=server|st=web-server}\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"web-server +{st=server|st=web-server}\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:234
msgid "\\f[B]+{a&b} (AND for inclusion):\\f[R] True only if \\f[B]all\\f[R] conditions in the group are true\\fR"
msgstr "\\f[B]+{a&b} (UND für Einschluss):\\f[R] Wahr nur, wenn \\f[B]alle\\f[R] Bedingungen in der Gruppe erfüllt sind\\fR"

#. type: Plain text
#: condinapt.1:239
#, no-wrap
msgid ""
"\\f[C]\n"
"database-tools +{d=bookworm&st=server}\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"database-tools +{d=bookworm&st=server}\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:243
msgid "\\f[B]-{a|b} (OR for exclusion):\\f[R] The package is excluded if \\f[B]at least one\\f[R] of the conditions is true\\fR"
msgstr "\\f[B]-{a|b} (ODER für Ausschluss):\\f[R] Das Paket wird ausgeschlossen, wenn \\f[B]mindestens eine\\f[R] der Bedingungen erfüllt ist\\fR"

#. type: Plain text
#: condinapt.1:248
#, no-wrap
msgid ""
"\\f[C]\n"
"debug-tools -{env=production|st=minimal}\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"debug-tools -{env=production|st=minimal}\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:252
msgid "\\f[B]-{a&b} (AND for exclusion):\\f[R] The package is excluded only if \\f[B]all\\f[R] conditions are true\\fR"
msgstr "\\f[B]-{a&b} (UND für Ausschluss):\\f[R] Das Paket wird nur ausgeschlossen, wenn \\f[B]alle\\f[R] Bedingungen erfüllt sind\\fR"

#. type: Plain text
#: condinapt.1:257
#, no-wrap
msgid ""
"\\f[C]\n"
"development-tools -{env=production&st=minimal}\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"development-tools -{env=production&st=minimal}\\fR\n"
"\n"

#. type: SS
#: condinapt.1:258
#, no-wrap
msgid "Logical Operators"
msgstr "Logische Operatoren"

#. type: Plain text
#: condinapt.1:262
msgid "\\f[B]|| (OR / Fallback):\\f[R] Try to install the left part.  If it fails, try the right part\\fR"
msgstr "\\f[B]|| (ODER / Fallback):\\f[R] Versucht, den linken Teil zu installieren. Falls dies fehlschlägt, wird der rechte Teil versucht\\fR"

#. type: Plain text
#: condinapt.1:267
#, no-wrap
msgid ""
"\\f[C]\n"
"exfatprogs -d=bookworm || exfat-utils\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"exfatprogs -d=bookworm || exfat-utils\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:271
msgid "\\f[B]&& (AND / Conjunction):\\f[R] All parts must successfully pass filter checks\\fR"
msgstr "\\f[B]&& (UND / Verknüpfung):\\f[R] Alle Teile müssen die Filterprüfungen erfolgreich bestehen\\fR"

#. type: Plain text
#: condinapt.1:276
#, no-wrap
msgid ""
"\\f[C]\n"
"nginx +st=web-server && php-fpm\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"nginx +st=web-server && php-fpm\\fR\n"
"\n"

#. type: SS
#: condinapt.1:277
#, no-wrap
msgid "Special Modifiers"
msgstr "Spezielle Modifikatoren"

#. type: Plain text
#: condinapt.1:283
msgid "\\f[B]! (Mandatory Package):\\f[R] If a package is marked with \\f[B]!\\f[R], but cannot be found in repositories, CondinAPT will abort execution with an error\\fR"
msgstr "\\f[B]! (Obligatorisches Paket):\\f[R] Ist ein Paket mit \\f[B]!\\f[R] markiert und kann nicht in den Repositories gefunden werden, bricht CondinAPT die Ausführung mit einem Fehler ab\\fR"

#. type: Plain text
#: condinapt.1:288
#, no-wrap
msgid ""
"\\f[C]\n"
"!essential-package\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"!essential-package\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:292
msgid "\\f[B]\\[at] (Release Specification):\\f[R] Install a package from a specific Debian/Ubuntu release\\fR"
msgstr "\\f[B]\\[at] (Releasespezifikation):\\f[R] Installiert ein Paket aus einer bestimmten Debian/Ubuntu-Version\\fR"

#. type: Plain text
#: condinapt.1:297
#, no-wrap
msgid ""
"\\f[C]\n"
"kernel-image-6.5.0 \\[at]trixie-backports\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"kernel-image-6.5.0 \\[at]trixie-backports\\fR\n"
"\n"

#. type: SS
#: condinapt.1:298
#, no-wrap
msgid "Installation Queues"
msgstr "Installationswarteschlangen"

#. type: Plain text
#: condinapt.1:304
msgid "The \\f[B]\\[em]\\f[R] separator on a separate line divides the list into groups (queues).  Packages from one queue are installed together in a single apt call.  Queues are executed strictly sequentially.\\fR"
msgstr "Der \\f[B]\\[em]\\f[R]-Trenner in einer eigenen Zeile teilt die Liste in Gruppen (Warteschlangen). Pakete aus einer Warteschlange werden gemeinsam in einem einzelnen apt-Aufruf installiert. Warteschlangen werden strikt nacheinander abgearbeitet.\\fR"

#. type: Plain text
#: condinapt.1:320
#, no-wrap
msgid ""
"\\f[C]\n"
"# Queue 1: Base system\n"
"systemd\n"
"network-manager\n"
"---\n"
"# Queue 2: Web server\n"
"nginx\n"
"php-fpm\n"
"---\n"
"# Queue 3: Monitoring\n"
"prometheus\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"# Queue 1: Base system\n"
"systemd\n"
"network-manager\n"
"---\n"
"# Queue 2: Web server\n"
"nginx\n"
"php-fpm\n"
"---\n"
"# Queue 3: Monitoring\n"
"prometheus\\fR\n"
"\n"

#. type: SS
#: condinapt.1:321
#, no-wrap
msgid "Priority Queue"
msgstr "Prioritätswarteschlange"

#. type: Plain text
#: condinapt.1:326
msgid "Packages listed in the file specified by the \\f[B]-P\\f[R] flag (one package per line, no filters) form a special \\[lq]Queue #1\\[rq], which is executed first.\\fR"
msgstr "Pakete, die in der durch den \\f[B]-P\\f[R]-Schalter angegebenen Datei aufgelistet sind (ein Paket pro Zeile, keine Filter), bilden eine spezielle \\[lq]Queue #1\\[rq], die zuerst ausgeführt wird.\\fR"

#. type: Plain text
#: condinapt.1:330
msgid "Any package from the priority list is automatically removed from all regular queues.  This ensures it will be installed unconditionally."
msgstr "Alle Pakete aus der Prioritätenliste werden automatisch aus allen regulären Warteschlangen entfernt.  Dies stellt sicher, dass sie bedingungslos installiert werden."

#. type: SS
#: condinapt.1:331
#, no-wrap
msgid "Quick Start"
msgstr "Schnellstart"

#. type: Plain text
#: condinapt.1:334
msgid "Create the configuration file \\f[B]config.conf\\f[R]:\\fR"
msgstr "Erstellen Sie die Konfigurationsdatei \\f[B]config.conf\\f[R]:\\fR"

#. type: Plain text
#: condinapt.1:341
#, no-wrap
msgid ""
"\\f[C]\n"
"DISTRIBUTION=\\[dq]bookworm\\[dq]\n"
"SYSTEM_TYPE=\\[dq]server\\[dq]\n"
"ENVIRONMENT=\\[dq]production\\[dq]\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"DISTRIBUTION=\\[dq]bookworm\\[dq]\n"
"SYSTEM_TYPE=\\[dq]server\\[dq]\n"
"ENVIRONMENT=\\[dq]production\\[dq]\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:344
msgid "Create the package list \\f[B]packages.list\\f[R]:\\fR"
msgstr "Erstellen Sie die Paketliste \\f[B]packages.list\\f[R]:\\fR"

#. type: Plain text
#: condinapt.1:350
#, no-wrap
msgid ""
"\\f[C]\n"
"# Base packages - always installed\n"
"vim\n"
"curl\\fR\n"
msgstr ""
"\\f[C]\n"
"# Basispakete – werden immer installiert\n"
"vim\n"
"curl\\fR\n"

#. type: Plain text
#: condinapt.1:354
#, no-wrap
msgid ""
"\\f[C]# Packages only for servers\n"
"nginx +SYSTEM_TYPE=server\n"
"mysql-server +SYSTEM_TYPE=server\\fR\n"
msgstr ""
"\\f[C]# Pakete nur für Server\n"
"nginx +SYSTEM_TYPE=server\n"
"mysql-server +SYSTEM_TYPE=server\\fR\n"

#. type: Plain text
#: condinapt.1:358
#, no-wrap
msgid ""
"\\f[C]# Exclude packages for production environment\n"
"debug-tools -ENVIRONMENT=production\\fR\n"
"\n"
msgstr ""
"\\f[C]# Pakete für Produktionsumgebungen ausschließen\n"
"debug-tools -ENVIRONMENT=production\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:361
msgid "Run the installation:"
msgstr "Führen Sie die Installation aus:"

#. type: Plain text
#: condinapt.1:366
#, no-wrap
msgid ""
"\\f[C]\n"
"condinapt -l packages.list -c config.conf\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"condinapt -l packages.list -c config.conf\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:369
msgid "Or test in simulation mode:"
msgstr "Oder im Simulationsmodus testen:"

#. type: Plain text
#: condinapt.1:374
#, no-wrap
msgid ""
"\\f[C]\n"
"condinapt -l packages.list -c config.conf -s\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"condinapt -l packages.list -c config.conf -s\\fR\n"
"\n"

#. type: SS
#: condinapt.1:375
#, no-wrap
msgid "Multimedia Server"
msgstr "Multimedia-Server"

#. type: Plain text
#: condinapt.1:378 condinapt.1:400 condinapt-minios.7:142
#: condinapt-minios.7:165 condinapt-minios.7:186 condinapt-minios.7:213
msgid "\\f[B]packages.list:\\fR"
msgstr "\\f[B]packages.list:\\fR"

#. type: Plain text
#: condinapt.1:384 condinapt-minios.7:148
#, no-wrap
msgid ""
"\\f[C]\n"
"# Basic multimedia codecs - always\n"
"gstreamer1.0-plugins-base\n"
"gstreamer1.0-plugins-good\\fR\n"
msgstr ""
"\\f[C]\n"
"# Grundlegende Multimedia-Codecs – immer\n"
"gstreamer1.0-plugins-base\n"
"gstreamer1.0-plugins-good\\fR\n"

#. type: Plain text
#: condinapt.1:388
#, no-wrap
msgid ""
"\\f[C]# Additional codecs - not for minimal installation\n"
"gstreamer1.0-plugins-bad -st=minimal\n"
"gstreamer1.0-plugins-ugly -st=minimal\\fR\n"
msgstr ""
"\\f[C]# Zusätzliche Codecs – nicht für Minimalinstallation\n"
"gstreamer1.0-plugins-bad -st=minimal\n"
"gstreamer1.0-plugins-ugly -st=minimal\\fR\n"

#. type: Plain text
#: condinapt.1:396
#, no-wrap
msgid ""
"\\f[C]# Professional tools - only for full configuration\n"
"ffmpeg +st=media-server\n"
"vlc +st=media-server\n"
"---\n"
"# Distribution-specific packages from backports\n"
"ffmpeg \\[at]bookworm-backports +d=bookworm\\fR\n"
"\n"
msgstr ""
"\\f[C]# Professionelle Werkzeuge – nur für vollständige Konfiguration\n"
"ffmpeg +st=media-server\n"
"vlc +st=media-server\n"
"---\n"
"# Distributionsspezifische Pakete aus Backports\n"
"ffmpeg \\[at]bookworm-backports +d=bookworm\\fR\n"
"\n"

#. type: SS
#: condinapt.1:397
#, no-wrap
msgid "Web Server with Various Configurations"
msgstr "Webserver mit verschiedenen Konfigurationen"

#. type: Plain text
#: condinapt.1:406
#, no-wrap
msgid ""
"\\f[C]\n"
"# Basic web server components\n"
"nginx\n"
"openssl\\fR\n"
msgstr ""
"\\f[C]\n"
"# Grundlegende Webserver-Komponenten\n"
"nginx\n"
"openssl\\fR\n"

#. type: Plain text
#: condinapt.1:410
#, no-wrap
msgid ""
"\\f[C]# Database - only for full installations\n"
"mysql-server +st=full-server -{env=minimal}\n"
"postgresql +st=database-server\\fR\n"
msgstr ""
"\\f[C]# Datenbank – nur für vollständige Installationen\n"
"mysql-server +st=full-server -{env=minimal}\n"
"postgresql +st=database-server\\fR\n"

#. type: Plain text
#: condinapt.1:414
#, no-wrap
msgid ""
"\\f[C]# PHP - for web servers\n"
"php-fpm +feat=php\n"
"php-mysql +{feat=php&st=full-server}\\fR\n"
msgstr ""
"\\f[C]# PHP – für Webserver\n"
"php-fpm +feat=php\n"
"php-mysql +{feat=php&st=full-server}\\fR\n"

#. type: Plain text
#: condinapt.1:418
#, no-wrap
msgid ""
"\\f[C]# Monitoring - not for development\n"
"prometheus-node-exporter -env=development\\fR\n"
"\n"
msgstr ""
"\\f[C]# Monitoring – nicht für Entwicklung\n"
"prometheus-node-exporter -env=development\\fR\n"
"\n"

#. type: SH
#: condinapt.1:419
#, no-wrap
msgid "OPERATING MODES"
msgstr "BETRIEBSMODI"

#. type: SS
#: condinapt.1:420
#, no-wrap
msgid "Simulation Mode"
msgstr "Simulationsmodus"

#. type: Plain text
#: condinapt.1:424
msgid "Allows you to see which packages will be installed without actually installing them:"
msgstr "Ermöglicht es, anzuzeigen, welche Pakete installiert würden, ohne diese tatsächlich zu installieren:"

#. type: Plain text
#: condinapt.1:429
#, no-wrap
msgid ""
"\\f[C]\n"
"condinapt -l packages.list -c system.conf -s\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"condinapt -l packages.list -c system.conf -s\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:432
msgid "In simulation mode, the script exits with exit code 1."
msgstr "Im Simulationsmodus beendet sich das Skript mit Exit-Code 1."

#. type: SS
#: condinapt.1:432
#, no-wrap
msgid "Check Mode"
msgstr "Prüfmodus"

#. type: Plain text
#: condinapt.1:435
msgid "Checks which packages from the list are already installed on the system:"
msgstr "Überprüft, welche Pakete aus der Liste bereits auf dem System installiert sind:"

#. type: Plain text
#: condinapt.1:440
#, no-wrap
msgid ""
"\\f[C]\n"
"condinapt -l packages.list -c system.conf -C\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"condinapt -l packages.list -c system.conf -C\\fR\n"
"\n"

#. type: Plain text
#: condinapt.1:444
msgid "Shows errors for uninstalled packages and returns exit code 1 if there are uninstalled packages."
msgstr "Zeigt Fehler für nicht installierte Pakete an und gibt Exit-Code 1 zurück, falls Pakete fehlen."

#. type: SS
#: condinapt.1:444
#, no-wrap
msgid "Debugging Modes"
msgstr "Debug-Modi"

#. type: Plain text
#: condinapt.1:447
msgid "\\f[B]Verbose Output (-v):\\fR"
msgstr "\\f[B]Ausführliche Ausgabe (-v):\\fR"

#. type: Plain text
#: condinapt.1:450
msgid "Shows detailed information about filter checks and displays results for each package."
msgstr "Zeigt detaillierte Informationen zu Filterprüfungen und gibt Ergebnisse für jedes Paket aus."

#. type: Plain text
#: condinapt.1:452
msgid "\\f[B]Very Verbose Output (-vv):\\fR"
msgstr "\\f[B]Sehr ausführliche Ausgabe (-vv):\\fR"

#. type: Plain text
#: condinapt.1:454
msgid "Maximum process detail, shows all intermediate steps."
msgstr "Maximale Prozessdetails, zeigt alle Zwischenschritte."

#. type: Plain text
#: condinapt.1:456
msgid "\\f[B]Command Tracing (-x):\\fR"
msgstr "\\f[B]Befehlsverfolgung (-x):\\fR"

#. type: Plain text
#: condinapt.1:459
msgid "Enables \\f[B]set -x\\f[R] for script debugging, shows each command being executed.\\fR"
msgstr "Aktiviert \\f[B]set -x\\f[R] zur Skript-Diagnose und zeigt jeden ausgeführten Befehl an.\\fR"

#. type: SH
#: condinapt.1:459
#, no-wrap
msgid "ERROR HANDLING"
msgstr "FEHLERBEHANDLUNG"

#. type: SS
#: condinapt.1:460
#, no-wrap
msgid "Mandatory Packages"
msgstr "Verpflichtende Pakete"

#. type: Plain text
#: condinapt.1:464
msgid "If a package is marked as mandatory (\\f[B]!\\f[R]) but not found in repositories, CondinAPT:\\fR"
msgstr "Wenn ein Paket als obligatorisch markiert ist (\\f[B]!\\f[R]), aber in den Repositories nicht gefunden wird, führt CondinAPT:\\fR"

#. type: IP
#: condinapt.1:464
#, no-wrap
msgid "\\f[R]1.\\fR"
msgstr "\\f[R]1.\\fR"

#. type: Plain text
#: condinapt.1:466
msgid "Outputs an error message"
msgstr "Gibt eine Fehlermeldung aus"

#. type: Plain text
#: condinapt.1:468
msgid "Aborts execution (unless in simulation mode)"
msgstr "Bricht die Ausführung ab (außer im Simulationsmodus)"

#. type: IP
#: condinapt.1:468
#, no-wrap
msgid "3."
msgstr "3."

#. type: Plain text
#: condinapt.1:470
msgid "Returns exit code 1"
msgstr "Gibt den Exit-Code 1 zurück"

#. type: SS
#: condinapt.1:470
#, no-wrap
msgid "Handling Unavailable Versions"
msgstr "Umgang mit nicht verfügbaren Versionen"

#. type: Plain text
#: condinapt.1:473
msgid "\\f[B]Loose Versions (=):\\fR"
msgstr "\\f[B]Lockere Versionen (=):\\fR"

#. type: Plain text
#: condinapt.1:476
msgid "If the exact version is unavailable, any available version is installed with a warning."
msgstr "Wenn die exakte Version nicht verfügbar ist, wird eine beliebige verfügbare Version mit einer Warnung installiert."

#. type: Plain text
#: condinapt.1:478
msgid "\\f[B]Strict Versions (==):\\fR"
msgstr "\\f[B]Strikte Versionen (==):\\fR"

#. type: Plain text
#: condinapt.1:481
msgid "If the exact version is unavailable, the package is skipped.  If the package is mandatory (\\f[B]!\\f[R]), execution aborts.\\fR"
msgstr "Wenn die exakte Version nicht verfügbar ist, wird das Paket übersprungen. Ist das Paket obligatorisch (\\f[B]!\\f[R]), wird die Ausführung abgebrochen.\\fR"

#. type: SS
#: condinapt.1:481
#, no-wrap
msgid "Version Holding"
msgstr "Versionssperre"

#. type: Plain text
#: condinapt.1:485
msgid "CondinAPT automatically applies \\f[B]apt-mark hold\\f[R] when the exactly requested version was installed, preventing automatic updates.\\fR"
msgstr "CondinAPT setzt automatisch \\f[B]apt-mark hold\\f[R], wenn genau die angeforderte Version installiert wurde, um automatische Updates zu verhindern.\\fR"

#. type: SH
#: condinapt.1:485 condinapt-minios.7:297
#, no-wrap
msgid "FILES"
msgstr "DATEIEN"

#. type: TP
#: condinapt.1:486
#, no-wrap
msgid "\\f[B]/etc/condinapt/config.conf\\fR"
msgstr "\\f[B]/etc/condinapt/config.conf\\fR"

#. type: Plain text
#: condinapt.1:489
msgid "Default configuration file"
msgstr "Standard-Konfigurationsdatei"

#. type: TP
#: condinapt.1:489
#, no-wrap
msgid "\\f[B]/etc/condinapt/filters.map\\fR"
msgstr "\\f[B]/etc/condinapt/filters.map\\fR"

#. type: Plain text
#: condinapt.1:492
msgid "Default filter mapping file"
msgstr "Standard-Datei für Filterzuordnungen"

#. type: Plain text
#: condinapt.1:496
msgid "\\f[B]apt\\f[R](8), \\f[B]apt-get\\f[R](8), \\f[B]apt-cache\\f[R](8), \\f[B]condinapt-minios\\f[R](7)\\fR"
msgstr "\\f[B]apt\\f[R](8), \\f[B]apt-get\\f[R](8), \\f[B]apt-cache\\f[R](8), \\f[B]condinapt-minios\\f[R](7)\\fR"
