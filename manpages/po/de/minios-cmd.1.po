#. type: TH
#: minios-cmd.1:17
#, no-wrap
msgid "MiniOS Command-Line Builder"
msgstr "MiniOS-Kommandozeilen-Builder"

#. type: Plain text
#: minios-cmd.1:23
msgid "minios-cmd - command-line utility for configuring and building customized MiniOS system images"
msgstr "minios-cmd – Kommandozeilenwerkzeug zur Konfiguration und Erstellung angepasster MiniOS-Systemabbilder"

#. type: Plain text
#: minios-cmd.1:26
msgid "\\f[B]minios-cmd\\f[R] [\\f[I]OPTIONS\\f[R]]\\fR"
msgstr "\\f[B]minios-cmd\\f[R] [\\f[I]OPTIONS\\f[R]]\\fR"

#. type: Plain text
#: minios-cmd.1:33
msgid "\\f[B]minios-cmd\\f[R] is a command-line utility designed to simplify the process of configuring and building customized MiniOS system images.  Acting as a frontend for \\f[B]minios-live\\f[R](1), it manages the configuration and invokes \\f[B]minios-live\\f[R] to execute the actual build steps.\\fR"
msgstr "\\f[B]minios-cmd\\f[R] ist ein Kommandozeilenwerkzeug, das den Prozess der Konfiguration und Erstellung angepasster MiniOS-Systemabbilder vereinfacht. Als Frontend für \\f[B]minios-live\\f[R](1) verwaltet es die Konfiguration und ruft \\f[B]minios-live\\f[R] zur Ausführung der eigentlichen Bauschritte auf.\\fR"

#. type: Plain text
#: minios-cmd.1:37
msgid "With \\f[B]minios-cmd\\f[R], you can customize various aspects of your MiniOS image, including:\\fR"
msgstr "Mit \\f[B]minios-cmd\\f[R] können Sie verschiedene Aspekte Ihres MiniOS-Abbilds anpassen, darunter:\\fR"

#. type: Plain text
#: minios-cmd.1:41
msgid "\\f[B]Distribution:\\f[R] Choose from Debian releases (\\f[B]buster\\f[R], \\f[B]bullseye\\f[R], \\f[B]bookworm\\f[R], \\f[B]trixie\\f[R]) and Ubuntu releases (\\f[B]jammy\\f[R], \\f[B]noble\\f[R])\\fR"
msgstr "\\f[B]Distribution:\\f[R] Auswahl aus Debian-Releases (\\f[B]buster\\f[R], \\f[B]bullseye\\f[R], \\f[B]bookworm\\f[R], \\f[B]trixie\\f[R]) und Ubuntu-Releases (\\f[B]jammy\\f[R], \\f[B]noble\\f[R])\\fR"

#. type: Plain text
#: minios-cmd.1:44
msgid "\\f[B]Architecture:\\f[R] Specify the target architecture (\\f[B]amd64\\f[R], \\f[B]i386\\f[R] for older distributions)\\fR"
msgstr "\\f[B]Architektur:\\f[R] Zielarchitektur angeben (\\f[B]amd64\\f[R], \\f[B]i386\\f[R] für ältere Distributionen)\\fR"

#. type: Plain text
#: minios-cmd.1:46
msgid "\\f[B]Desktop Environment:\\fR"
msgstr "\\f[B]Desktop-Umgebung:\\fR"

#. type: Plain text
#: minios-cmd.1:50
msgid "\\f[B]Debian:\\f[R] \\f[B]xfce\\f[R] (standard), \\f[B]flux\\f[R] (minimum), \\f[B]lxqt\\f[R] (bookworm/trixie only)\\fR"
msgstr "\\f[B]Debian:\\f[R] \\f[B]xfce\\f[R] (Standard), \\f[B]flux\\f[R] (Minimal), \\f[B]lxqt\\f[R] (nur bookworm/trixie)\\fR"

#. type: Plain text
#: minios-cmd.1:52
msgid "\\f[B]Ubuntu:\\f[R] \\f[B]xfce\\f[R] only\\fR"
msgstr "\\f[B]Ubuntu:\\f[R] nur \\f[B]xfce\\f[R]\\fR"

#. type: Plain text
#: minios-cmd.1:55
msgid "\\f[B]Package Variant:\\fR"
msgstr "\\f[B]Paketvariante:\\fR"

#. type: Plain text
#: minios-cmd.1:59
msgid "\\f[B]All Debian:\\f[R] \\f[B]standard\\f[R] (xfce), \\f[B]minimum\\f[R] (flux)\\fR"
msgstr "\\f[B]Alle Debian:\\f[R] \\f[B]standard\\f[R] (xfce), \\f[B]minimum\\f[R] (flux)\\fR"

#. type: Plain text
#: minios-cmd.1:61
msgid "\\f[B]Bookworm/Trixie only:\\f[R] \\f[B]toolbox\\f[R], \\f[B]ultra\\fR"
msgstr "\\f[B]Nur Bookworm/Trixie:\\f[R] \\f[B]toolbox\\f[R], \\f[B]ultra\\fR"

#. type: Plain text
#: minios-cmd.1:63
msgid "\\f[B]Ubuntu:\\f[R] \\f[B]standard\\f[R] only\\fR"
msgstr "\\f[B]Ubuntu:\\f[R] nur \\f[B]standard\\f[R]\\fR"

#. type: Plain text
#: minios-cmd.1:67
msgid "\\f[B]Compression Type:\\f[R] Specify the image compression method (\\f[B]zstd\\f[R])\\fR"
msgstr "\\f[B]Kompressionstyp:\\f[R] Methode zur Abbildkomprimierung angeben (\\f[B]zstd\\f[R])\\fR"

#. type: Plain text
#: minios-cmd.1:70
msgid "\\f[B]Kernel:\\f[R] Configure kernel type, enable AUFS support, and DKMS module compilation\\fR"
msgstr "\\f[B]Kernel:\\f[R] Kerneltyp konfigurieren, AUFS-Unterstützung aktivieren und DKMS-Modulkompilierung\\fR"

#. type: Plain text
#: minios-cmd.1:73
msgid "\\f[B]Locale and Timezone:\\f[R] Set the system locale and timezone with multilingual support\\fR"
msgstr "\\f[B]Locale und Zeitzone:\\f[R] System-Locale und Zeitzone mit Mehrsprachigkeitsunterstützung festlegen\\fR"

#. type: SH
#: minios-cmd.1:73 condinapt.1:68
#, no-wrap
msgid "OPTIONS"
msgstr "OPTIONEN"

#. type: SS
#: minios-cmd.1:74
#, no-wrap
msgid "Configuration Options"
msgstr "Konfigurationsoptionen"

#. type: TP
#: minios-cmd.1:75
#, no-wrap
msgid "\\f[B]--config-file\\f[R] \\f[I]FILE\\fR"
msgstr "\\f[B]--config-file\\f[R] \\f[I]FILE\\fR"

#. type: Plain text
#: minios-cmd.1:79
msgid "Specify the configuration file path.  All other options are ignored."
msgstr "Pfad zur Konfigurationsdatei angeben. Alle anderen Optionen werden ignoriert."

#. type: TP
#: minios-cmd.1:79
#, no-wrap
msgid "\\f[B]--config-only\\fR"
msgstr "\\f[B]--config-only\\fR"

#. type: Plain text
#: minios-cmd.1:82
msgid "Generate the configuration file only and do not start the build process."
msgstr "Nur die Konfigurationsdatei erzeugen und den Build-Prozess nicht starten."

#. type: TP
#: minios-cmd.1:83
#, no-wrap
msgid "\\f[B]-b\\f[R], \\f[B]--build-dir\\f[R] \\f[I]DIR\\fR"
msgstr "\\f[B]-b\\f[R], \\f[B]--build-dir\\f[R] \\f[I]DIR\\fR"

#. type: Plain text
#: minios-cmd.1:86
msgid "Specify the build directory."
msgstr "Build-Verzeichnis angeben."

#. type: SS
#: minios-cmd.1:86
#, no-wrap
msgid "System Options"
msgstr "Systemoptionen"

#. type: Plain text
#: minios-cmd.1:90
msgid "These options \\f[B]must be provided\\f[R] unless a configuration file is used:\\fR"
msgstr "Diese Optionen \\f[B]müssen angegeben werden\\f[R], sofern keine Konfigurationsdatei verwendet wird:\\fR"

#. type: TP
#: minios-cmd.1:90
#, no-wrap
msgid "\\f[B]-d\\f[R], \\f[B]--distribution\\f[R] \\f[I]NAME\\fR"
msgstr "\\f[B]-d\\f[R], \\f[B]--distribution\\f[R] \\f[I]NAME\\fR"

#. type: Plain text
#: minios-cmd.1:94
msgid "Specify the distribution name (e.g., `bookworm').  \\f[B]REQUIRED\\fR"
msgstr "Geben Sie den Distributionsnamen an (z. B. \\[dq]bookworm\\[dq]).  \\f[B]ERFORDERLICH\\fR"

#. type: TP
#: minios-cmd.1:94
#, no-wrap
msgid "\\f[B]-a\\f[R], \\f[B]--architecture\\f[R] \\f[I]NAME\\fR"
msgstr "\\f[B]-a\\f[R], \\f[B]--architecture\\f[R] \\f[I]NAME\\fR"

#. type: Plain text
#: minios-cmd.1:98
msgid "Specify the architecture (e.g., `amd64').  \\f[B]REQUIRED\\fR"
msgstr "Geben Sie die Architektur an (z. B. \\[dq]amd64\\[dq]).  \\f[B]ERFORDERLICH\\fR"

#. type: TP
#: minios-cmd.1:98
#, no-wrap
msgid "\\f[B]-de\\f[R], \\f[B]--desktop-environment\\f[R] \\f[I]NAME\\fR"
msgstr "\\f[B]-de\\f[R], \\f[B]--desktop-environment\\f[R] \\f[I]NAME\\fR"

#. type: Plain text
#: minios-cmd.1:102
msgid "Specify the desktop environment (e.g., `xfce').  \\f[B]REQUIRED\\fR"
msgstr "Geben Sie die Desktop-Umgebung an (z. B. \\[dq]xfce\\[dq]).  \\f[B]ERFORDERLICH\\fR"

#. type: TP
#: minios-cmd.1:102
#, no-wrap
msgid "\\f[B]-pv\\f[R], \\f[B]--package-variant\\f[R] \\f[I]NAME\\fR"
msgstr "\\f[B]-pv\\f[R], \\f[B]--package-variant\\f[R] \\f[I]NAME\\fR"

#. type: Plain text
#: minios-cmd.1:106
msgid "Specify the package variant (e.g., `standard').  \\f[B]REQUIRED\\fR"
msgstr "Geben Sie die Paketvariante an (z. B. \\[dq]standard\\[dq]).  \\f[B]ERFORDERLICH\\fR"

#. type: TP
#: minios-cmd.1:106
#, no-wrap
msgid "\\f[B]-c\\f[R], \\f[B]--compression-type\\f[R] \\f[I]NAME\\fR"
msgstr "\\f[B]-c\\f[R], \\f[B]--compression-type\\f[R] \\f[I]NAME\\fR"

#. type: Plain text
#: minios-cmd.1:109
msgid "Specify the compression type (e.g., `zstd')."
msgstr "Geben Sie den Kompressionstyp an (z. B. \\[dq]zstd\\[dq])."

#. type: SS
#: minios-cmd.1:109
#, no-wrap
msgid "Kernel Options"
msgstr "Kernel-Optionen"

#. type: TP
#: minios-cmd.1:110
#, no-wrap
msgid "\\f[B]-kf\\f[R], \\f[B]--kernel-flavour\\f[R] \\f[I]NAME\\fR"
msgstr "\\f[B]-kf\\f[R], \\f[B]--kernel-flavour\\f[R] \\f[I]NAME\\fR"

#. type: Plain text
#: minios-cmd.1:113
msgid "Specify the kernel flavour (e.g., `none')."
msgstr "Geben Sie den Kernel-Typ an (z. B. \\[dq]none\\[dq])."

#. type: TP
#: minios-cmd.1:113
#, no-wrap
msgid "\\f[B]-aufs\\f[R], \\f[B]--kernel-aufs\\fR"
msgstr "\\f[B]-aufs\\f[R], \\f[B]--kernel-aufs\\fR"

#. type: Plain text
#: minios-cmd.1:116
msgid "Enable AUFS support in the kernel."
msgstr "Aktiviert AUFS-Unterstützung im Kernel."

#. type: TP
#: minios-cmd.1:116
#, no-wrap
msgid "\\f[B]-dkms\\f[R], \\f[B]--kernel-build-dkms\\fR"
msgstr "\\f[B]-dkms\\f[R], \\f[B]--kernel-build-dkms\\fR"

#. type: Plain text
#: minios-cmd.1:119
msgid "Enable compilation of additional drivers during kernel installation."
msgstr "Aktiviert die Kompilierung zusätzlicher Treiber während der Kernel-Installation."

#. type: SS
#: minios-cmd.1:119
#, no-wrap
msgid "Locale and Timezone Options"
msgstr "Locale- und Zeitzonen-Optionen"

#. type: TP
#: minios-cmd.1:120
#, no-wrap
msgid "\\f[B]-l\\f[R], \\f[B]--locale\\f[R] \\f[I]NAME\\fR"
msgstr "\\f[B]-l\\f[R], \\f[B]--locale\\f[R] \\f[I]NAME\\fR"

#. type: Plain text
#: minios-cmd.1:123
msgid "Specify the system locale (e.g., `en_US')."
msgstr "Geben Sie das System-Locale an (z. B. \\[dq]en_US\\[dq])."

#. type: TP
#: minios-cmd.1:123
#, no-wrap
msgid "\\f[B]-ml\\f[R], \\f[B]--multilingual\\fR"
msgstr "\\f[B]-ml\\f[R], \\f[B]--multilingual\\fR"

#. type: Plain text
#: minios-cmd.1:126
msgid "Enable multilingual support."
msgstr "Aktiviert Mehrsprachenunterstützung."

#. type: TP
#: minios-cmd.1:126
#, no-wrap
msgid "\\f[B]-kl\\f[R], \\f[B]--keep-locales\\fR"
msgstr "\\f[B]-kl\\f[R], \\f[B]--keep-locales\\fR"

#. type: Plain text
#: minios-cmd.1:129
msgid "Keep all available locales."
msgstr "Behält alle verfügbaren Locales."

#. type: TP
#: minios-cmd.1:129
#, no-wrap
msgid "\\f[B]-tz\\f[R], \\f[B]--timezone\\f[R] \\f[I]NAME\\fR"
msgstr "\\f[B]-tz\\f[R], \\f[B]--timezone\\f[R] \\f[I]NAME\\fR"

#. type: Plain text
#: minios-cmd.1:132
msgid "Specify the timezone (e.g., `Etc/UTC')."
msgstr "Geben Sie die Zeitzone an (z. B. \\[dq]Etc/UTC\\[dq])."

#. type: SS
#: minios-cmd.1:132
#, no-wrap
msgid "Boot Menu Options"
msgstr "Bootmenü-Optionen"

#. type: TP
#: minios-cmd.1:133
#, no-wrap
msgid "\\f[B]-mln\\f[R], \\f[B]--menu-language\\f[R] \\f[I]NAME\\fR"
msgstr "\\f[B]-mln\\f[R], \\f[B]--menu-language\\f[R] \\f[I]NAME\\fR"

#. type: Plain text
#: minios-cmd.1:137
msgid "Specify the boot menu language (`multilang' for language selection or specific language code like `ru_RU')."
msgstr "Geben Sie die Sprache des Bootmenüs an (\\[dq]multilang\\[dq] für Sprachauswahl oder spezifischer Sprachcode wie \\[dq]ru_RU\\[dq])."

#. type: SH
#: minios-cmd.1:137
#, no-wrap
msgid "DEFAULT SETTINGS"
msgstr "STANDARDWERTE"

#. type: SS
#: minios-cmd.1:138
#, no-wrap
msgid "Kernel Settings"
msgstr "Kernel-Einstellungen"

#. type: Plain text
#: minios-cmd.1:141
msgid "\\f[B]KERNEL_FLAVOUR\\f[R]: \\[lq]none\\[rq]\\fR"
msgstr "\\f[B]KERNEL_FLAVOUR\\f[R]: \\[lq]none\\[rq]\\fR"

#. type: SS
#: minios-cmd.1:141
#, no-wrap
msgid "Locale & Timezone Settings"
msgstr "Locale- & Zeitzonen-Einstellungen"

#. type: Plain text
#: minios-cmd.1:145
msgid "\\f[B]LOCALE\\f[R]: \\[lq]en_US\\[rq] \\f[B]LIVE_TIMEZONE\\f[R]: \\[lq]Etc/UTC\\[rq]\\fR"
msgstr "\\f[B]LOCALE\\f[R]: \\[lq]en_US\\[rq] \\f[B]LIVE_TIMEZONE\\f[R]: \\[lq]Etc/UTC\\[rq]\\fR"

#. type: SS
#: minios-cmd.1:145
#, no-wrap
msgid "Boot Menu Settings"
msgstr "Bootmenü-Einstellungen"

#. type: Plain text
#: minios-cmd.1:148
msgid "\\f[B]MENU_LANG\\f[R]: \\[lq]multilang\\[rq]\\fR"
msgstr "\\f[B]MENU_LANG\\f[R]: \\[lq]multilang\\[rq]\\fR"

#. type: SH
#: minios-cmd.1:148
#, no-wrap
msgid "INTERACTION WITH MINIOS-LIVE"
msgstr "INTERAKTION MIT MINIOS-LIVE"

#. type: Plain text
#: minios-cmd.1:154
msgid "\\f[B]minios-cmd\\f[R] prepares the build environment and generates a \\f[B]build.conf\\f[R] configuration file based on the options provided.  It then calls \\f[B]minios-live\\f[R] with the relevant environment variables, delegating the build execution to \\f[B]minios-live\\f[R].\\fR"
msgstr "\\f[B]minios-cmd\\f[R] bereitet die Build-Umgebung vor und erzeugt eine \\f[B]build.conf\\f[R]-Konfigurationsdatei basierend auf den angegebenen Optionen. Anschließend wird \\f[B]minios-live\\f[R] mit den entsprechenden Umgebungsvariablen aufgerufen und die Ausführung des Builds an \\f[B]minios-live\\f[R] delegiert.\\fR"

#. type: Plain text
#: minios-cmd.1:157
msgid "Create a MiniOS Standard system image with default settings:"
msgstr "Erstellt ein MiniOS-Standard-Systemabbild mit Standardeinstellungen:"

#. type: Plain text
#: minios-cmd.1:162
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-cmd -d bookworm -a amd64 -de xfce -pv standard -c zstd -aufs -dkms -kl\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-cmd -d bookworm -a amd64 -de xfce -pv standard -c zstd -aufs -dkms -kl\\fR\n"
"\n"

#. type: Plain text
#: minios-cmd.1:165
msgid "Create a MiniOS Toolbox system image with default settings:"
msgstr "Erstellt ein MiniOS-Toolbox-Systemabbild mit Standardeinstellungen:"

#. type: Plain text
#: minios-cmd.1:170
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-cmd -d bookworm -a amd64 -de xfce -pv toolbox -c zstd -aufs -dkms -kl\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-cmd -d bookworm -a amd64 -de xfce -pv toolbox -c zstd -aufs -dkms -kl\\fR\n"
"\n"

#. type: Plain text
#: minios-cmd.1:173
msgid "Create a system image with Russian locale:"
msgstr "Ein Systemabbild mit russischer Locale erstellen:"

#. type: Plain text
#: minios-cmd.1:178
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-cmd -d bookworm -a amd64 -de xfce -pv toolbox -l ru_RU\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-cmd -d bookworm -a amd64 -de xfce -pv toolbox -l ru_RU\\fR\n"
"\n"

#. type: Plain text
#: minios-cmd.1:181
msgid "Create a system image with LXQt desktop environment:"
msgstr "Ein Systemabbild mit der LXQt-Desktop-Umgebung erstellen:"

#. type: Plain text
#: minios-cmd.1:186
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-cmd -d bookworm -a amd64 -de lxqt -pv standard\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-cmd -d bookworm -a amd64 -de lxqt -pv standard\\fR\n"
"\n"

#. type: Plain text
#: minios-cmd.1:189
msgid "Create a system image for 32-bit architecture:"
msgstr "Ein Systemabbild für 32-Bit-Architektur erstellen:"

#. type: Plain text
#: minios-cmd.1:194
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-cmd -d buster -a i386 -de xfce -pv standard\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-cmd -d buster -a i386 -de xfce -pv standard\\fR\n"
"\n"

#. type: Plain text
#: minios-cmd.1:197
msgid "Create a system image with Ubuntu Jammy:"
msgstr "Ein Systemabbild mit Ubuntu Jammy erstellen:"

#. type: Plain text
#: minios-cmd.1:202
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-cmd -d jammy -pv standard -a amd64 -de xfce\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-cmd -d jammy -pv standard -a amd64 -de xfce\\fR\n"
"\n"

#. type: Plain text
#: minios-cmd.1:207
msgid "Enable multilingual support (generates locales for English, Spanish, German, French, Italian, Portuguese, Brazilian Portuguese, Russian, and Indonesian):"
msgstr "Mehrsprachige Unterstützung aktivieren (erstellt Locales für Englisch, Spanisch, Deutsch, Französisch, Italienisch, Portugiesisch, brasilianisches Portugiesisch, Russisch und Indonesisch):"

#. type: Plain text
#: minios-cmd.1:212
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-cmd -d trixie -a amd64 -de xfce -pv standard -ml\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-cmd -d trixie -a amd64 -de xfce -pv standard -ml\\fR\n"
"\n"

#. type: Plain text
#: minios-cmd.1:215
msgid "Create a system image with Russian boot menu language:"
msgstr "Ein Systemabbild mit russischer Sprache im Boot-Menü erstellen:"

#. type: Plain text
#: minios-cmd.1:220
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-cmd -d bookworm -a amd64 -de xfce -pv standard -mln ru_RU\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-cmd -d bookworm -a amd64 -de xfce -pv standard -mln ru_RU\\fR\n"
"\n"

#. type: SH
#: minios-cmd.1:221
#, no-wrap
msgid "GENERATING AND USING CONFIGURATION FILES"
msgstr "ERZEUGEN UND VERWENDEN VON KONFIGURATIONSDATEIEN"

#. type: Plain text
#: minios-cmd.1:224
msgid "Generate a configuration file:"
msgstr "Eine Konfigurationsdatei erzeugen:"

#. type: Plain text
#: minios-cmd.1:229
#, no-wrap
msgid ""
"\\f[C]\n"
"minios-cmd --config-only --config-file myconfig.conf -d bookworm -a amd64 -de xfce -pv standard\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"minios-cmd --config-only --config-file myconfig.conf -d bookworm -a amd64 -de xfce -pv standard\\fR\n"
"\n"

#. type: Plain text
#: minios-cmd.1:232
msgid "Use the configuration file with \\f[B]minios-live\\f[R]:\\fR"
msgstr "Die Konfigurationsdatei mit \\f[B]minios-live\\f[R] verwenden:\\fR"

#. type: Plain text
#: minios-cmd.1:237
#, no-wrap
msgid ""
"\\f[C]\n"
"BUILD_CONF=/path/to/myconfig.conf minios-live -\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"BUILD_CONF=/path/to/myconfig.conf minios-live -\\fR\n"
"\n"

#. type: Plain text
#: minios-cmd.1:240
msgid "or:"
msgstr "oder:"

#. type: Plain text
#: minios-cmd.1:246
#, no-wrap
msgid ""
"\\f[C]\n"
"export BUILD_CONF=/path/to/myconfig.conf\n"
"minios-live -\\fR\n"
"\n"
msgstr ""
"\\f[C]\n"
"export BUILD_CONF=/path/to/myconfig.conf\n"
"minios-live -\\fR\n"
"\n"

#. type: Plain text
#: minios-cmd.1:251
msgid "\\f[B]minios-live\\f[R](1), \\f[B]condinapt\\f[R](1), \\f[B]condinapt-minios\\f[R](7)\\fR"
msgstr "\\f[B]minios-live\\f[R](1), \\f[B]condinapt\\f[R](1), \\f[B]condinapt-minios\\f[R](7)\\fR"
