#: linux-live/minioslib:693 minios-live:149
msgid "Command not found:"
msgstr "Commande introuvable :"

#: linux-live/minioslib:2759
msgid "grub.template.cfg template not found"
msgstr "Modèle grub.template.cfg introuvable"

#: minios-cmd:48 minios-cmd:140 minios-live:86
msgid "Usage:"
msgstr "Utilisation :"

#: minios-cmd:49
msgid "Creates a system image with the specified parameters."
msgstr "Crée une image système avec les paramètres spécifiés."

#: minios-cmd:51
msgid "Options:"
msgstr "Options :"

#: minios-cmd:53
msgid "Config Options:"
msgstr "Options de configuration :"

#: minios-cmd:54
msgid "Specify the configuration file path. All other options are ignored."
msgstr ""
"Spécifiez le chemin du fichier de configuration. Toutes les autres options "
"seront ignorées."

#: minios-cmd:55
msgid ""
"Generate the configuration file only and do not start the build process."
msgstr ""
"Générer uniquement le fichier de configuration et ne pas démarrer le "
"processus de compilation."

#: minios-cmd:57
msgid "Build Options:"
msgstr "Options de compilation :"

#: minios-cmd:58
msgid "Specify the build directory."
msgstr "Spécifiez le répertoire de compilation."

#: minios-cmd:60
msgid "System Options:"
msgstr "Options système :"

#: minios-cmd:61
msgid "Specify the distribution name (e.g., 'bookworm'). REQUIRED"
msgstr ""
"Spécifiez le nom de la distribution (par exemple, 'bookworm'). OBLIGATOIRE"

#: minios-cmd:62
msgid "Specify the architecture (e.g., 'amd64'). REQUIRED"
msgstr "Spécifiez l'architecture (par exemple, 'amd64'). OBLIGATOIRE"

#: minios-cmd:63
msgid "Specify the desktop environment (e.g., 'xfce'). REQUIRED"
msgstr "Spécifiez l'environnement de bureau (par exemple, 'xfce'). OBLIGATOIRE"

#: minios-cmd:64
msgid "Specify the package variant (e.g., 'standard'). REQUIRED"
msgstr "Spécifiez la variante du paquet (par exemple, 'standard'). OBLIGATOIRE"

#: minios-cmd:65
msgid "Specify the compression type (e.g., 'zstd')."
msgstr "Spécifiez le type de compression (par exemple, 'zstd')."

#: minios-cmd:67
msgid "Kernel Options:"
msgstr "Options du noyau :"

#: minios-cmd:68
msgid "Specify the kernel flavour (e.g., 'none')."
msgstr "Spécifiez la saveur du noyau (par exemple, 'none')."

#: minios-cmd:69
msgid "Enable AUFS support in the kernel."
msgstr "Activer la prise en charge d'AUFS dans le noyau."

#: minios-cmd:70
msgid "Enable compilation of additional drivers during kernel installation."
msgstr ""
"Activer la compilation de pilotes supplémentaires pendant l'installation du "
"noyau."

#: minios-cmd:72
msgid "Locale and Timezone Options:"
msgstr "Options de paramètres régionaux et de fuseau horaire :"

#: minios-cmd:73
msgid "Specify the system locale (e.g., 'en_US')."
msgstr "Spécifiez les paramètres régionaux du système (par exemple, 'en_US')."

#: minios-cmd:74
msgid "Enable multilingual support."
msgstr "Activer la prise en charge multilingue."

#: minios-cmd:75
msgid "Keep all available locales."
msgstr "Conserver toutes les configurations régionales disponibles."

#: minios-cmd:76
msgid "Specify the timezone (e.g., 'Etc/UTC')."
msgstr "Spécifiez le fuseau horaire (par exemple, 'Etc/UTC')."

#: minios-cmd:78
msgid "Boot Loader Options:"
msgstr "Options du chargeur d’amorçage :"

#: minios-cmd:79
msgid "Specify the initramfs builder ('livekit' or 'dracut')."
msgstr "Indiquez le générateur d’initramfs (« livekit » ou « dracut »)."

#: minios-cmd:81
msgid "Boot Menu Options:"
msgstr "Options du menu de démarrage :"

#: minios-cmd:82
msgid ""
"Specify the boot menu language ('multilang' for language selection or "
"specific language code like 'ru_RU')."
msgstr ""
"Spécifiez la langue du menu de démarrage ('multilang' pour la sélection de "
"la langue ou un code de langue spécifique comme 'ru_RU')."

#: minios-cmd:84
msgid "Ubuntu Pro Options:"
msgstr "Options Ubuntu Pro :"

#: minios-cmd:85
msgid ""
"Specify Ubuntu Pro subscription token for fresh packages during build "
"(removed from final image)."
msgstr ""
"Spécifiez le jeton d’abonnement Ubuntu Pro pour obtenir des paquets récents "
"lors de la construction (supprimé de l’image finale)."

#: minios-cmd:87
msgid "Default Settings:"
msgstr "Paramètres par défaut :"

#: minios-cmd:89
msgid "Kernel Settings:"
msgstr "Paramètres du noyau :"

#: minios-cmd:92
msgid "Locale & Timezone Settings:"
msgstr "Paramètres régionaux et fuseau horaire :"

#: minios-cmd:96
msgid "Boot Loader Settings:"
msgstr "Paramètres du chargeur d’amorçage :"

#: minios-cmd:99
msgid "Boot Menu Settings:"
msgstr "Paramètres du menu de démarrage :"

#: minios-cmd:102 minios-live:109
msgid "Examples:"
msgstr "Exemples :"

#: minios-cmd:104
msgid "1. Create a MiniOS Standard system image (default settings):"
msgstr "1. Créer une image système MiniOS Standard (paramètres par défaut) :"

#: minios-cmd:107
msgid "2. Create a MiniOS Toolbox system image (default settings):"
msgstr "2. Créer une image système MiniOS Toolbox (paramètres par défaut) :"

#: minios-cmd:110
msgid ""
"3. Create a system image with the 'bookworm' distribution, 'amd64' "
"architecture, 'toolbox' package variant, and Russian locale:"
msgstr ""
"3. Créer une image système avec la distribution 'bookworm', l'architecture "
"'amd64', la variante de paquet 'toolbox' et les paramètres régionaux russes :"

#: minios-cmd:113
msgid ""
"4. Create a system image with the 'bookworm' distribution, 'amd64' "
"architecture, 'standard' package variant and 'lxqt' desktop environment:"
msgstr ""
"4. Créer une image système avec la distribution 'bookworm', l'architecture "
"'amd64', la variante de paquet 'standard' et l'environnement de bureau "
"'lxqt' :"

#: minios-cmd:116
msgid ""
"5. Create a system image with 'buster' distribution, 'i386' architecture, "
"and 'xfce' desktop environment:"
msgstr ""
"5. Créer une image système avec la distribution 'buster', l'architecture "
"'i386' et l'environnement de bureau 'xfce' :"

#: minios-cmd:119
msgid ""
"6. Create a system image with the 'jammy' distribution and 'standard' "
"package variant:"
msgstr ""
"6. Créer une image système avec la distribution 'jammy' et la variante de "
"paquet 'standard' :"

#: minios-cmd:122
msgid ""
"7. Create a system image with 'trixie' distribution, 'amd64' architecture, "
"and 'xfce' desktop environment with multilingual support enabled:"
msgstr ""
"7. Créer une image système avec la distribution 'trixie', l'architecture "
"'amd64', l'environnement de bureau 'xfce' et la prise en charge multilingue "
"activée :"

#: minios-cmd:125
msgid "8. Create a system image with Russian boot menu language:"
msgstr "8. Créer une image système avec le menu de démarrage en langue russe :"

#: minios-cmd:128
msgid "9. Create a system image with livekit initramfs builder:"
msgstr "9. Créer une image système avec le générateur d’initramfs livekit :"

#: minios-cmd:131
msgid ""
"10. Create an Ubuntu system image with Ubuntu Pro subscription for fresh "
"packages:"
msgstr ""
"10. Créer une image système Ubuntu avec un abonnement Ubuntu Pro pour des "
"paquets récents :"

#: minios-cmd:134
msgid ""
"has many more options available. Please refer to the above options list for "
"more details."
msgstr ""
"De nombreuses autres options sont disponibles. Veuillez consulter la liste "
"des options ci-dessus pour plus de détails."

#: minios-cmd:141
msgid "Try '%s --help' for more information."
msgstr "Essayez '%s --help' pour plus d'informations."

#: minios-live:87
msgid "This script builds bootable MiniOS ISO image."
msgstr "Ce script génère une image ISO amorçable MiniOS."

#: minios-live:89
msgid "Commands:"
msgstr "Commandes :"

#: minios-live:91
msgid "Install a minimal base system using debootstrap"
msgstr "Installer un système de base minimal avec debootstrap"

#: minios-live:92
msgid "Install core components and desktop environment in chroot"
msgstr ""
"Installer les composants principaux et l’environnement de bureau dans le "
"chroot"

#: minios-live:93
msgid "Create the main SquashFS image of the core system"
msgstr "Créer l’image SquashFS principale du système de base"

#: minios-live:94
msgid "Build additional SquashFS modules with extra packages"
msgstr ""
"Construire des modules SquashFS supplémentaires avec des paquets additionnels"

#: minios-live:95
msgid "Generate boot files, initrd, and boot configuration"
msgstr ""
"Générer les fichiers de démarrage, l’initrd et la configuration de démarrage"

#: minios-live:96
msgid "Generate configuration files for the build"
msgstr "Générer les fichiers de configuration pour la construction"

#: minios-live:97
msgid "Create the final bootable ISO image"
msgstr "Créer l’image ISO finale amorçable"

#: minios-live:98
msgid "Remove source files after the build"
msgstr "Supprimer les fichiers sources après la construction"

#: minios-live:100
msgid "How it works:"
msgstr "Fonctionnement :"

#: minios-live:102
msgid "No arguments or -h/--help: display this help (no root required)"
msgstr ""
"Aucun argument ou -h/--help : afficher cette aide (pas besoin des droits "
"root)"

#: minios-live:103
msgid "Single command: run only that build stage (requires root)"
msgstr ""
"Commande unique : exécuter uniquement cette étape de construction (requiert "
"les droits root)"

#: minios-live:104
msgid "start_cmd - end_cmd: run all commands in the range"
msgstr "start_cmd - end_cmd : exécuter toutes les commandes de la plage"

#: minios-live:105
msgid "Use '- end_cmd' to run from the first command to end_cmd"
msgstr ""
"Utilisez '- end_cmd' pour exécuter de la première commande jusqu’à end_cmd"

#: minios-live:106
msgid "Use 'start_cmd -' to run from start_cmd to the last command"
msgstr ""
"Utilisez 'start_cmd -' pour exécuter de start_cmd jusqu’à la dernière "
"commande"

#: minios-live:107
msgid "Use '-' alone to run the entire build from start to finish"
msgstr ""
"Utilisez '-' seul pour exécuter l’ensemble de la construction du début à la "
"fin"

#: minios-live:111
msgid "Display this help and exit:"
msgstr "Afficher cette aide et quitter :"

#: minios-live:114
msgid "Run the build from start to finish:"
msgstr "Exécuter la construction du début à la fin :"

#: minios-live:117
msgid ""
"Start the build by building the base environment and finish by installing "
"the entire system in chroot:"
msgstr ""
"Démarrer la construction en créant l’environnement de base et terminer en "
"installant tout le système dans le chroot :"

#: minios-live:120
msgid ""
"Start the build from the beginning and finish by installing the entire "
"system in chroot:"
msgstr ""
"Démarrer la construction depuis le début et terminer en installant tout le "
"système dans le chroot :"

#: minios-live:123
msgid "Start the build by building the base environment and run to completion:"
msgstr ""
"Démarrer la construction en créant l’environnement de base et aller jusqu’à "
"la fin :"

#: minios-live:126
msgid "Build only ISO image from previously prepared data:"
msgstr ""
"Construire uniquement l’image ISO à partir des données déjà préparées :"

