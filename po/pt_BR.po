#: linux-live/minioslib:693
msgid "Command not found:"
msgstr "Comando não encontrado:"

#: linux-live/minioslib:2759
msgid "grub.template.cfg template not found"
msgstr "Arquivo de modelo grub.template.cfg não encontrado"

#: minios-cmd:31 minios-live:70
msgid "Usage:"
msgstr "Uso:"

#: minios-cmd:32
msgid "Creates a system image with the specified parameters."
msgstr "Cria uma imagem de sistema com os parâmetros especificados."

#: minios-cmd:34
msgid "Options:"
msgstr "Opções:"

#: minios-cmd:36
msgid "Config Options:"
msgstr "Opções de Configuração:"

#: minios-cmd:37
msgid "Specify the configuration file path. All other options are ignored."
msgstr ""
"Especifique o caminho do arquivo de configuração. Todas as outras opções "
"serão ignoradas."

#: minios-cmd:38
msgid ""
"Generate the configuration file only and do not start the build process."
msgstr ""
"Gerar apenas o arquivo de configuração e não iniciar o processo de "
"compilação."

#: minios-cmd:40
msgid "Build Options:"
msgstr "Opções de Compilação:"

#: minios-cmd:41
msgid "Specify the build directory."
msgstr "Especifique o diretório de compilação."

#: minios-cmd:43
msgid "System Options:"
msgstr "Opções do Sistema:"

#: minios-cmd:44
msgid "Specify the distribution name (e.g., 'bookworm'). REQUIRED"
msgstr "Especifique o nome da distribuição (ex: 'bookworm'). OBRIGATÓRIO"

#: minios-cmd:45
msgid "Specify the architecture (e.g., 'amd64'). REQUIRED"
msgstr "Especifique a arquitetura (ex: 'amd64'). OBRIGATÓRIO"

#: minios-cmd:46
msgid "Specify the desktop environment (e.g., 'xfce'). REQUIRED"
msgstr "Especifique o ambiente de área de trabalho (ex: 'xfce'). OBRIGATÓRIO"

#: minios-cmd:47
msgid "Specify the package variant (e.g., 'standard'). REQUIRED"
msgstr "Especifique a variante do pacote (ex: 'standard'). OBRIGATÓRIO"

#: minios-cmd:48
msgid "Specify the compression type (e.g., 'zstd')."
msgstr "Especifique o tipo de compressão (ex: 'zstd')."

#: minios-cmd:50
msgid "Kernel Options:"
msgstr "Opções do Kernel:"

#: minios-cmd:51
msgid "Specify the kernel flavour (e.g., 'none')."
msgstr "Especifique o sabor do kernel (ex: 'none')."

#: minios-cmd:52
msgid "Enable AUFS support in the kernel."
msgstr "Habilitar o suporte AUFS no kernel."

#: minios-cmd:53
msgid "Enable compilation of additional drivers during kernel installation."
msgstr ""
"Habilitar a compilação de drivers adicionais durante a instalação do kernel."

#: minios-cmd:55
msgid "Locale and Timezone Options:"
msgstr "Opções de Localização e Fuso Horário:"

#: minios-cmd:56
msgid "Specify the system locale (e.g., 'en_US')."
msgstr "Especifique a localização do sistema (ex: 'en_US')."

#: minios-cmd:57
msgid "Enable multilingual support."
msgstr "Habilitar suporte multilíngue."

#: minios-cmd:58
msgid "Keep all available locales."
msgstr "Manter todas as localizações disponíveis."

#: minios-cmd:59
msgid "Specify the timezone (e.g., 'Etc/UTC')."
msgstr "Especifique o fuso horário (ex: 'Etc/UTC')."

#: minios-cmd:61
msgid "Boot Loader Options:"
msgstr "Opções do Boot Loader:"

#: minios-cmd:62
msgid "Specify the initramfs builder ('livekit' or 'dracut')."
msgstr "Especifique o construtor do initramfs ('livekit' ou 'dracut')."

#: minios-cmd:64
msgid "Boot Menu Options:"
msgstr "Opções do Menu de Inicialização:"

#: minios-cmd:65
msgid ""
"Specify the boot menu language ('multilang' for language selection or "
"specific language code like 'ru_RU')."
msgstr ""
"Especifique o idioma do menu de inicialização ('multilang' para seleção de "
"idioma ou um código de idioma específico como 'ru_RU')."

#: minios-cmd:67
msgid "Ubuntu Pro Options:"
msgstr "Opções do Ubuntu Pro:"

#: minios-cmd:68
msgid ""
"Specify Ubuntu Pro subscription token for fresh packages during build "
"(removed from final image)."
msgstr ""
"Informe o token de assinatura do Ubuntu Pro para obter pacotes atualizados "
"durante a construção (removido da imagem final)."

#: minios-cmd:70
msgid "Default Settings:"
msgstr "Configurações Padrão:"

#: minios-cmd:72
msgid "Kernel Settings:"
msgstr "Configurações do Kernel:"

#: minios-cmd:75
msgid "Locale & Timezone Settings:"
msgstr "Configurações de Localização e Fuso Horário:"

#: minios-cmd:79
msgid "Boot Loader Settings:"
msgstr "Configurações do Boot Loader:"

#: minios-cmd:82
msgid "Boot Menu Settings:"
msgstr "Configurações do Menu de Inicialização:"

#: minios-cmd:85 minios-live:76
msgid "Examples:"
msgstr "Exemplos:"

#: minios-cmd:87
msgid "1. Create a MiniOS Standard system image (default settings):"
msgstr "1. Criar uma imagem de sistema MiniOS Standard (configurações padrão):"

#: minios-cmd:90
msgid "2. Create a MiniOS Toolbox system image (default settings):"
msgstr "2. Criar uma imagem de sistema MiniOS Toolbox (configurações padrão):"

#: minios-cmd:93
msgid ""
"3. Create a system image with the 'bookworm' distribution, 'amd64' "
"architecture, 'toolbox' package variant, and Russian locale:"
msgstr ""
"3. Criar uma imagem de sistema com a distribuição 'bookworm', arquitetura "
"'amd64', variante de pacote 'toolbox' e localização russa:"

#: minios-cmd:96
msgid ""
"4. Create a system image with the 'bookworm' distribution, 'amd64' "
"architecture, 'standard' package variant and 'lxqt' desktop environment:"
msgstr ""
"4. Criar uma imagem de sistema com a distribuição 'bookworm', arquitetura "
"'amd64', variante de pacote 'standard' e ambiente de área de trabalho 'lxqt':"

#: minios-cmd:99
msgid ""
"5. Create a system image with 'buster' distribution, 'i386' architecture, "
"and 'xfce' desktop environment:"
msgstr ""
"5. Criar uma imagem de sistema com a distribuição 'buster', arquitetura "
"'i386' e ambiente de área de trabalho 'xfce':"

#: minios-cmd:102
msgid ""
"6. Create a system image with the 'jammy' distribution and 'standard' "
"package variant:"
msgstr ""
"6. Criar uma imagem de sistema com a distribuição 'jammy' e variante de "
"pacote 'standard':"

#: minios-cmd:105
msgid ""
"7. Create a system image with 'trixie' distribution, 'amd64' architecture, "
"and 'xfce' desktop environment with multilingual support enabled:"
msgstr ""
"7. Criar uma imagem de sistema com a distribuição 'trixie', arquitetura "
"'amd64', ambiente de área de trabalho 'xfce' e suporte multilíngue "
"habilitado:"

#: minios-cmd:108
msgid "8. Create a system image with Russian boot menu language:"
msgstr ""
"8. Criar uma imagem de sistema com o idioma do menu de inicialização em "
"russo:"

#: minios-cmd:111
msgid "9. Create a system image with livekit initramfs builder:"
msgstr "9. Crie uma imagem do sistema com o construtor de initramfs livekit:"

#: minios-cmd:114
msgid ""
"10. Create an Ubuntu system image with Ubuntu Pro subscription for fresh "
"packages:"
msgstr ""
"10. Crie uma imagem do sistema Ubuntu com assinatura Ubuntu Pro para pacotes "
"atualizados:"

#: minios-cmd:117
msgid ""
"has many more options available. Please refer to the above options list for "
"more details."
msgstr ""
"Muitas outras opções estão disponíveis. Consulte a lista de opções acima "
"para mais detalhes."

#: minios-live:56
msgid "This script builds bootable MiniOS ISO image."
msgstr "Este script cria uma imagem ISO MiniOS inicializável."

#: minios-live:61
msgid "Run the build from start to finish."
msgstr "Executar a compilação do início ao fim."

#: minios-live:62
msgid ""
"Start the build by building the base environment and finish by installing "
"the entire system in chroot."
msgstr ""
"Iniciar a compilação criando o ambiente base e finalizar instalando todo o "
"sistema em chroot."

#: minios-live:63
msgid ""
"Start the build from the beginning and finish by installing the entire "
"system in chroot."
msgstr ""
"Iniciar a compilação do início e finalizar instalando todo o sistema em "
"chroot."

#: minios-live:64
msgid "Start the build by building the base environment and run to completion."
msgstr ""
"Iniciar a compilação criando o ambiente base e executar até a conclusão."

#: minios-live:65
msgid "Build only ISO image from previously prepared data."
msgstr "Compilar apenas a imagem ISO a partir de dados preparados previamente."

#: minios-live:69
msgid "Supported commands:"
msgstr "Comandos suportados:"

#: minios-live:71
msgid "  Run from start_cmd to end_cmd"
msgstr "  Executar de start_cmd até end_cmd"

#: minios-live:72
msgid "  If start_cmd is omitted, start from the first command"
msgstr "  Se start_cmd for omitido, iniciar com o primeiro comando"

#: minios-live:73
msgid "  If end_cmd is omitted, end with the last command"
msgstr "  Se end_cmd for omitido, finalizar com o último comando"

#: minios-live:74
msgid "  Enter a single cmd to run the specific command"
msgstr "  Inserir um único cmd para executar o comando específico"

#: minios-live:75
msgid "  Enter '-' as the only argument to run all commands\\n"
msgstr "  Inserir '-' como único argumento para executar todos os comandos\\n"

