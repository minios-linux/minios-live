#: linux-live/minioslib:693 minios-live:149
msgid "Command not found:"
msgstr "Comando non trovato:"

#: linux-live/minioslib:2759
msgid "grub.template.cfg template not found"
msgstr "Template grub.template.cfg non trovato"

#: minios-cmd:48 minios-cmd:140 minios-live:86
msgid "Usage:"
msgstr "Utilizzo:"

#: minios-cmd:49
msgid "Creates a system image with the specified parameters."
msgstr "Crea un'immagine di sistema con i parametri specificati."

#: minios-cmd:51
msgid "Options:"
msgstr "Opzioni:"

#: minios-cmd:53
msgid "Config Options:"
msgstr "Opzioni di configurazione:"

#: minios-cmd:54
msgid "Specify the configuration file path. All other options are ignored."
msgstr ""
"Specificare il percorso del file di configurazione. Tutte le altre opzioni "
"verranno ignorate."

#: minios-cmd:55
msgid ""
"Generate the configuration file only and do not start the build process."
msgstr ""
"Generare solo il file di configurazione e non avviare il processo di "
"compilazione."

#: minios-cmd:57
msgid "Build Options:"
msgstr "Opzioni di compilazione:"

#: minios-cmd:58
msgid "Specify the build directory."
msgstr "Specificare la directory di compilazione."

#: minios-cmd:60
msgid "System Options:"
msgstr "Opzioni di sistema:"

#: minios-cmd:61
msgid "Specify the distribution name (e.g., 'bookworm'). REQUIRED"
msgstr "Specificare il nome della distribuzione (es. 'bookworm'). OBBLIGATORIO"

#: minios-cmd:62
msgid "Specify the architecture (e.g., 'amd64'). REQUIRED"
msgstr "Specificare l'architettura (es. 'amd64'). OBBLIGATORIO"

#: minios-cmd:63
msgid "Specify the desktop environment (e.g., 'xfce'). REQUIRED"
msgstr "Specificare l'ambiente desktop (es. 'xfce'). OBBLIGATORIO"

#: minios-cmd:64
msgid "Specify the package variant (e.g., 'standard'). REQUIRED"
msgstr "Specificare la variante del pacchetto (es. 'standard'). OBBLIGATORIO"

#: minios-cmd:65
msgid "Specify the compression type (e.g., 'zstd')."
msgstr "Specificare il tipo di compressione (es. 'zstd')."

#: minios-cmd:67
msgid "Kernel Options:"
msgstr "Opzioni del kernel:"

#: minios-cmd:68
msgid "Specify the kernel flavour (e.g., 'none')."
msgstr "Specificare il flavour del kernel (es. 'none')."

#: minios-cmd:69
msgid "Enable AUFS support in the kernel."
msgstr "Abilita il supporto AUFS nel kernel."

#: minios-cmd:70
msgid "Enable compilation of additional drivers during kernel installation."
msgstr ""
"Abilita la compilazione di driver aggiuntivi durante l'installazione del "
"kernel."

#: minios-cmd:72
msgid "Locale and Timezone Options:"
msgstr "Opzioni di impostazioni locali e fuso orario:"

#: minios-cmd:73
msgid "Specify the system locale (e.g., 'en_US')."
msgstr "Specificare le impostazioni locali di sistema (es. 'en_US')."

#: minios-cmd:74
msgid "Enable multilingual support."
msgstr "Abilita il supporto multilingue."

#: minios-cmd:75
msgid "Keep all available locales."
msgstr "Mantieni tutte le impostazioni locali disponibili."

#: minios-cmd:76
msgid "Specify the timezone (e.g., 'Etc/UTC')."
msgstr "Specificare il fuso orario (es. 'Etc/UTC')."

#: minios-cmd:78
msgid "Boot Loader Options:"
msgstr "Opzioni Boot Loader:"

#: minios-cmd:79
msgid "Specify the initramfs builder ('livekit' or 'dracut')."
msgstr "Specifica il builder initramfs ('livekit' o 'dracut')."

#: minios-cmd:81
msgid "Boot Menu Options:"
msgstr "Opzioni del menu di avvio:"

#: minios-cmd:82
msgid ""
"Specify the boot menu language ('multilang' for language selection or "
"specific language code like 'ru_RU')."
msgstr ""
"Specificare la lingua del menu di avvio ('multilang' per la selezione della "
"lingua o un codice lingua specifico come 'ru_RU')."

#: minios-cmd:84
msgid "Ubuntu Pro Options:"
msgstr "Opzioni Ubuntu Pro:"

#: minios-cmd:85
msgid ""
"Specify Ubuntu Pro subscription token for fresh packages during build "
"(removed from final image)."
msgstr ""
"Specifica il token di sottoscrizione Ubuntu Pro per pacchetti aggiornati "
"durante la build (rimosso dall'immagine finale)."

#: minios-cmd:87
msgid "Default Settings:"
msgstr "Impostazioni predefinite:"

#: minios-cmd:89
msgid "Kernel Settings:"
msgstr "Impostazioni del kernel:"

#: minios-cmd:92
msgid "Locale & Timezone Settings:"
msgstr "Impostazioni locali e fuso orario:"

#: minios-cmd:96
msgid "Boot Loader Settings:"
msgstr "Impostazioni Boot Loader:"

#: minios-cmd:99
msgid "Boot Menu Settings:"
msgstr "Impostazioni del menu di avvio:"

#: minios-cmd:102 minios-live:109
msgid "Examples:"
msgstr "Esempi:"

#: minios-cmd:104
msgid "1. Create a MiniOS Standard system image (default settings):"
msgstr ""
"1. Crea un'immagine di sistema MiniOS Standard (impostazioni predefinite):"

#: minios-cmd:107
msgid "2. Create a MiniOS Toolbox system image (default settings):"
msgstr ""
"2. Crea un'immagine di sistema MiniOS Toolbox (impostazioni predefinite):"

#: minios-cmd:110
msgid ""
"3. Create a system image with the 'bookworm' distribution, 'amd64' "
"architecture, 'toolbox' package variant, and Russian locale:"
msgstr ""
"3. Crea un'immagine di sistema con la distribuzione 'bookworm', architettura "
"'amd64', variante del pacchetto 'toolbox' e impostazioni locali russe:"

#: minios-cmd:113
msgid ""
"4. Create a system image with the 'bookworm' distribution, 'amd64' "
"architecture, 'standard' package variant and 'lxqt' desktop environment:"
msgstr ""
"4. Crea un'immagine di sistema con la distribuzione 'bookworm', architettura "
"'amd64', variante del pacchetto 'standard' e ambiente desktop 'lxqt':"

#: minios-cmd:116
msgid ""
"5. Create a system image with 'buster' distribution, 'i386' architecture, "
"and 'xfce' desktop environment:"
msgstr ""
"5. Crea un'immagine di sistema con la distribuzione 'buster', architettura "
"'i386' e ambiente desktop 'xfce':"

#: minios-cmd:119
msgid ""
"6. Create a system image with the 'jammy' distribution and 'standard' "
"package variant:"
msgstr ""
"6. Crea un'immagine di sistema con la distribuzione 'jammy' e la variante "
"del pacchetto 'standard':"

#: minios-cmd:122
msgid ""
"7. Create a system image with 'trixie' distribution, 'amd64' architecture, "
"and 'xfce' desktop environment with multilingual support enabled:"
msgstr ""
"7. Crea un'immagine di sistema con la distribuzione 'trixie', architettura "
"'amd64', ambiente desktop 'xfce' e supporto multilingue abilitato:"

#: minios-cmd:125
msgid "8. Create a system image with Russian boot menu language:"
msgstr "8. Crea un'immagine di sistema con il menu di avvio in lingua russa:"

#: minios-cmd:128
msgid "9. Create a system image with livekit initramfs builder:"
msgstr "9. Crea un'immagine di sistema con il builder initramfs livekit:"

#: minios-cmd:131
msgid ""
"10. Create an Ubuntu system image with Ubuntu Pro subscription for fresh "
"packages:"
msgstr ""
"10. Crea un'immagine di sistema Ubuntu con sottoscrizione Ubuntu Pro per "
"pacchetti aggiornati:"

#: minios-cmd:134
msgid ""
"has many more options available. Please refer to the above options list for "
"more details."
msgstr ""
"Sono disponibili molte altre opzioni. Fare riferimento all'elenco delle "
"opzioni sopra riportato per maggiori dettagli."

#: minios-cmd:141
msgid "Try '%s --help' for more information."
msgstr "Prova con '%s --help' per maggiori informazioni."

#: minios-live:87
msgid "This script builds bootable MiniOS ISO image."
msgstr "Questo script crea un'immagine ISO MiniOS avviabile."

#: minios-live:89
msgid "Commands:"
msgstr "Comandi:"

#: minios-live:91
msgid "Install a minimal base system using debootstrap"
msgstr "Installa un sistema base minimale utilizzando debootstrap"

#: minios-live:92
msgid "Install core components and desktop environment in chroot"
msgstr "Installa i componenti principali e l'ambiente desktop in chroot"

#: minios-live:93
msgid "Create the main SquashFS image of the core system"
msgstr "Crea l'immagine SquashFS principale del sistema core"

#: minios-live:94
msgid "Build additional SquashFS modules with extra packages"
msgstr "Crea moduli SquashFS aggiuntivi con pacchetti extra"

#: minios-live:95
msgid "Generate boot files, initrd, and boot configuration"
msgstr "Genera i file di boot, initrd e la configurazione di avvio"

#: minios-live:96
msgid "Generate configuration files for the build"
msgstr "Genera i file di configurazione per la build"

#: minios-live:97
msgid "Create the final bootable ISO image"
msgstr "Crea l'immagine ISO finale avviabile"

#: minios-live:98
msgid "Remove source files after the build"
msgstr "Rimuovi i file sorgente dopo la build"

#: minios-live:100
msgid "How it works:"
msgstr "Come funziona:"

#: minios-live:102
msgid "No arguments or -h/--help: display this help (no root required)"
msgstr "Nessun argomento o -h/--help: mostra questo aiuto (root non richiesto)"

#: minios-live:103
msgid "Single command: run only that build stage (requires root)"
msgstr "Comando singolo: esegue solo quella fase della build (richiede root)"

#: minios-live:104
msgid "start_cmd - end_cmd: run all commands in the range"
msgstr "start_cmd - end_cmd: esegue tutti i comandi nell'intervallo"

#: minios-live:105
msgid "Use '- end_cmd' to run from the first command to end_cmd"
msgstr "Usa '- end_cmd' per eseguire dal primo comando a end_cmd"

#: minios-live:106
msgid "Use 'start_cmd -' to run from start_cmd to the last command"
msgstr "Usa 'start_cmd -' per eseguire da start_cmd all'ultimo comando"

#: minios-live:107
msgid "Use '-' alone to run the entire build from start to finish"
msgstr "Usa '-' da solo per eseguire l'intera build dall'inizio alla fine"

#: minios-live:111
msgid "Display this help and exit:"
msgstr "Mostra questo aiuto ed esci:"

#: minios-live:114
msgid "Run the build from start to finish:"
msgstr "Esegui la build dall'inizio alla fine:"

#: minios-live:117
msgid ""
"Start the build by building the base environment and finish by installing "
"the entire system in chroot:"
msgstr ""
"Avvia la build creando l'ambiente base e termina installando l'intero "
"sistema in chroot:"

#: minios-live:120
msgid ""
"Start the build from the beginning and finish by installing the entire "
"system in chroot:"
msgstr ""
"Avvia la build dall'inizio e termina installando l'intero sistema in chroot:"

#: minios-live:123
msgid "Start the build by building the base environment and run to completion:"
msgstr ""
"Avvia la build creando l'ambiente base ed esegui fino al completamento:"

#: minios-live:126
msgid "Build only ISO image from previously prepared data:"
msgstr "Crea solo l'immagine ISO dai dati già preparati:"

