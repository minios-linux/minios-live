#: linux-live/minioslib:693 minios-live:149
msgid "Command not found:"
msgstr "Comando no encontrado:"

#: linux-live/minioslib:2759
msgid "grub.template.cfg template not found"
msgstr "No se encontró la plantilla grub.template.cfg"

#: minios-cmd:48 minios-cmd:140 minios-live:86
msgid "Usage:"
msgstr "Uso:"

#: minios-cmd:49
msgid "Creates a system image with the specified parameters."
msgstr "Crea una imagen del sistema con los parámetros especificados."

#: minios-cmd:51
msgid "Options:"
msgstr "Opciones:"

#: minios-cmd:53
msgid "Config Options:"
msgstr "Opciones de configuración:"

#: minios-cmd:54
msgid "Specify the configuration file path. All other options are ignored."
msgstr ""
"Especifique la ruta del archivo de configuración. Se ignorarán todas las "
"demás opciones."

#: minios-cmd:55
msgid ""
"Generate the configuration file only and do not start the build process."
msgstr ""
"Generar solo el archivo de configuración y no iniciar el proceso de "
"compilación."

#: minios-cmd:57
msgid "Build Options:"
msgstr "Opciones de compilación:"

#: minios-cmd:58
msgid "Specify the build directory."
msgstr "Especifique el directorio de compilación."

#: minios-cmd:60
msgid "System Options:"
msgstr "Opciones del sistema:"

#: minios-cmd:61
msgid "Specify the distribution name (e.g., 'bookworm'). REQUIRED"
msgstr "Especifique el nombre de la distribución (ej. 'bookworm'). OBLIGATORIO"

#: minios-cmd:62
msgid "Specify the architecture (e.g., 'amd64'). REQUIRED"
msgstr "Especifique la arquitectura (ej. 'amd64'). OBLIGATORIO"

#: minios-cmd:63
msgid "Specify the desktop environment (e.g., 'xfce'). REQUIRED"
msgstr "Especifique el entorno de escritorio (ej. 'xfce'). OBLIGATORIO"

#: minios-cmd:64
msgid "Specify the package variant (e.g., 'standard'). REQUIRED"
msgstr "Especifique la variante del paquete (ej. 'standard'). OBLIGATORIO"

#: minios-cmd:65
msgid "Specify the compression type (e.g., 'zstd')."
msgstr "Especifique el tipo de compresión (ej. 'zstd')."

#: minios-cmd:67
msgid "Kernel Options:"
msgstr "Opciones del kernel:"

#: minios-cmd:68
msgid "Specify the kernel flavour (e.g., 'none')."
msgstr "Especifique el sabor del kernel (ej. 'none')."

#: minios-cmd:69
msgid "Enable AUFS support in the kernel."
msgstr "Habilitar la compatibilidad con AUFS en el kernel."

#: minios-cmd:70
msgid "Enable compilation of additional drivers during kernel installation."
msgstr ""
"Habilitar la compilación de controladores adicionales durante la instalación "
"del kernel."

#: minios-cmd:72
msgid "Locale and Timezone Options:"
msgstr "Opciones de configuración regional y zona horaria:"

#: minios-cmd:73
msgid "Specify the system locale (e.g., 'en_US')."
msgstr "Especifique la configuración regional del sistema (ej. 'en_US')."

#: minios-cmd:74
msgid "Enable multilingual support."
msgstr "Habilitar la compatibilidad con varios idiomas."

#: minios-cmd:75
msgid "Keep all available locales."
msgstr "Mantener todas las configuraciones regionales disponibles."

#: minios-cmd:76
msgid "Specify the timezone (e.g., 'Etc/UTC')."
msgstr "Especifique la zona horaria (ej. 'Etc/UTC')."

#: minios-cmd:78
msgid "Boot Loader Options:"
msgstr "Opciones del gestor de arranque:"

#: minios-cmd:79
msgid "Specify the initramfs builder ('livekit' or 'dracut')."
msgstr "Especifique el generador de initramfs ('livekit' o 'dracut')."

#: minios-cmd:81
msgid "Boot Menu Options:"
msgstr "Opciones del menú de arranque:"

#: minios-cmd:82
msgid ""
"Specify the boot menu language ('multilang' for language selection or "
"specific language code like 'ru_RU')."
msgstr ""
"Especifique el idioma del menú de arranque ('multilang' para selección de "
"idioma o un código de idioma específico como 'ru_RU')."

#: minios-cmd:84
msgid "Ubuntu Pro Options:"
msgstr "Opciones de Ubuntu Pro:"

#: minios-cmd:85
msgid ""
"Specify Ubuntu Pro subscription token for fresh packages during build "
"(removed from final image)."
msgstr ""
"Especifique el token de suscripción de Ubuntu Pro para obtener paquetes "
"actualizados durante la compilación (se elimina de la imagen final)."

#: minios-cmd:87
msgid "Default Settings:"
msgstr "Ajustes predeterminados:"

#: minios-cmd:89
msgid "Kernel Settings:"
msgstr "Ajustes del kernel:"

#: minios-cmd:92
msgid "Locale & Timezone Settings:"
msgstr "Ajustes de configuración regional y zona horaria:"

#: minios-cmd:96
msgid "Boot Loader Settings:"
msgstr "Configuración del gestor de arranque:"

#: minios-cmd:99
msgid "Boot Menu Settings:"
msgstr "Ajustes del menú de arranque:"

#: minios-cmd:102 minios-live:109
msgid "Examples:"
msgstr "Ejemplos:"

#: minios-cmd:104
msgid "1. Create a MiniOS Standard system image (default settings):"
msgstr ""
"1. Crear una imagen del sistema MiniOS Standard (ajustes predeterminados):"

#: minios-cmd:107
msgid "2. Create a MiniOS Toolbox system image (default settings):"
msgstr ""
"2. Crear una imagen del sistema MiniOS Toolbox (ajustes predeterminados):"

#: minios-cmd:110
msgid ""
"3. Create a system image with the 'bookworm' distribution, 'amd64' "
"architecture, 'toolbox' package variant, and Russian locale:"
msgstr ""
"3. Crear una imagen del sistema con la distribución 'bookworm', arquitectura "
"'amd64', variante de paquete 'toolbox' y configuración regional rusa:"

#: minios-cmd:113
msgid ""
"4. Create a system image with the 'bookworm' distribution, 'amd64' "
"architecture, 'standard' package variant and 'lxqt' desktop environment:"
msgstr ""
"4. Crear una imagen del sistema con la distribución 'bookworm', arquitectura "
"'amd64', variante de paquete 'standard' y entorno de escritorio 'lxqt':"

#: minios-cmd:116
msgid ""
"5. Create a system image with 'buster' distribution, 'i386' architecture, "
"and 'xfce' desktop environment:"
msgstr ""
"5. Crear una imagen del sistema con la distribución 'buster', arquitectura "
"'i386' y entorno de escritorio 'xfce':"

#: minios-cmd:119
msgid ""
"6. Create a system image with the 'jammy' distribution and 'standard' "
"package variant:"
msgstr ""
"6. Crear una imagen del sistema con la distribución 'jammy' y la variante de "
"paquete 'standard':"

#: minios-cmd:122
msgid ""
"7. Create a system image with 'trixie' distribution, 'amd64' architecture, "
"and 'xfce' desktop environment with multilingual support enabled:"
msgstr ""
"7. Crear una imagen del sistema con la distribución 'trixie', arquitectura "
"'amd64', entorno de escritorio 'xfce' y compatibilidad con varios idiomas "
"habilitada:"

#: minios-cmd:125
msgid "8. Create a system image with Russian boot menu language:"
msgstr ""
"8. Crear una imagen del sistema con el idioma ruso en el menú de arranque:"

#: minios-cmd:128
msgid "9. Create a system image with livekit initramfs builder:"
msgstr "9. Crear una imagen del sistema con el generador de initramfs livekit:"

#: minios-cmd:131
msgid ""
"10. Create an Ubuntu system image with Ubuntu Pro subscription for fresh "
"packages:"
msgstr ""
"10. Crear una imagen del sistema Ubuntu con suscripción Ubuntu Pro para "
"paquetes actualizados:"

#: minios-cmd:134
msgid ""
"has many more options available. Please refer to the above options list for "
"more details."
msgstr ""
"Tiene muchas más opciones disponibles. Consulte la lista de opciones "
"anterior para obtener más detalles."

#: minios-cmd:141
msgid "Try '%s --help' for more information."
msgstr "Prueba '%s --help' para más información."

#: minios-live:87
msgid "This script builds bootable MiniOS ISO image."
msgstr "Este script crea una imagen ISO de MiniOS de arranque."

#: minios-live:89
msgid "Commands:"
msgstr "Comandos:"

#: minios-live:91
msgid "Install a minimal base system using debootstrap"
msgstr "Instala un sistema base mínimo usando debootstrap"

#: minios-live:92
msgid "Install core components and desktop environment in chroot"
msgstr ""
"Instala los componentes principales y el entorno de escritorio en chroot"

#: minios-live:93
msgid "Create the main SquashFS image of the core system"
msgstr "Crea la imagen principal SquashFS del sistema base"

#: minios-live:94
msgid "Build additional SquashFS modules with extra packages"
msgstr "Genera módulos adicionales SquashFS con paquetes extra"

#: minios-live:95
msgid "Generate boot files, initrd, and boot configuration"
msgstr "Genera archivos de arranque, initrd y la configuración de arranque"

#: minios-live:96
msgid "Generate configuration files for the build"
msgstr "Genera archivos de configuración para la compilación"

#: minios-live:97
msgid "Create the final bootable ISO image"
msgstr "Crea la imagen ISO final booteable"

#: minios-live:98
msgid "Remove source files after the build"
msgstr "Elimina los archivos fuente después de la compilación"

#: minios-live:100
msgid "How it works:"
msgstr "Cómo funciona:"

#: minios-live:102
msgid "No arguments or -h/--help: display this help (no root required)"
msgstr "Sin argumentos o -h/--help: muestra esta ayuda (no requiere root)"

#: minios-live:103
msgid "Single command: run only that build stage (requires root)"
msgstr "Comando único: ejecuta solo esa etapa de compilación (requiere root)"

#: minios-live:104
msgid "start_cmd - end_cmd: run all commands in the range"
msgstr "start_cmd - end_cmd: ejecuta todos los comandos en ese rango"

#: minios-live:105
msgid "Use '- end_cmd' to run from the first command to end_cmd"
msgstr "Usa '- end_cmd' para ejecutar desde el primer comando hasta end_cmd"

#: minios-live:106
msgid "Use 'start_cmd -' to run from start_cmd to the last command"
msgstr ""
"Usa 'start_cmd -' para ejecutar desde start_cmd hasta el último comando"

#: minios-live:107
msgid "Use '-' alone to run the entire build from start to finish"
msgstr "Usa '-' solo para ejecutar toda la compilación de principio a fin"

#: minios-live:111
msgid "Display this help and exit:"
msgstr "Muestra esta ayuda y sale:"

#: minios-live:114
msgid "Run the build from start to finish:"
msgstr "Ejecuta la compilación de principio a fin:"

#: minios-live:117
msgid ""
"Start the build by building the base environment and finish by installing "
"the entire system in chroot:"
msgstr ""
"Inicia la compilación construyendo el entorno base y finaliza instalando "
"todo el sistema en chroot:"

#: minios-live:120
msgid ""
"Start the build from the beginning and finish by installing the entire "
"system in chroot:"
msgstr ""
"Inicia la compilación desde el principio y finaliza instalando todo el "
"sistema en chroot:"

#: minios-live:123
msgid "Start the build by building the base environment and run to completion:"
msgstr ""
"Inicia la compilación construyendo el entorno base y ejecuta hasta completar:"

#: minios-live:126
msgid "Build only ISO image from previously prepared data:"
msgstr ""
"Compila solo la imagen ISO a partir de los datos preparados previamente:"

