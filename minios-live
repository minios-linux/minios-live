#!/bin/bash

# Author: Marcos Tischer Vallim. <https://github.com/mvallim>
# Author: crims0n. <https://minios.dev>

set -e          # exit on error
set -o pipefail # exit on pipeline error
set -u          # treat unset variable as error

SET_E=""
SET_U=""

# ---[ CONSTANTS & VARIABLES ]---
SCRIPT_DIR="$(dirname "$(readlink -f "${0}")")"
export TEXTDOMAIN="minios-live"
if [[ "$SCRIPT_DIR" == "/usr/bin" ]]; then
    export TEXTDOMAINDIR="/usr/share/locale"
else
    export TEXTDOMAINDIR="$SCRIPT_DIR/locale"
    if [[ -d "$SCRIPT_DIR/po" ]]; then
        if command -v msgfmt >/dev/null 2>&1; then
            for po_file in "$SCRIPT_DIR"/po/*.po; do
                [[ -f "$po_file" ]] || continue
                lang=$(basename "$po_file" .po)
                mo_file="$TEXTDOMAINDIR/$lang/LC_MESSAGES/minios-live.mo"
                if [[ ! -f "$mo_file" || "$po_file" -nt "$mo_file" ]]; then
                    mkdir -p "$(dirname "$mo_file")"
                    msgfmt -o "$mo_file" "$po_file" 2>/dev/null || true
                fi
            done
        fi
    fi
fi
: "${MAIN_EXECUTABLE:="minios-live"}"
: "${BUILD_SCRIPTS:="linux-live"}"
: "${RELEASE_VERSION:=""}"
: "${RELEASE:="false"}"
[ -n "${RELEASE_VERSION}" ] && RELEASE="true"

if [[ "$SCRIPT_DIR" == "/usr/bin" ]]; then
    BUILD_SCRIPTS_DIR="/usr/share/minios-live"
    : "${BUILD_CONF:="/etc/minios-live/build.conf"}"
    : "${BUILD_DIR:="$PWD/build"}"
else
    BUILD_SCRIPTS_DIR="$SCRIPT_DIR/$BUILD_SCRIPTS"
    : "${BUILD_CONF:="$BUILD_SCRIPTS_DIR/build.conf"}"
    : "${BUILD_DIR:="$SCRIPT_DIR/build"}"
fi
export DEBIAN_FRONTEND=noninteractive
export LIBMOUNT_FORCE_MOUNT2=always

MINIOSLIB="${BUILD_SCRIPTS_DIR}/minioslib"

# ---[ SOURCE FILES ]---
. "$MINIOSLIB" || exit 1

console_colors

# ---[ INITIALIZE BUILD DIRECTORY & CONFIGURATION ]---
if [[ "$MAIN_EXECUTABLE" = "minios-cmd" && ! -f "$BUILD_CONF" ]]; then
    if [[ "$SCRIPT_DIR" == "/usr/bin" ]]; then
        cp "/etc/minios-live/build.conf" "$BUILD_CONF"
    else
        cp "$SCRIPT_DIR/$BUILD_SCRIPTS/build.conf" "$BUILD_CONF"
    fi
fi

. "$BUILD_CONF" || exit 1
export VERBOSITY_LEVEL

[ "${VERBOSITY_LEVEL}" -ge 2 ] && export PS4='+ ${BASH_SOURCE}:${LINENO}: ' && set -x

# ---[ FUNCTIONS ]---
help() {
    local HEADLINE="${1:-}"
    local PROG
    PROG="$(basename "$0")"

    console_colors

    if [[ -n "${HEADLINE}" ]]; then
        echo -e "${LIGHTRED}${HEADLINE}${ENDCOLOR}"
        echo ""
    fi

    echo -e "${BOLD}$(gettext "Usage:")${ENDCOLOR} ${PROG} [-h | --help] [start_cmd] [-] [end_cmd]"
    echo "$(gettext "This script builds bootable MiniOS ISO image.")"
    echo ""
    echo -e "${BOLD}$(gettext "Commands:")${ENDCOLOR}"
    echo ""
    echo -e "  ${LIGHTGREEN}build-bootstrap${ENDCOLOR}   $(gettext "Install a minimal base system using debootstrap")"
    echo -e "  ${LIGHTGREEN}build-chroot${ENDCOLOR}      $(gettext "Install core components and desktop environment in chroot")"
    echo -e "  ${LIGHTGREEN}build-live${ENDCOLOR}        $(gettext "Create the main SquashFS image of the core system")"
    echo -e "  ${LIGHTGREEN}build-modules${ENDCOLOR}     $(gettext "Build additional SquashFS modules with extra packages")"
    echo -e "  ${LIGHTGREEN}build-boot${ENDCOLOR}        $(gettext "Generate boot files, initrd, and boot configuration")"
    echo -e "  ${LIGHTGREEN}build-config${ENDCOLOR}      $(gettext "Generate configuration files for the build")"
    echo -e "  ${LIGHTGREEN}build-iso${ENDCOLOR}         $(gettext "Create the final bootable ISO image")"
    echo -e "  ${LIGHTGREEN}remove-sources${ENDCOLOR}    $(gettext "Remove source files after the build")"
    echo ""
    echo -e "${BOLD}$(gettext "How it works:")${ENDCOLOR}"
    echo ""
    echo -e "  $(gettext "No arguments or -h/--help: display this help (no root required)")"
    echo -e "  $(gettext "Single command: run only that build stage (requires root)")"
    echo -e "  $(gettext "start_cmd - end_cmd: run all commands in the range")"
    echo -e "  $(gettext "Use '- end_cmd' to run from the first command to end_cmd")"
    echo -e "  $(gettext "Use 'start_cmd -' to run from start_cmd to the last command")"
    echo -e "  $(gettext "Use '-' alone to run the entire build from start to finish")"
    echo ""
    echo -e "${BOLD}$(gettext "Examples:")${ENDCOLOR}"
    echo ""
    echo -e "  $(gettext "Display this help and exit:")"
    echo -e "     ${PROG} -h"
    echo ""
    echo -e "  $(gettext "Run the build from start to finish:")"
    echo -e "     ${PROG} -"
    echo ""
    echo -e "  $(gettext "Start the build by building the base environment and finish by installing the entire system in chroot:")"
    echo -e "     ${PROG} build-bootstrap - build-chroot"
    echo ""
    echo -e "  $(gettext "Start the build from the beginning and finish by installing the entire system in chroot:")"
    echo -e "     ${PROG} - build-chroot"
    echo ""
    echo -e "  $(gettext "Start the build by building the base environment and run to completion:")"
    echo -e "     ${PROG} build-bootstrap -"
    echo ""
    echo -e "  $(gettext "Build only ISO image from previously prepared data:")"
    echo -e "     ${PROG} build-iso"

    exit 0
}

# Validate command arguments and show help without requiring root.
validate_command_args() {
    if (($# < 1 || $# > 3)); then
        help
    fi

    local ARG i FOUND
    for ARG in "$@"; do
        [[ "${ARG}" == "-" ]] && continue
        FOUND=false
        for ((i = 0; i < "${#CMD[@]}"; i++)); do
            if [[ "${CMD[i]}" == "${ARG}" ]]; then
                FOUND=true
                break
            fi
        done
        if [[ "${FOUND}" == "false" ]]; then
            help "$(gettext 'Command not found:') ${ARG}"
        fi
    done
}

# ---[ BUILD PATHS AND DIRECTORIES ]---
APTCACHE_DIR="$BUILD_DIR/aptcache/$DISTRIBUTION"
ROOTFS_TARBALL="$BUILD_DIR/rootfs/$DISTRIBUTION-$DISTRIBUTION_ARCH-rootfs.tar.gz"
ISO_DIR="$BUILD_DIR/iso"
WORK_DIR="$BUILD_DIR/$DISTRIBUTION-$PACKAGE_VARIANT-$DISTRIBUTION_ARCH"
INSTALL_DIR="$WORK_DIR/core"
EXCLUDE_CORE_FILE="$WORK_DIR/squashfs-core-exclude"

# ---[ COMMANDS ]---
CMD=(build_bootstrap build_chroot build_live build_modules build_boot build_config build_iso remove_sources)

if [[ "$#" -eq 0 ]] || [[ "${1:-}" == "-h" ]] || [[ "${1:-}" == "--help" ]]; then
    help
fi

# normalize both hyphens and underscores into underscore form,
# but leave lone "-" untouched
ARGS=("$@")
for idx in "${!ARGS[@]}"; do
    [[ "${ARGS[$idx]}" == "-" ]] && continue
    ARGS[$idx]="${ARGS[$idx]//-/_}"
done

validate_command_args "${ARGS[@]}"

# ----[ MAIN ]----
allow_root_only

create_log_file "$@"

set -- "${ARGS[@]}"

#trap 'mountpoint -q "$WORK_DIR" && unmount_dirs "$WORK_DIR"' EXIT
trap 'mountpoint -q "$WORK_DIR" && unmount_dirs "$WORK_DIR"; [ "${USE_APT_CACHE_REPO}" = "true" ] && stop_http_server' EXIT

common_variables

if [[ " ${CMD[@]:-} " =~ " ${1:-} " ]] || [[ "${1:-}" == "-" ]]; then
    if [ "${USE_APT_CACHE_REPO}" = "false" ]; then
        toggle_shell_options e
        check_internet_connection
        toggle_shell_options e
    fi

    [[ "${CONTAINER,,}" == "true" ]] && new_run

    mkdir -p "${INSTALL_DIR}"

    generate_chroot_configuration_file "$WORK_DIR/minios_build.conf"

    ensure_host_prerequisites

    #generate_squashfs_exclude_file "${EXCLUDE_CORE_FILE}" "${INSTALL_DIR}"

fi

determine_command_range "$@"

# Run commands within the defined range.
for ((ii = START_INDEX; ii < END_INDEX; ii++)); do
    "${CMD[ii]}"
done

echo -e "${BOLD}${LIGHTYELLOW}$0${ENDCOLOR} - ${LIGHTGREEN}Command completed successfully!${ENDCOLOR}"
